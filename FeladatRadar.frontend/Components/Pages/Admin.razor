    .admin-inline-input:focus { box-shadow:0 0 0 2px var(--accent-subtle); }
    .admin-rename-btn { background:none; border:none; cursor:pointer; font-size:.65rem; opacity:.3; transition:opacity .15s; padding:0 2px; vertical-align:middle; }
    .admin-rename-btn:hover { opacity:1; }

    /* ── Modal ── */
    .admin-modal-backdrop { position:fixed; inset:0; z-index:999; background:rgba(26,22,48,.5); backdrop-filter:blur(4px); display:flex; align-items:center; justify-content:center; padding:16px; }
    .admin-modal { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:24px; width:100%; max-width:420px; box-shadow:0 12px 40px rgba(0,0,0,.2); }
    .admin-modal-title { font-size:1.1rem; font-weight:700; margin-bottom:12px; color:var(--text-primary); }
    .admin-modal-body { font-size:.88rem; color:var(--text-secondary); margin-bottom:20px; line-height:1.5; }
    .admin-modal-actions { display:flex; gap:8px; justify-content:flex-end; flex-wrap:wrap; }
    .admin-modal-btn { padding:8px 20px; border:none; border-radius:8px; font-size:.84rem; font-weight:600; cursor:pointer; font-family:var(--font); transition:all .12s; }
    .admin-modal-cancel { background:var(--surface-2); color:var(--text-secondary); }
    .admin-modal-cancel:hover { background:var(--border); }
    .admin-modal-confirm { background:#e53935; color:#fff; }
    .admin-modal-confirm:hover { background:#c62828; }

    /* ── Mobile card view (hidden on desktop) ── */
    .admin-mobile-cards { display:none; flex-direction:column; gap:10px; }
    .admin-user-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:14px 16px; display:flex; flex-direction:column; gap:10px; }
    .admin-card-inactive { opacity:.55; }
    .admin-card-header { display:flex; align-items:flex-start; justify-content:space-between; gap:10px; }
    .admin-card-name-block { flex:1; min-width:0; display:flex; flex-direction:column; gap:3px; }
    .admin-card-fullname { font-weight:700; font-size:.9rem; color:var(--text-primary); display:flex; align-items:center; gap:4px; flex-wrap:wrap; }
    .admin-card-username { font-size:.78rem; color:var(--text-muted); }
    .admin-card-email { font-size:.8rem; color:var(--text-secondary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .admin-card-badges { display:flex; gap:4px; flex-wrap:wrap; flex-shrink:0; }
    .admin-card-footer { display:flex; align-items:center; justify-content:space-between; gap:8px; flex-wrap:wrap; }
    .admin-card-date { font-size:.72rem; color:var(--text-muted); }
    .admin-card-actions { display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
    .admin-card-empty { padding:32px; text-align:center; color:var(--text-muted); font-size:.875rem; }
    .admin-audit-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:2px; }
    .admin-audit-title { font-size:.82rem; font-weight:600; color:var(--text-secondary); }

    /* ══════════════════════════════
       RESPONSIVE BREAKPOINTS
    ══════════════════════════════ */

    /* Tablet: 768px – 1100px — hide some table columns */
    @@media (max-width:1100px) {
        .admin-col-email, .admin-col-username { display:none; }
        .admin-td-email { display:none; }
        .fr-content { padding:16px 18px; }
    }

    
    @@media (max-width:767px) {
        .admin-stats-grid { grid-template-columns:repeat(2,1fr); }
        .admin-detail-grid { grid-template-columns:1fr; }
        .admin-desktop-table { display:none !important; }
        .admin-mobile-cards { display:flex; }
        .fr-content { padding:12px; gap:10px; }
        .admin-tab { padding:7px 10px; font-size:.75rem; }
        .admin-tab svg { display:none; }
        .admin-tab-count { display:none; }
        .admin-email-text { display:none; }
    }

    
    @@media (max-width:480px) {
        .admin-stats-grid { grid-template-columns:1fr 1fr; gap:8px; }
        .admin-stat-card { padding:14px 10px; }
        .admin-stat-num { font-size:1.8rem; }
        .admin-tab { padding:6px 8px; font-size:.7rem; }
        .admin-inline-input { width:68px; font-size:.72rem; }
        .admin-modal { padding:18px; }
        .fr-content { padding:10px; }
        .admin-detail-row { padding:8px 14px; font-size:.8rem; }
        .admin-pill { padding:5px 10px; font-size:.7rem; }
    }
</style>

@code {
    private bool _menuOpen = false;
    private string SidebarClass => _menuOpen ? "fr-sidebar fr-sidebar-open" : "fr-sidebar";
    private string LayoutClass => _menuOpen ? "fr-layout fr-menu-open" : "fr-layout";
    private void ToggleMenu() { _menuOpen = !_menuOpen; StateHasChanged(); }
    private void CloseMenu() { _menuOpen = false; StateHasChanged(); }
    private bool _hasCheckedAuth = false;
    private bool _isAuthenticated = false;
    private string _userRole = "";
    private string _userEmail = "";
    private string _theme = "light";
    private bool _isLoading = true;

    private string _activeTab = "stats";

    private SystemStatsDto _stats = new();
    private List<AdminUserDto> _allUsers = new();
    private List<AdminGroupDto> _allGroups = new();
    private List<AuditLogEntry> _auditLog = new();

    private string _userSearch = "";
    private string _userFilter = "all";
    private string _groupSearch = "";

    private string _toastMessage = "";
    private bool _toastIsError = false;

    private bool _confirmVisible = false;
    private string _confirmMessage = "";
    private Func<Task>? _confirmAction = null;

    private int _editingUserId = 0;
    private string _editFirstName = "";
    private string _editLastName = "";

    private void StartRename(AdminUserDto user)
    {
        _editingUserId = user.UserID;
        _editFirstName = user.FirstName;
        _editLastName = user.LastName;
    }

    private async Task SaveRename(AdminUserDto user)
    {
        if (string.IsNullOrWhiteSpace(_editFirstName) || string.IsNullOrWhiteSpace(_editLastName))
        { ShowToast("Mindkét névmező kitöltése kötelező.", true); return; }
        var result = await AdminService.RenameUserAsync(user.UserID, _editFirstName.Trim(), _editLastName.Trim());
        if (result.Status == "OK")
        {
            user.FirstName = _editFirstName.Trim();
            user.LastName = _editLastName.Trim();
            _editingUserId = 0;
            ShowToast("Név módosítva.");
        }
        else ShowToast(result.Message, true);
    }

    private IEnumerable<AdminUserDto> FilteredUsers
    {
        get
        {
            var q = _allUsers.AsEnumerable();
            if (_userFilter != "all")
                q = q.Where(u => u.UserRole == _userFilter);
            if (!string.IsNullOrWhiteSpace(_userSearch))
            {
                var s = _userSearch.ToLower();
                q = q.Where(u =>
                    u.Username.ToLower().Contains(s) ||
                    u.Email.ToLower().Contains(s) ||
                    u.FirstName.ToLower().Contains(s) ||
                    u.LastName.ToLower().Contains(s));
            }
            return q;
        }
    }

    private IEnumerable<AdminGroupDto> FilteredGroups
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_groupSearch)) return _allGroups;
            var s = _groupSearch.ToLower();
            return _allGroups.Where(g =>
                g.GroupName.ToLower().Contains(s) ||
                g.OwnerName.ToLower().Contains(s));
        }
    }

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.setTheme", _theme);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        try { await AuthService.InitializeAsync(); } catch { }
        _hasCheckedAuth = true;
        _isAuthenticated = AuthService.IsAuthenticated;
        _userEmail = AuthService.CurrentUser?.Email ?? "";
        _userRole = AuthService.CurrentUser?.UserRole ?? "";
        if (!_isAuthenticated) { Navigation.NavigateTo("/login"); return; }
        if (_userRole != "Admin") { StateHasChanged(); return; }
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _isLoading = true; StateHasChanged();
        try { _stats = await AdminService.GetSystemStatsAsync(); } catch { _stats = new(); }
        try { _allUsers = await AdminService.GetAllUsersAsync(); } catch { _allUsers = new(); }
        try { _allGroups = await AdminService.GetAllGroupsAsync(); } catch { _allGroups = new(); }
        _isLoading = false; StateHasChanged();
    }

    private async Task LoadAuditLog()
    {
        try { _auditLog = await AdminService.GetAuditLogAsync(); } catch { _auditLog = new(); }
        StateHasChanged();
    }

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        if (tab == "audit" && !_auditLog.Any())
            await LoadAuditLog();
        StateHasChanged();
    }

    private void ShowToast(string message, bool isError = false)
    {
        _toastMessage = message;
        _toastIsError = isError;
        StateHasChanged();
    }

    private void ShowConfirm(string message, Func<Task> action)
    {
        _confirmMessage = message;
        _confirmAction = action;
        _confirmVisible = true;
        StateHasChanged();
    }

    private async Task ConfirmAction()
    {
        _confirmVisible = false;
        if (_confirmAction != null)
            await _confirmAction();
        StateHasChanged();
    }

    private async Task HandleRoleChange(int userId, string newRole)
    {
        var result = await AdminService.ChangeUserRoleAsync(userId, newRole);
        if (result.Status == "OK")
        {
            var u = _allUsers.FirstOrDefault(x => x.UserID == userId);
            if (u != null) u.UserRole = newRole;
            ShowToast($"Szerepkör módosítva: {newRole}");
        }
        else ShowToast(result.Message, true);
    }

    private void HandleToggleActive(int userId, bool activate)
    {
        var u = _allUsers.FirstOrDefault(x => x.UserID == userId);
        var name = u != null ? $"{u.FirstName} {u.LastName}" : $"#{userId}";
        var msg = activate
            ? $"Biztosan aktiválod {name} felhasználót?"
            : $"Biztosan letiltod {name} felhasználót?";

        ShowConfirm(msg, async () =>
        {
            var result = await AdminService.ToggleUserActiveAsync(userId, activate);
            if (result.Status == "OK")
            {
                if (u != null) u.IsActive = activate;
                ShowToast(result.Message);
            }
            else ShowToast(result.Message, true);
        });
    }

    private void HandleDeleteUser(AdminUserDto user)
    {
        ShowConfirm($"Biztosan TÖRLÖD {user.FirstName} {user.LastName} ({user.Username}) felhasználót? Ez nem vonható vissza!", async () =>
        {
            var result = await AdminService.DeleteUserAsync(user.UserID);
            if (result.Status == "OK")
            {
                _allUsers.RemoveAll(u => u.UserID == user.UserID);
                ShowToast(result.Message);
            }
            else ShowToast(result.Message, true);
        });
    }

    private void HandleDeleteGroup(AdminGroupDto group)
    {
        ShowConfirm($"Biztosan törlöd a \"{group.GroupName}\" csoportot ({group.MemberCount} taggal)? Ez nem vonható vissza!", async () =>
        {
            var result = await AdminService.DeleteGroupAsync(group.GroupID);
            if (result.Status == "OK")
            {
                _allGroups.RemoveAll(g => g.GroupID == group.GroupID);
                ShowToast(result.Message);
            }
            else ShowToast(result.Message, true);
        });
    }

    private string TranslateAction(string action) => action switch
    {
        "CHANGE_ROLE" or "ChangeUserRole" => "Szerepkör módosítás",
        "ACTIVATE_USER" or "ToggleUserActive" => "Aktiválás/Tiltás",
        "DEACTIVATE_USER" => "Felhasználó tiltás",
        "DELETE_USER" or "DeleteUser" => "Felhasználó törlés",
        "DELETE_GROUP" or "DeleteGroup" => "Csoport törlés",
        "DELETE_POLL" or "AdminDeletePoll" => "Szavazás törlés",
        "DELETE_EXAM" or "AdminDeleteExam" => "Dolgozat törlés",
        "DELETE_TASK" or "AdminDeleteTask" => "Feladat törlés",
        "RenameUser" => "Felhasználó átnevezés",
        _ => action
    };

    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
}
