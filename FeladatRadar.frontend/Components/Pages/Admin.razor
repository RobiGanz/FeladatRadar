    .admin-badge-warn { background:var(--danger-subtle); color:var(--danger); }
    .admin-badge-student { background:rgba(102,126,234,.12); color:#667eea; }
    .admin-badge-teacher { background:rgba(245,158,11,.12); color:#f59e0b; }
    .admin-badge-admin { background:rgba(229,57,53,.1); color:#e53935; }
    .admin-badge-action { background:var(--accent-subtle); color:var(--accent); }

    /* ── Action buttons ── */
    .admin-act-btn { width:28px; height:28px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .12s; flex-shrink:0; }
    .admin-act-warn { color:var(--warning); }
    .admin-act-warn:hover { background:var(--warning-subtle); border-color:var(--warning); }
    .admin-act-ok { color:var(--success); }
    .admin-act-ok:hover { background:var(--success-subtle); border-color:var(--success); }
    .admin-act-danger { color:var(--danger); }
    .admin-act-danger:hover { background:var(--danger-subtle); border-color:var(--danger); }

    /* ── Rename inline ── */
    .admin-rename-row { display:flex; gap:4px; align-items:center; flex-wrap:wrap; }
    .admin-rename-row-mobile { display:flex; gap:4px; align-items:center; flex-wrap:wrap; }
