    .admin-tab:hover { color:var(--text-primary); background:var(--surface-2); }
    .admin-tab-active { background:linear-gradient(135deg,#b71c1c,#e53935); color:#fff !important; font-weight:700; box-shadow:0 2px 8px rgba(229,57,53,.25); }
    .admin-tab-count { opacity:.75; font-weight:500; }

    /* ── Toast ── */
    .admin-toast { padding:10px 18px; border-radius:8px; font-size:.82rem; font-weight:600; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-shrink:0; }
