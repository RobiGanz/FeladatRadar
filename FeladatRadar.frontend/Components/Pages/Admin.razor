    .admin-td-date { color:var(--text-muted); font-size:.78rem; white-space:nowrap; }
    .admin-td-center { text-align:center; font-weight:600; }
    .admin-td-actions { display:flex; gap:4px; align-items:center; }
    .admin-td-muted { color:var(--text-muted); font-size:.75rem; font-style:italic; }
    .admin-td-details { color:var(--text-secondary); font-size:.78rem; max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

    /* ── Role select ── */
    .admin-role-select { padding:3px 8px; border:1px solid var(--border); border-radius:5px; background:var(--surface); color:var(--text-primary); font-size:.78rem; font-family:var(--font); cursor:pointer; font-weight:600; }
