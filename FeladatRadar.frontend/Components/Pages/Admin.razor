@page "/admin"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject AdminService AdminService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Admin Panel — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (_isAuthenticated && _userRole == "Admin")
{
    <div class="@LayoutClass" data-theme="@_theme" data-role="Admin">
        @if (_menuOpen)
        {
            <div class="fr-sidebar-backdrop" @onclick="CloseMenu"></div>
        }
        <aside class="@SidebarClass">
            <a href="/dashboard" class="fr-brand" @onclick="CloseMenu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
                <span>FeladatRadar</span>
            </a>
            <nav class="fr-nav">
                <a href="/naptar" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Naptár</a>
                <a href="/fokusz" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Csoportok</a>
                <a href="/admin" class="fr-nav-item fr-active" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>Admin</a>
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark")
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /></svg>
                        <span>Világos mód</span>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
                        <span>Sötét mód</span>
                    }
                </button>
                <button class="fr-logout" @onclick="HandleLogout"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Kijelentkezés</button>
            </div>
        </aside>

        <main class="fr-main">
            <header class="fr-topbar admin-topbar">
                <div class="fr-topbar-left">
                    <button class="fr-hamburger" @onclick="ToggleMenu" title="Menü">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
                    </button>
                    <span class="fr-page-title">🛡️ Admin Panel</span>
                </div>
                <div class="fr-topbar-right">
                    <div class="fr-user-chip">
                        <div class="fr-user-dot admin-dot"></div>
                        <span class="admin-email-text">@_userEmail</span>
                    </div>
                </div>
            </header>

            <div class="fr-content">
                @if (_isLoading)
                {
                    <div class="fr-loading-inline"><div class="fr-spinner"></div><span>Betöltés...</span></div>
                }
                else
                {
                    <!-- Tab navigation -->
                    <div class="admin-tabs">
                        <button class="admin-tab @(_activeTab == "stats" ? "admin-tab-active" : "")" @onclick='() => SwitchTab("stats")'>
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10" /><path d="M12 20V4" /><path d="M6 20v-6" /></svg>
                            <span>Áttekintés</span>
                        </button>
                        <button class="admin-tab @(_activeTab == "users" ? "admin-tab-active" : "")" @onclick='() => SwitchTab("users")'>
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                            <span>Felhasználók <span class="admin-tab-count">(@_allUsers.Count)</span></span>
                        </button>
                        <button class="admin-tab @(_activeTab == "groups" ? "admin-tab-active" : "")" @onclick='() => SwitchTab("groups")'>
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                            <span>Csoportok <span class="admin-tab-count">(@_allGroups.Count)</span></span>
                        </button>
                        <button class="admin-tab @(_activeTab == "audit" ? "admin-tab-active" : "")" @onclick='() => SwitchTab("audit")'>
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                            <span>Napló</span>
                        </button>
                    </div>

                    <!-- Toast üzenet -->
                    @if (!string.IsNullOrEmpty(_toastMessage))
                    {
                        <div class="admin-toast @(_toastIsError ? "admin-toast-error" : "admin-toast-ok")">
                            <span>@_toastMessage</span>
                            <button class="admin-toast-close" @onclick='() => _toastMessage = ""'>✕</button>
                        </div>
                    }

                    <!-- ═══ ÁTTEKINTÉS TAB ═══ -->
                    @if (_activeTab == "stats")
                    {
                        <div class="admin-stats-grid">
                            <div class="admin-stat-card admin-stat-purple">
                                <div class="admin-stat-num">@_stats.TotalUsers</div>
                                <div class="admin-stat-label">Összes felhasználó</div>
                            </div>
                            <div class="admin-stat-card admin-stat-blue">
                                <div class="admin-stat-num">@_stats.TotalStudents</div>
                                <div class="admin-stat-label">Diák</div>
                            </div>
                            <div class="admin-stat-card admin-stat-amber">
                                <div class="admin-stat-num">@_stats.TotalTeachers</div>
                                <div class="admin-stat-label">Tanár</div>
                            </div>
                            <div class="admin-stat-card admin-stat-red">
                                <div class="admin-stat-num">@_stats.TotalAdmins</div>
                                <div class="admin-stat-label">Admin</div>
                            </div>
                            <div class="admin-stat-card admin-stat-green">
                                <div class="admin-stat-num">@_stats.TotalGroups</div>
                                <div class="admin-stat-label">Csoport</div>
                            </div>
                            <div class="admin-stat-card admin-stat-teal">
                                <div class="admin-stat-num">@_stats.TotalSubjects</div>
                                <div class="admin-stat-label">Tantárgy</div>
                            </div>
                        </div>

                        <div class="admin-detail-grid">
                            <div class="fr-panel">
                                <div class="fr-panel-header"><span class="fr-panel-title">📊 Feladatok</span></div>
                                <div class="admin-detail-body">
                                    <div class="admin-detail-row"><span>Összes feladat</span><strong>@_stats.TotalTasks</strong></div>
                                    <div class="admin-detail-row"><span>Aktív feladat</span><strong class="admin-c-blue">@_stats.ActiveTasksCount</strong></div>
                                    <div class="admin-detail-row"><span>Lejárt feladat</span><strong class="admin-c-red">@_stats.OverdueTasksCount</strong></div>
                                    <div class="admin-detail-row"><span>Szavazások</span><strong>@_stats.TotalPolls</strong></div>
                                    <div class="admin-detail-row"><span>Dolgozatok</span><strong>@_stats.TotalExams</strong></div>
                                </div>
                            </div>
                            <div class="fr-panel">
                                <div class="fr-panel-header"><span class="fr-panel-title">📈 Regisztrációk</span></div>
                                <div class="admin-detail-body">
                                    <div class="admin-detail-row"><span>Ma regisztrált</span><strong class="admin-c-green">@_stats.NewUsersToday</strong></div>
                                    <div class="admin-detail-row"><span>Elmúlt 7 nap</span><strong class="admin-c-blue">@_stats.NewUsersThisWeek</strong></div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- ═══ FELHASZNÁLÓK TAB ═══ -->
                    @if (_activeTab == "users")
                    {
                        <div class="admin-toolbar">
                            <div class="admin-search-box">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                                <input type="text" placeholder="Keresés név, email, username..." @bind="_userSearch" @bind:event="oninput" />
                            </div>
                            <div class="admin-toolbar-row2">
                                <div class="admin-filter-pills">
                                    <button class="admin-pill @(_userFilter == "all" ? "admin-pill-active" : "")" @onclick='() => _userFilter = "all"'>Mind</button>
                                    <button class="admin-pill @(_userFilter == "Student" ? "admin-pill-active" : "")" @onclick='() => _userFilter = "Student"'>Diákok</button>
                                    <button class="admin-pill @(_userFilter == "Teacher" ? "admin-pill-active" : "")" @onclick='() => _userFilter = "Teacher"'>Tanárok</button>
                                    <button class="admin-pill @(_userFilter == "Admin" ? "admin-pill-active" : "")" @onclick='() => _userFilter = "Admin"'>Adminok</button>
                                </div>
                                <button class="admin-btn-refresh" @onclick="LoadData" title="Frissítés">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
                                </button>
                            </div>
                        </div>

                        <!-- Asztali tábla (tablet+) -->
                        <div class="fr-panel admin-table-panel admin-desktop-table">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Név</th>
                                        <th class="admin-col-email">Email</th>
                                        <th class="admin-col-username">Username</th>
                                        <th>Szerepkör</th>
                                        <th>Státusz</th>
                                        <th class="admin-col-date">Regisztráció</th>
                                        <th>Műveletek</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in FilteredUsers)
                                    {
                                        var isSelf = user.UserID == AuthService.CurrentUser?.UserID;
                                        <tr class="@(!user.IsActive ? "admin-row-inactive" : "")">
                                            <td class="admin-td-id">@user.UserID</td>
                                            <td class="admin-td-name">
                                                @if (_editingUserId == user.UserID)
                                                {
                                                    <div class="admin-rename-row">
                                                        <input class="admin-inline-input" @bind="_editFirstName" placeholder="Vezék." />
                                                        <input class="admin-inline-input" @bind="_editLastName" placeholder="Ker." />
                                                        <button class="admin-act-btn admin-act-ok" @onclick="() => SaveRename(user)">✓</button>
                                                        <button class="admin-act-btn" @onclick="() => _editingUserId = 0">✕</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span>@user.FirstName @user.LastName</span>
                                                    @if (!isSelf)
                                                    {
                                                        <button class="admin-rename-btn" @onclick="() => StartRename(user)" title="Név szerkesztés">✏️</button>
                                                    }
                                                }
                                            </td>
                                            <td class="admin-td-email admin-col-email">@user.Email</td>
                                            <td class="admin-col-username">@user.Username</td>
                                            <td>
                                                <select class="admin-role-select admin-role-@(user.UserRole.ToLower())"
                                                        value="@user.UserRole"
                                                        disabled="@(isSelf || user.UserRole == "Admin")"
                                                        @onchange="(e) => HandleRoleChange(user.UserID, e.Value?.ToString() ?? user.UserRole)">
                                                    <option value="Student">Student</option>
                                                    <option value="Teacher">Teacher</option>
                                                    <option value="Admin">Admin</option>
                                                </select>
                                            </td>
                                            <td>
                                                @if (user.IsActive)
                                                {
                                                    <span class="admin-badge admin-badge-ok">Aktív</span>
                                                }
                                                else
                                                {
                                                    <span class="admin-badge admin-badge-warn">Tiltva</span>
                                                }
                                            </td>
                                            <td class="admin-td-date admin-col-date">@user.CreatedAt.ToString("yyyy.MM.dd")</td>
                                            <td class="admin-td-actions">
                                                @if (isSelf)
                                                {
                                                    <span class="admin-td-muted">Te</span>
                                                }
                                                else if (user.UserRole == "Admin")
                                                {
                                                    <span class="admin-td-muted">Védett</span>
                                                }
                                                else
                                                {
                                                    @if (user.IsActive)
                                                    {
                                                        <button class="admin-act-btn admin-act-warn" title="Letiltás" @onclick="() => HandleToggleActive(user.UserID, false)">
                                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" /></svg>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="admin-act-btn admin-act-ok" title="Aktiválás" @onclick="() => HandleToggleActive(user.UserID, true)">
                                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                                                        </button>
                                                    }
                                                    <button class="admin-act-btn admin-act-danger" title="Törlés" @onclick="() => HandleDeleteUser(user)">
                                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (!FilteredUsers.Any())
                            {
                                <div class="fr-panel-empty">Nincs találat.</div>
                            }
                        </div>

                        <!-- Mobil kártya nézet -->
                        <div class="admin-mobile-cards">
                            @foreach (var user in FilteredUsers)
                            {
                                var isSelf = user.UserID == AuthService.CurrentUser?.UserID;
                                <div class="admin-user-card @(!user.IsActive ? "admin-card-inactive" : "")">
                                    <div class="admin-card-header">
                                        <div class="admin-card-name-block">
                                            @if (_editingUserId == user.UserID)
                                            {
                                                <div class="admin-rename-row-mobile">
                                                    <input class="admin-inline-input" @bind="_editFirstName" placeholder="Vezék." />
                                                    <input class="admin-inline-input" @bind="_editLastName" placeholder="Ker." />
                                                    <button class="admin-act-btn admin-act-ok" @onclick="() => SaveRename(user)">✓</button>
                                                    <button class="admin-act-btn" @onclick="() => _editingUserId = 0">✕</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="admin-card-fullname">
                                                    @user.FirstName @user.LastName
                                                    @if (!isSelf)
                                                    {
                                                        <button class="admin-rename-btn" @onclick="() => StartRename(user)">✏️</button>
                                                    }
                                                </div>
                                                <div class="admin-card-username">@@user.Username</div>
                                            }
                                        </div>
                                        <div class="admin-card-badges">
                                            <span class="admin-badge admin-badge-@(user.UserRole.ToLower())">@user.UserRole</span>
                                            @if (user.IsActive)
                                            {
                                                <span class="admin-badge admin-badge-ok">Aktív</span>
                                            }
                                            else
                                            {
                                                <span class="admin-badge admin-badge-warn">Tiltva</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="admin-card-email">@user.Email</div>
                                    <div class="admin-card-footer">
                                        <span class="admin-card-date">#@user.UserID · @user.CreatedAt.ToString("yyyy.MM.dd")</span>
                                        <div class="admin-card-actions">
                                            @if (isSelf)
                                            {
                                                <span class="admin-td-muted">Te</span>
                                            }
                                            else if (user.UserRole == "Admin")
                                            {
                                                <span class="admin-td-muted">Védett</span>
                                            }
                                            else
                                            {
                                                <select class="admin-role-select admin-role-@(user.UserRole.ToLower())"
                                                        value="@user.UserRole"
                                                        @onchange="(e) => HandleRoleChange(user.UserID, e.Value?.ToString() ?? user.UserRole)">
                                                    <option value="Student">Student</option>
                                                    <option value="Teacher">Teacher</option>
                                                    <option value="Admin">Admin</option>
                                                </select>
                                                @if (user.IsActive)
                                                {
                                                    <button class="admin-act-btn admin-act-warn" title="Letiltás" @onclick="() => HandleToggleActive(user.UserID, false)">
                                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" /></svg>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="admin-act-btn admin-act-ok" title="Aktiválás" @onclick="() => HandleToggleActive(user.UserID, true)">
                                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                                                    </button>
                                                }
                                                <button class="admin-act-btn admin-act-danger" title="Törlés" @onclick="() => HandleDeleteUser(user)">
                                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (!FilteredUsers.Any())
                            {
                                <div class="fr-panel admin-card-empty">Nincs találat.</div>
                            }
                        </div>
                    }

                    <!-- ═══ CSOPORTOK TAB ═══ -->
                    @if (_activeTab == "groups")
                    {
                        <div class="admin-toolbar">
                            <div class="admin-search-box">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                                <input type="text" placeholder="Keresés csoportnév, tulajdonos..." @bind="_groupSearch" @bind:event="oninput" />
                            </div>
                        </div>

                        <!-- Asztali tábla -->
                        <div class="fr-panel admin-table-panel admin-desktop-table">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Csoport neve</th>
                                        <th>Tulajdonos</th>
                                        <th class="admin-col-role">Szerepkör</th>
                                        <th>Tagok</th>
                                        <th class="admin-col-date">Létrehozva</th>
                                        <th>Műveletek</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in FilteredGroups)
                                    {
                                        <tr>
                                            <td class="admin-td-id">@g.GroupID</td>
                                            <td class="admin-td-name">@g.GroupName</td>
                                            <td>@g.OwnerName</td>
                                            <td class="admin-col-role"><span class="admin-badge admin-badge-@(g.OwnerRole.ToLower())">@g.OwnerRole</span></td>
                                            <td class="admin-td-center">@g.MemberCount</td>
                                            <td class="admin-td-date admin-col-date">@g.CreatedAt.ToString("yyyy.MM.dd")</td>
                                            <td class="admin-td-actions">
                                                <button class="admin-act-btn admin-act-danger" title="Csoport törlése" @onclick="() => HandleDeleteGroup(g)">
                                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (!FilteredGroups.Any())
                            {
                                <div class="fr-panel-empty">Nincs csoport.</div>
                            }
                        </div>

                        <!-- Mobil kártya nézet -->
                        <div class="admin-mobile-cards">
                            @foreach (var g in FilteredGroups)
                            {
                                <div class="admin-user-card">
                                    <div class="admin-card-header">
                                        <div class="admin-card-name-block">
                                            <div class="admin-card-fullname">@g.GroupName</div>
                                            <div class="admin-card-username">Tulajdonos: @g.OwnerName</div>
                                        </div>
                                        <div class="admin-card-badges">
                                            <span class="admin-badge admin-badge-@(g.OwnerRole.ToLower())">@g.OwnerRole</span>
                                        </div>
                                    </div>
                                    <div class="admin-card-footer">
                                        <span class="admin-card-date">#@g.GroupID · @g.MemberCount tag · @g.CreatedAt.ToString("yyyy.MM.dd")</span>
                                        <div class="admin-card-actions">
                                            <button class="admin-act-btn admin-act-danger" title="Csoport törlése" @onclick="() => HandleDeleteGroup(g)">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (!FilteredGroups.Any())
                            {
                                <div class="fr-panel admin-card-empty">Nincs csoport.</div>
                            }
                        </div>
                    }

                    <!-- ═══ AUDIT LOG TAB ═══ -->
                    @if (_activeTab == "audit")
                    {
                        <!-- Asztali tábla -->
                        <div class="fr-panel admin-table-panel admin-desktop-table">
                            <div class="fr-panel-header">
                                <span class="fr-panel-title">Rendszernapló (utolsó 100)</span>
                                <button class="admin-btn-refresh" @onclick="LoadAuditLog" title="Frissítés">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
                                </button>
                            </div>
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Időpont</th>
                                        <th>Felhasználó</th>
                                        <th>Művelet</th>
                                        <th class="admin-col-details">Részletek</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in _auditLog)
                                    {
                                        <tr>
                                            <td class="admin-td-date">@log.CreatedAt.ToString("MM.dd HH:mm")</td>
                                            <td>@log.Username</td>
                                            <td><span class="admin-badge admin-badge-action">@TranslateAction(log.Action)</span></td>
                                            <td class="admin-td-details admin-col-details">@(log.Details ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (!_auditLog.Any())
                            {
                                <div class="fr-panel-empty">Nincs bejegyzés a naplóban.</div>
                            }
                        </div>

                        <!-- Audit mobil kártya -->
                        <div class="admin-mobile-cards">
                            <div class="admin-audit-header">
                                <span class="admin-audit-title">Rendszernapló (utolsó 100)</span>
                                <button class="admin-btn-refresh" @onclick="LoadAuditLog" title="Frissítés">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
                                </button>
                            </div>
                            @foreach (var log in _auditLog)
                            {
                                <div class="admin-user-card">
                                    <div class="admin-card-header">
                                        <div class="admin-card-name-block">
                                            <div class="admin-card-fullname">@log.Username</div>
                                            <div class="admin-card-username">@log.CreatedAt.ToString("MM.dd HH:mm")</div>
                                        </div>
                                        <span class="admin-badge admin-badge-action">@TranslateAction(log.Action)</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(log.Details))
                                    {
                                        <div class="admin-card-email">@log.Details</div>
                                    }
                                </div>
                            }
                            @if (!_auditLog.Any())
                            {
                                <div class="fr-panel admin-card-empty">Nincs bejegyzés.</div>
                            }
                        </div>
                    }
                }
            </div>
        </main>
    </div>

    <!-- Megerősítő modal -->
    @if (_confirmVisible)
    {
        <div class="admin-modal-backdrop" @onclick="() => _confirmVisible = false">
            <div class="admin-modal" @onclick:stopPropagation="true">
                <div class="admin-modal-title">⚠️ Megerősítés</div>
                <div class="admin-modal-body">@_confirmMessage</div>
                <div class="admin-modal-actions">
                    <button class="admin-modal-btn admin-modal-cancel" @onclick="() => _confirmVisible = false">Mégse</button>
                    <button class="admin-modal-btn admin-modal-confirm" @onclick="ConfirmAction">Igen, végrehajtás</button>
                </div>
            </div>
        </div>
    }
}
else if (_isAuthenticated && _userRole != "Admin")
{
    <div class="fr-unauth"><p>🛡️ Nincs admin jogosultságod.</p><a href="/dashboard" class="fr-btn fr-btn-primary">Vissza a Dashboard-ra</a></div>
}
else
{
    <div class="fr-unauth"><p>Nincs aktív munkamenet.</p><a href="/login" class="fr-btn fr-btn-primary">Bejelentkezés</a></div>
}

<style>
    /* ── Admin theme ── */
    .fr-layout[data-role="Admin"] { --admin-accent:#e53935; --admin-accent-2:#b71c1c; }
    .fr-layout[data-role="Admin"] .fr-topbar,
    .admin-topbar { background:linear-gradient(135deg,#b71c1c 0%,#e53935 100%) !important; box-shadow:0 2px 16px rgba(229,57,53,.25) !important; }
    .fr-layout[data-role="Admin"] .fr-brand { background:linear-gradient(135deg,#b71c1c 0%,#e53935 100%) !important; }
    .admin-dot { background:#e53935 !important; }

    .fr-content { flex:1; overflow-y:auto; padding:20px 24px; display:flex; flex-direction:column; gap:14px; }
    .fr-loading-inline { display:flex; align-items:center; gap:10px; padding:40px; color:var(--text-muted); font-size:.875rem; }

