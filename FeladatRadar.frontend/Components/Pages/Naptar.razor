    private async Task OnGroupChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id)) _selectedGroupId = id;
        if (_groupMode) await LoadGroupData();
        StateHasChanged();
    }

    private async Task QuickComplete(int taskId)
    {
        try
        {
            var task = _tasks.FirstOrDefault(t => t.TaskID == taskId);
            SubjectResponse r;
            if (task?.IsCompleted == true)
                r = await TaskService.UncompleteTaskAsync(taskId);
            else
                r = await TaskService.CompleteTaskAsync(taskId);
            if (r.Status == "OK" || r.Status == "SUCCESS") await LoadData();
            else { _message = r.Message; _messageIsError = true; }
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task AddEntry()
    {
        _formError = "";
        if (_selSubjectId == 0) { _formError = "Válassz tantárgyat."; return; }
        _isSaving = true; StateHasChanged();
        try
        {
            var startDate = _addingToDate.Date; // a pontos kattintott dátum, nem a heti offset-ből számolt
            var r = await ScheduleService.AddEntryAsync(new AddScheduleRequest
            {
                SubjectID      = _selSubjectId,
                DayOfWeek      = _addingToDay,
                StartTime      = _selStart,
                EndTime        = _selEnd,
                Location       = string.IsNullOrWhiteSpace(_selLocation) ? null : _selLocation,
                RecurrenceType = _selRecurrence,
                StartDate      = startDate,
                RecurrenceEndDate = null
            });
            if (r.Status == "OK" || r.Status == "SUCCESS") { _message = "Bejegyzés hozzáadva."; _messageIsError = false; _addingToDay = 0; await LoadData(); }
            else _formError = r.Message;
