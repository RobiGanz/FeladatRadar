            });
            if (r.Status == "OK" || r.Status == "SUCCESS") { _message = "Csoport bejegyzés hozzáadva."; _messageIsError = false; _addingToDay = 0; await LoadGroupData(); }
            else _formError = r.Message;
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _isSaving = false; StateHasChanged(); }
    }

    // ── Láthatóság-szűrő metódusok ──────────────────────────────────────────
    private bool IsEntryVisibleOnDate(ScheduleEntryDto entry, DateTime date)
    {
        if (entry.RecurrenceEndDate.HasValue && date.Date > entry.RecurrenceEndDate.Value.Date) return false;

        var refDate = entry.StartDate?.Date ?? entry.CreatedAt.Date;

        // Egyik típusnál sem jelenhet meg a referencia dátum ELŐTT
        if (date.Date < refDate) return false;

        switch (entry.RecurrenceType)
        {
            case "Weekly":
            case "Biweekly":
            {
                // Heti/kéthetente: a hét napja kell hogy egyezzen
                var dow = (int)date.DayOfWeek == 0 ? 7 : (int)date.DayOfWeek;
                if (entry.DayOfWeek != dow) return false;
                if (entry.RecurrenceType == "Weekly") return true;
                return ((date.Date - refDate).Days / 7) % 2 == 0;
            }

            case "Monthly":
                // Minden hónapban ugyanaz a nap (ápr. 1. → máj. 1. → jún. 1.)
                // DayOfWeek NEM számít – csak a hónap napja
                var targetDay = Math.Min(refDate.Day, DateTime.DaysInMonth(date.Year, date.Month));
                return date.Day == targetDay;

            case "None":
                // Egyszeri: csak a pontos dátum egyezik, DayOfWeek NEM számít
                return date.Date == refDate;

            default:
                return true;
        }
    }

    private bool IsGroupEntryVisibleOnDate(GroupScheduleEntryDto entry, DateTime date)
    {
        if (entry.RecurrenceEndDate.HasValue && date.Date > entry.RecurrenceEndDate.Value.Date) return false;

        var refDate = entry.StartDate?.Date ?? entry.CreatedAt.Date;

        if (date.Date < refDate) return false;

        switch (entry.RecurrenceType)
        {
            case "Weekly":
            case "Biweekly":
            {
                var dow = (int)date.DayOfWeek == 0 ? 7 : (int)date.DayOfWeek;
                if (entry.DayOfWeek != dow) return false;
                if (entry.RecurrenceType == "Weekly") return true;
                return ((date.Date - refDate).Days / 7) % 2 == 0;
            }

            case "Monthly":
                var targetDay = Math.Min(refDate.Day, DateTime.DaysInMonth(date.Year, date.Month));
                return date.Day == targetDay;

            case "None":
                return date.Date == refDate;

            default:
                return true;
        }
    }

    private async Task AddTask()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_taskTitle)) { _formError = "Add meg a feladat nevét."; return; }
        _isSaving = true; StateHasChanged();
        try
        {
            if (_groupMode && _selectedGroupId > 0)
            {
                var r = await GroupService.AddGroupTaskAsync(_selectedGroupId, new AddGroupTaskRequest
                {
                    SubjectID = _taskSubjectId > 0 ? _taskSubjectId : 1,
                    Title = _taskTitle.Trim(),
                    Description = string.IsNullOrWhiteSpace(_taskDescription) ? null : _taskDescription.Trim(),
                    DueDate = _taskDueDate,
                    TaskType = _taskType
                });
                if (r.Status == "OK" || r.Status == "SUCCESS") { _message = $"Csoportos feladat hozzáadva: {_taskTitle}"; _messageIsError = false; _addingToDay = 0; await LoadGroupData(); }
                else _formError = r.Message;
            }
            else
            {
                var r = await TaskService.AddTaskAsync(new AddTaskRequest
                {
                    SubjectID = _taskSubjectId == 0 ? null : _taskSubjectId,
                    Title = _taskTitle.Trim(),
                    Description = _taskDescription.Trim(),
                    DueDate = _taskDueDate,
                    TaskType = _taskType,
                    RecurrenceType = _taskRecurrence,
                    RecurrenceEndDate = (_taskRecurrence != "None" && _taskHasEndDate) ? _taskRecurrenceEnd : null
                });
                if (r.Status == "OK" || r.Status == "SUCCESS") { _message = $"Feladat hozzáadva: {_taskTitle}"; _messageIsError = false; _addingToDay = 0; await LoadData(); }
                else _formError = r.Message;
            }
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _isSaving = false; StateHasChanged(); }
    }
    private async Task DeleteEntry(int entryId)
    {
