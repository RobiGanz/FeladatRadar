@page "/csoport"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject GroupService GroupService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Csoportok — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (_isAuthenticated)
{
    <div class="fr-layout" data-theme="@_theme">
        <aside class="fr-sidebar">
            <div class="fr-brand">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
                <span>FeladatRadar</span>
            </div>
            <nav class="fr-nav">
                <a href="/dashboard" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>Dashboard</a>
                <a href="/naptar" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Naptár</a>
                <a href="/feladatok" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>Feladatok</a>
                <a href="/fokusz" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item fr-active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Csoportok</a>
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark")
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /></svg>
                        <span>Világos mód</span>
     }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
                        <span>Sötét mód</span>
     }
                </button>
                <button class="fr-logout" @onclick="HandleLogout"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Kijelentkezés</button>
            </div>
        </aside>

        <main class="fr-main">
            <header class="fr-topbar">
                <div class="fr-topbar-left">
                    <span class="fr-page-title">Csoportok</span>
                    <span class="fr-breadcrumb">/ @_groups.Count csoport</span>
                </div>
                <div class="fr-topbar-right">
                    <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showCreate = !_showCreate">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Új csoport
                    </button>
                    <div class="fr-user-chip">
                        <div class="fr-user-dot"></div>
                        <span>@_userEmail</span>
                    </div>
                </div>
            </header>

            <div class="fr-content">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="fr-alert @(_messageIsError ? "fr-alert-danger" : "fr-alert-success")">
                        @_message
                        <button class="fr-alert-close" @onclick="() => _message = string.Empty"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></button>
                    </div>
                }

                @if (_invites.Any())
                {
                    <div class="fr-panel">
                        <div class="fr-panel-header">
                            <span class="fr-panel-title">Függő meghívók</span>
                            <span class="fr-badge fr-badge-warn">@_invites.Count</span>
                        </div>
                        <div class="fr-panel-body">
                            @foreach (var inv in _invites)
                            {
                                <div class="fr-invite-row">
                                    <div class="fr-invite-info">
                                        <span class="fr-invite-name">@inv.GroupName</span>
                                        <span class="fr-invite-from">meghívta: @inv.InvitedByName · @inv.CreatedAt.ToString("MM.dd")</span>
                                    </div>
                                    <div style="display:flex;gap:8px;">
                                        <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => AcceptInvite(inv.InviteID)">Elfogadás</button>
                                        <button class="fr-btn-ghost fr-btn-sm" @onclick="() => DeclineInvite(inv.InviteID)">Elutasítás</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (_showCreate)
                {
                    <div class="fr-form-card">
                        <h2 class="fr-form-title">Új csoport létrehozása</h2>
                        <div class="fr-field">
                            <label class="fr-label">Csoport neve</label>
                            <input class="fr-input" type="text" placeholder="pl. Vizsgacsoport 2025" @bind="_newGroupName" maxlength="100" />
                        </div>
                        @if (!string.IsNullOrEmpty(_createError))
                        {
                            <div class="fr-alert fr-alert-danger">@_createError</div>
                        }
                        <div style="display:flex;gap:10px;">
                            <button class="fr-btn fr-btn-primary" @onclick="CreateGroup" disabled="@_isCreating">
                                @(_isCreating ? "Létrehozás..." : "Csoport létrehozása")
                            </button>
                            <button class="fr-btn-ghost" @onclick="() => _showCreate = false">Mégse</button>
                        </div>
                    </div>
                }

                <div class="fr-groups-layout">
                    <div class="fr-group-list">
                        @if (!_groups.Any())
                        {
                            <div class="fr-empty">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                <span>Még nem vagy egy csoportban sem.</span>
                                <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showCreate = true">Csoport létrehozása</button>
                            </div>
                        }
                        else
                        {
                            @foreach (var g in _groups)
                            {
                                <div class="fr-group-item @(_selectedGroup?.GroupID == g.GroupID ? "fr-group-item-active" : "")" @onclick="() => SelectGroup(g)">
                                    <div class="fr-group-item-main">
                                        <span class="fr-group-item-name">@g.GroupName</span>
                                        <span class="fr-group-item-meta">@g.MemberCount tag</span>
                                    </div>
                                    @if (g.IsOwner)
                                    {
                                        <span class="fr-badge fr-badge-accent">Tulajdonos</span>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @if (_selectedGroup != null)
                    {
                        <div class="fr-group-detail">
                            <div class="fr-group-detail-head">
                                <h2 class="fr-group-detail-name">@_selectedGroup.GroupName</h2>
                                <div class="fr-detail-tabs">
                                    <button class="fr-dtab @(_detailTab == "members" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("members")'>Tagok</button>
                                    <button class="fr-dtab @(_detailTab == "subjects" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("subjects")'>Tantárgyak</button>
                                    <button class="fr-dtab @(_detailTab == "tasks" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("tasks")'>Feladatok</button>
                                </div>
                            </div>

                            <div class="fr-detail-body">
                                @if (_isLoadingDetail)
                                {
                                    <div class="fr-panel-empty"><div class="fr-spinner fr-spinner-sm"></div></div>
                                }
                                else if (_detailTab == "members")
                                {
                                    <table class="fr-table">
                                        <thead><tr><th>Név</th><th>Email</th><th>Csatlakozás</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (var m in _members)
                                            {
                                                <tr>
                                                    <td class="fr-td-name">@m.FirstName @m.LastName</td>
                                                    <td class="fr-td-meta">@m.Email</td>
                                                    <td class="fr-td-meta">@m.JoinedAt.ToString("yyyy.MM.dd")</td>
                                                    <td>@if (m.IsOwner) {
                                                    <span class="fr-badge fr-badge-accent">Tulajdonos</span>
                                                }
            </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>
</div>
}
else
{
    <div class="fr-unauth"><p>Nincs aktív munkamenet.</p><a href="/login" class="fr-btn fr-btn-primary">Bejelentkezés</a></div>
}

<style>
    .fr-layout {
        --accent: #2563eb;
        --accent-hover: #1d4ed8;
        --accent-subtle: rgba(37,99,235,.08);
        --bg: #f8f9fb;
        --surface: #fff;
        --surface-2: #f1f3f7;
        --border: #e4e7ed;
        --text-primary: #0f1117;
        --text-secondary: #52586a;
        --text-muted: #9299aa;
        --danger: #dc2626;
        --danger-subtle: rgba(220,38,38,.07);
        --warning: #d97706;
        --warning-subtle: rgba(217,119,6,.08);
        --success: #16a34a;
        --success-subtle: rgba(22,163,74,.08);
        --radius: 10px;
        --font: -apple-system,BlinkMacSystemFont,Inter,Segoe UI,system-ui,sans-serif;
    }

        .fr-layout[data-theme="dark"] {
            --bg: #0d0f14;
            --surface: #161820;
            --surface-2: #1e2130;
            --border: #272b3a;
            --text-primary: #f0f2f8;
            --text-secondary: #8892a4;
            --text-muted: #4e566a;
            --accent-subtle: rgba(37,99,235,.15);
            --danger-subtle: rgba(220,38,38,.12);
            --warning-subtle: rgba(217,119,6,.12);
            --success-subtle: rgba(22,163,74,.12);
        }

    .fr-layout {
        display: grid;
        grid-template-columns: 220px 1fr;
        height: 100vh;
        background: var(--bg);
        font-family: var(--font);
        color: var(--text-primary);
    }

    .fr-sidebar {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border-right: 1px solid var(--border);
        height: 100vh;
        overflow: hidden;
    }

    .fr-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 20px 18px;
        font-weight: 700;
        font-size: .95rem;
        color: var(--accent);
        border-bottom: 1px solid var(--border);
    }

    .fr-nav {
        flex: 1;
        padding: 12px 10px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow-y: auto;
        scrollbar-width: none;
    }

    .fr-nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border-radius: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: .875rem;
        font-weight: 500;
        transition: background .15s,color .15s;
    }

        .fr-nav-item:hover {
            background: var(--surface-2);
            color: var(--text-primary);
        }

        .fr-nav-item.fr-active {
            background: var(--accent-subtle);
            color: var(--accent);
        }

    .fr-sidebar-footer {
        padding: 12px 10px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .fr-theme-toggle, .fr-logout {
        display: flex;
        align-items: center;
        gap: 9px;
        width: 100%;
        padding: 9px 10px;
        border: none;
        border-radius: 8px;
        background: none;
        color: var(--text-secondary);
        font-size: .85rem;
        font-weight: 500;
        cursor: pointer;
        text-align: left;
        transition: background .15s,color .15s;
        font-family: var(--font);
    }

        .fr-theme-toggle:hover {
            background: var(--surface-2);
            color: var(--text-primary);
        }

        .fr-logout:hover {
            background: var(--danger-subtle);
            color: var(--danger);
        }

    .fr-main {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 100vh;
    }

    .fr-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        height: 56px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }

    .fr-topbar-left, .fr-topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .fr-page-title {
        font-size: 1rem;
        font-weight: 700;
    }

    .fr-breadcrumb {
        font-size: .85rem;
        color: var(--text-muted);
    }

    .fr-user-chip {
        display: flex;
        align-items: center;
        gap: 7px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 5px 12px 5px 8px;
        font-size: .8rem;
        color: var(--text-secondary);
    }

    .fr-user-dot {
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
    }

    .fr-content {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .fr-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
    }

    .fr-spinner {
        width: 28px;
        height: 28px;
        border: 2.5px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: fr-spin .7s linear infinite;
    }

    .fr-spinner-sm {
        width: 18px;
        height: 18px;
        border-width: 2px;
    }

    @@keyframes fr-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .fr-unauth {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        gap: 16px;
    }

    .fr-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 16px;
        border-radius: 8px;
        font-size: .875rem;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: background .15s;
        font-family: var(--font);
    }

    .fr-btn-primary {
        background: var(--accent);
        color: #fff;
    }

        .fr-btn-primary:hover:not(:disabled) {
            background: var(--accent-hover);
        }

        .fr-btn-primary:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .fr-btn-sm {
        padding: 7px 13px;
        font-size: .82rem;
    }

    .fr-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 14px;
        border-radius: 8px;
        font-size: .875rem;
        font-weight: 500;
        background: none;
        border: 1px solid var(--border);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all .15s;
    }

        .fr-btn-ghost:hover {
            background: var(--surface-2);
            color: var(--text-primary);
        }

    .fr-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 16px;
        border-radius: 8px;
        font-size: .875rem;
        font-weight: 500;
    }

    .fr-alert-danger {
        background: var(--danger-subtle);
        color: var(--danger);
        border: 1px solid rgba(220,38,38,.2);
    }

    .fr-alert-success {
        background: var(--success-subtle);
        color: var(--success);
        border: 1px solid rgba(22,163,74,.2);
    }

    .fr-alert-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: .6;
        display: flex;
        align-items: center;
    }

    .fr-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .fr-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
    }

    .fr-panel-title {
        font-weight: 700;
        font-size: .9rem;
    }

    .fr-panel-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        color: var(--text-muted);
        font-size: .875rem;
    }

    .fr-invite-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 20px;
        border-bottom: 1px solid var(--border);
        gap: 16px;
    }

        .fr-invite-row:last-child {
            border-bottom: none;
        }

    .fr-invite-info {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .fr-invite-name {
        font-weight: 600;
        font-size: .9rem;
    }

    .fr-invite-from {
        font-size: .78rem;
        color: var(--text-muted);
    }

    .fr-badge {
        font-size: .72rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
    }

    .fr-badge-accent {
        background: var(--accent-subtle);
        color: var(--accent);
    }

    .fr-badge-warn {
        background: var(--warning-subtle);
        color: var(--warning);
    }

    .fr-form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        max-width: 480px;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .fr-form-title {
        font-weight: 700;
        font-size: 1rem;
    }

    .fr-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .fr-label {
        font-size: .8rem;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .fr-input {
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        color: var(--text-primary);
        font-size: .875rem;
        font-family: inherit;
        outline: none;
        transition: border-color .15s;
    }

        .fr-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-subtle);
        }

    .fr-groups-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 16px;
        flex: 1;
        min-height: 0;
    }

    .fr-group-list {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        align-self: start;
    }

    .fr-group-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 16px;
        border-bottom: 1px solid var(--border);
        cursor: pointer;
        transition: background .12s;
        gap: 10px;
    }

        .fr-group-item:last-child {
            border-bottom: none;
        }

        .fr-group-item:hover {
            background: var(--surface-2);
        }

        .fr-group-item.fr-group-item-active {
            background: var(--accent-subtle);
        }

    .fr-group-item-main {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
    }

    .fr-group-item-name {
        font-weight: 600;
        font-size: .9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fr-group-item-meta {
        font-size: .75rem;
        color: var(--text-muted);
    }

    .fr-group-detail {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .fr-group-detail-head {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .fr-group-detail-name {
        font-weight: 700;
        font-size: 1.05rem;
    }

