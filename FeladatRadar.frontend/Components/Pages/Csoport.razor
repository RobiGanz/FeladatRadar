@code {
    private bool _hasCheckedAuth = false;
    private bool _isAuthenticated = false;
    private string _userEmail = "";
    private string _theme = "light";
    private string _message = "";
    private bool _messageIsError = false;

    private bool _isTeacher = false;
    private int _currentUserId = 0;

    private List<GroupDto> _groups = new();
    private List<GroupInviteDto> _invites = new();
    private GroupDto? _selectedGroup = null;
    private string _detailTab = "members";

    private List<GroupMemberDto> _members = new();
    private List<GroupSubjectDto> _groupSubjects = new();
    private List<GroupTaskDto> _groupTasks = new();
    private bool _isLoadingDetail = false;

    private bool _showCreate = false;
    private string _newGroupName = "";
    private string _createError = "";
    private bool _isCreating = false;

    private string _inviteEmail = "";
    private string _inviteError = "";
    private bool _isInviting = false;

    private string _pollQuestion = "";
    private string _pollOptionsText = "Igen\nNem\nTalán";
    private DateTime? _pollExpires = null;
    private string _pollError = "";
    private bool _isSavingPoll = false;

    private string _examTitle = "";
    private string _examSubject = "";
    private DateTime _examDate = DateTime.Now.AddDays(7);
    private string _examDesc = "";
    private string _examError = "";
    private bool _isSavingExam = false;

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.setTheme", _theme);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        try { await AuthService.InitializeAsync(); } catch { }
        _hasCheckedAuth = true;
        _isAuthenticated = AuthService.IsAuthenticated;
        _userEmail = AuthService.CurrentUser?.Email ?? "";
        _isTeacher = AuthService.CurrentUser?.UserRole == "Teacher";
        _currentUserId = AuthService.CurrentUser?.UserID ?? 0;
        if (!_isAuthenticated) { Navigation.NavigateTo("/login"); return; }
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try { _groups = await GroupService.GetMyGroupsAsync(); } catch { _groups = new(); }
        try { _invites = await GroupService.GetMyInvitesAsync(); } catch { _invites = new(); }
    }

    private async Task SelectGroup(GroupDto g)
    {
        _selectedGroup = g;
        _detailTab = "members";
        await LoadGroupDetail();
    }

    private async Task LoadGroupDetail()
    {
        if (_selectedGroup == null) return;
        _isLoadingDetail = true; StateHasChanged();
        try { _members = await GroupService.GetMembersAsync(_selectedGroup.GroupID); } catch { _members = new(); }
        try { _groupSubjects = await GroupService.GetGroupSubjectsAsync(_selectedGroup.GroupID); } catch { _groupSubjects = new(); }
        try { _groupTasks = await GroupService.GetGroupTasksAsync(_selectedGroup.GroupID); } catch { _groupTasks = new(); }
        _isLoadingDetail = false; StateHasChanged();
    }

    private async Task SwitchTab(string tab) { _detailTab = tab; StateHasChanged(); }

    private async Task CreateGroup()
    {
        _createError = "";
        if (string.IsNullOrWhiteSpace(_newGroupName)) { _createError = "Add meg a csoport nevét."; return; }
        _isCreating = true; StateHasChanged();
        try
        {
            var r = await GroupService.CreateGroupAsync(_newGroupName.Trim());
            if (r.Status == "OK" || r.Status == "SUCCESS") { _message = "Csoport létrehozva."; _messageIsError = false; _newGroupName = ""; _showCreate = false; await LoadData(); }
            else { _createError = r.Message; }
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _isCreating = false; StateHasChanged(); }
    }

    private async Task AcceptInvite(int inviteId)
    {
        try { var r = await GroupService.AcceptInviteAsync(inviteId); _messageIsError = r.Status != "OK" && r.Status != "SUCCESS"; _message = _messageIsError ? r.Message : "Meghívó elfogadva."; if (!_messageIsError) await LoadData(); }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task DeclineInvite(int inviteId)
    {
        try { var r = await GroupService.DeclineInviteAsync(inviteId); _messageIsError = r.Status != "OK" && r.Status != "SUCCESS"; _message = _messageIsError ? r.Message : "Meghívó elutasítva."; if (!_messageIsError) await LoadData(); }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
}
