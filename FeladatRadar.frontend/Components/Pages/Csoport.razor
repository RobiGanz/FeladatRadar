@page "/csoport"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject GroupService GroupService
@inject TeacherService TeacherService
@inject AdminService AdminService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Csoportok — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (_isAuthenticated)
{
    <div class="@LayoutClass" data-theme="@_theme" data-role="@_userRole">
        @if (_menuOpen) { <div class="fr-sidebar-backdrop" @onclick="CloseMenu"></div> }
        <aside class="@SidebarClass">
                        <a href="/dashboard" class="fr-brand" @onclick="CloseMenu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <span>FeladatRadar</span>
            </a>
            <nav class="fr-nav">
                
                <a href="/naptar" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Naptár</a>
                <a href="/fokusz" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item fr-active" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Csoportok</a>
                            @if (_userRole == "Admin") { <a href="/admin" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>Admin</a> }
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark") { <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/></svg><span>Világos mód</span> }
                    else { <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg><span>Sötét mód</span> }
                </button>

            </div>
        </aside>

        <main class="fr-main">
            <header class="fr-topbar">
                <div class="fr-topbar-left">
                    <button class="fr-hamburger" @onclick="ToggleMenu" title="Menü">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                                        <span class="fr-page-title">Csoportok</span>
                    <span class="fr-breadcrumb">/ @_groups.Count csoport</span>
                </div>
                <div class="fr-topbar-right">
                    <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showCreate = !_showCreate">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Új csoport
                    </button>
                </div>
            </header>

            <div class="fr-content">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="fr-alert @(_messageIsError ? "fr-alert-danger" : "fr-alert-success")">
                        @_message
                        <button class="fr-alert-close" @onclick="() => _message = string.Empty"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                    </div>
                }

                <!-- Pending invites -->
                @if (_invites.Any())
                {
                    <div class="fr-panel">
                        <div class="fr-panel-header">
                            <span class="fr-panel-title">Függő meghívók</span>
                            <span class="fr-badge fr-badge-warn">@_invites.Count</span>
                        </div>
                        <div class="fr-panel-body">
                            @foreach (var inv in _invites)
                            {
                                <div class="fr-invite-row">
                                    <div class="fr-invite-info">
                                        <span class="fr-invite-name">@inv.GroupName</span>
                                        <span class="fr-invite-from">meghívta: @inv.InvitedByName · @inv.CreatedAt.ToString("MM.dd")</span>
                                    </div>
                                    <div style="display:flex;gap:8px;">
                                        <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => AcceptInvite(inv.InviteID)">Elfogadás</button>
                                        <button class="fr-btn-ghost fr-btn-sm" @onclick="() => DeclineInvite(inv.InviteID)">Elutasítás</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Create group form -->
                @if (_showCreate)
                {
                    <div class="fr-form-card">
                        <h2 class="fr-form-title">Új csoport létrehozása</h2>
                        <div class="fr-field">
                            <label class="fr-label">Csoport neve</label>
                            <input class="fr-input" type="text" placeholder="pl. Vizsgacsoport 2026" @bind="_newGroupName" maxlength="100" />
                        </div>
                        @if (!string.IsNullOrEmpty(_createError))
                        {
                            <div class="fr-alert fr-alert-danger">@_createError</div>
                        }
                        <div style="display:flex;gap:10px;">
                            <button class="fr-btn fr-btn-primary" @onclick="CreateGroup" disabled="@_isCreating">
                                @(_isCreating ? "Létrehozás..." : "Csoport létrehozása")
                            </button>
                            <button class="fr-btn-ghost" @onclick="() => _showCreate = false">Mégse</button>
                        </div>
                    </div>
                }

                <!-- Groups layout -->
                <div class="fr-groups-layout">
                    <!-- Group list -->
                    <div class="fr-group-list">
                        @if (!_groups.Any())
                        {
                            <div class="fr-empty">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                <span>Még nem vagy egy csoportban sem.</span>
                                <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showCreate = true">Csoport létrehozása</button>
                            </div>
                        }
                        else
                        {
                            @foreach (var g in _groups)
                            {
                                var gColor = _groupColors[Math.Abs(g.GroupName?.GetHashCode() ?? 0) % _groupColors.Length];
                                <div class="fr-group-item @(_selectedGroup?.GroupID == g.GroupID ? "fr-group-item-active" : "")"
                                     @onclick="() => SelectGroup(g)">
                                    <div class="fr-group-color-dot" style="background:@gColor"></div>
                                    <div class="fr-group-item-main">
                                        <span class="fr-group-item-name">@g.GroupName</span>
                                        <span class="fr-group-item-meta">
                                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                            @g.MemberCount tag
                                            @if (g.OwnerRole == "Teacher") { <span class="fr-group-type-badge fr-type-teacher">Tanári</span> }
                                            else { <span class="fr-group-type-badge fr-type-student">Diák</span> }
                                        </span>
                                    </div>
                                    @if (g.IsOwner)
                                    {
                                        <span class="fr-badge fr-badge-accent">Tulajdonos</span>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <!-- Group detail -->
                    @if (_selectedGroup != null)
                    {
                        <div class="fr-group-detail">
                            <div class="fr-group-detail-head">
                                <h2 class="fr-group-detail-name">@_selectedGroup.GroupName</h2>
                                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                                    <div class="fr-detail-tabs">
                                        <button class="fr-dtab @(_detailTab == "members" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("members")'>Tagok</button>
                                        <button class="fr-dtab @(_detailTab == "tasks" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("tasks")'>Feladatok</button>
                                        <button class="fr-dtab @(_detailTab == "polls" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("polls")'>🗳️ Szavazás @(_polls.Count > 0 ? $"({_polls.Count})" : "")</button>
                                        <button class="fr-dtab @(_detailTab == "exams" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("exams")'>📝 Dolgozatok @(_exams.Count > 0 ? $"({_exams.Count})" : "")</button>
                                        @if (_canManage)
                                        {
                                            <button class="fr-dtab @(_detailTab == "invite" ? "fr-dtab-active" : "")" @onclick='() => SwitchTab("invite")'>Meghívó</button>
                                        }
                                    </div>
                                    @if (!_selectedGroup.IsOwner)
                                    {
                                        <button class="fr-btn-ghost fr-btn-sm fr-btn-danger" @onclick="() => LeaveGroup(_selectedGroup.GroupID)">Kilépés</button>
                                    }
                                </div>
                            </div>

                            @if (_selectedGroup.OwnerRole == "Teacher" && !_selectedGroup.IsOwner && !_isTeacher)
                            {
                                <div class="fr-permission-notice">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                    Tanári csoport — csak megtekintés és szavazás elérhető.
                                </div>
                            }

                            <div class="fr-detail-body">
                                @if (_isLoadingDetail)
                                {
                                    <div class="fr-panel-empty"><div class="fr-spinner fr-spinner-sm"></div></div>
                                }
                                else if (_detailTab == "members")
                                {
                                    <table class="fr-table">
                                        <thead><tr><th>Név</th><th>Email</th><th>Csatlakozás</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (var m in _members)
                                            {
                                                <tr>
                                                    <td class="fr-td-name">@m.FirstName @m.LastName</td>
                                                    <td class="fr-td-meta">@m.Email</td>
                                                    <td class="fr-td-meta">@m.JoinedAt.ToString("yyyy.MM.dd")</td>
                                                    <td>@if (m.IsOwner) { <span class="fr-badge fr-badge-accent">Tulajdonos</span> }</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else if (_detailTab == "tasks")
                                {
                                    <div class="fr-tab-content">
                                    @if (_canManage)
                                    {
                                        <div class="fr-teacher-form">
                                            <h3 class="fr-section-title">Csoportos feladat hozzáadása</h3>
                                            @if (_groupSubjects.Any())
                                            {
                                                <div class="fr-field">
                                                    <label class="fr-label">Tantárgy</label>
                                                    <select class="fr-input" @bind="_taskSubjectId">
                                                        <option value="0">— Válassz —</option>
                                                        @foreach (var s in _groupSubjects) { <option value="@s.SubjectID">@s.SubjectName</option> }
                                                    </select>
                                                </div>
                                            }
                                            <div class="fr-field">
                                                <label class="fr-label">Cím</label>
                                                <input class="fr-input" type="text" placeholder="pl. Mat. ZH felkészülés" @bind="_taskTitle" maxlength="200" />
                                            </div>
                                            <div class="fr-field">
                                                <label class="fr-label">Határidő</label>
                                                <input class="fr-input" type="datetime-local" @bind="_taskDate" />
                                            </div>
                                            <div class="fr-field">
                                                <label class="fr-label">Leírás (opcionális)</label>
                                                <textarea class="fr-input fr-textarea" rows="2" placeholder="Tematika, tudnivalók..." @bind="_taskDesc"></textarea>
                                            </div>
                                            @if (!string.IsNullOrEmpty(_taskError)) { <p class="fr-form-error">@_taskError</p> }
                                            <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="CreateGroupTask" disabled="@_isSavingTask">
                                                @(_isSavingTask ? "Mentés..." : "Feladat hozzáadása")
                                            </button>
                                        </div>
                                    }
                                    @if (!_groupTasks.Any())
                                    {
                                        <div class="fr-panel-empty fr-text-muted">Nincsenek feladatok.</div>
                                    }
                                    else
                                    {
                                        <table class="fr-table">
                                            <thead><tr><th>Feladat</th><th>Tantárgy</th><th>Határidő</th><th>Tag</th><th></th></tr></thead>
                                            <tbody>
                                                @foreach (var t in _groupTasks.OrderBy(t => t.DueDate))
                                                {
                                                    var overdue = !t.IsCompleted && t.DueDate < DateTime.Now;
                                                    <tr class='@(overdue ? "fr-row-danger" : "") @(t.IsCompleted ? "fr-row-done" : "")'>
                                                        <td class="fr-td-name">@t.Title</td>
                                                        <td class="fr-td-meta">@t.SubjectName</td>
                                                        <td class="fr-td-meta @(overdue ? "fr-text-danger" : "")">@t.DueDate.ToString("MM.dd HH:mm")</td>
                                                        <td class="fr-td-meta">@t.OwnerName</td>
                                                        <td>
                                                            @if (t.IsCompleted) { <span class="fr-badge fr-badge-success">Kész</span> }
                                                            else if (overdue) { <span class="fr-badge fr-badge-danger">Lejárt</span> }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    </div>
                                }
                                else if (_detailTab == "polls")
                                {
                                    <div class="fr-tab-content">
                                        @if (_canManage)
                                        {
                                            <div class="fr-teacher-form">
                                                <h3 class="fr-section-title">Új szavazás létrehozása</h3>
                                                <div class="fr-field">
                                                    <label class="fr-label">Kérdés</label>
                                                    <input class="fr-input" type="text" placeholder="pl. Szombaton lézerharc?" @bind="_pollQuestion" maxlength="300" />
                                                </div>
                                                <div class="fr-field">
                                                    <label class="fr-label">Opciók (soronként egy)</label>
                                                    <textarea class="fr-input fr-textarea" rows="4" placeholder="Igen&#10;Nem&#10;Talán" @bind="_pollOptionsText"></textarea>
                                                </div>
                                                <div class="fr-field">
                                                    <label class="fr-label">Lejárat (opcionális)</label>
                                                    <input class="fr-input" type="datetime-local" @bind="_pollExpires" />
                                                </div>
                                                @if (!string.IsNullOrEmpty(_pollError)) { <p class="fr-form-error">@_pollError</p> }
                                                <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="CreatePoll" disabled="@_isSavingPoll">
                                                    @(_isSavingPoll ? "Mentés..." : "Szavazás létrehozása")
                                                </button>
                                            </div>
                                        }
                                        @if (!_polls.Any())
                                        {
                                            <div class="fr-panel-empty fr-text-muted">Még nincs szavazás ebben a csoportban.</div>
                                        }
                                        else
                                        {
                                            @foreach (var poll in _polls)
                                            {
                                                <div class="fr-poll-card">
                                                    <div class="fr-poll-head">
                                                        <span class="fr-poll-question">@poll.Question</span>
                                                        <div style="display:flex;align-items:center;gap:8px;">
                                                            <span class="fr-td-meta">@poll.CreatedByName · @poll.CreatedAt.ToString("MM.dd")</span>
                                                            @if (poll.ExpiresAt.HasValue) { <span class="fr-badge fr-badge-warn">⏱ @poll.ExpiresAt.Value.ToString("MM.dd HH:mm")</span> }
                                                            @if (poll.CreatedBy == _currentUserId)
                                                            {
                                                                <button class="fr-icon-btn fr-icon-btn-danger" @onclick="() => DeletePoll(poll.PollID)">🗑</button>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div class="fr-poll-options">
                                                        @foreach (var opt in poll.Options)
                                                        {
                                                            var pct = poll.TotalVotes > 0 ? (opt.VoteCount * 100 / poll.TotalVotes) : 0;
                                                            var isMyVote = poll.MyVoteOptionID == opt.OptionID;
                                                            <div class='fr-poll-option @(isMyVote ? "fr-poll-option-selected" : "")' @onclick="() => CastVote(poll.PollID, opt.OptionID)">
                                                                <div class="fr-poll-bar" style="width:@pct%"></div>
                                                                <span class="fr-poll-option-text">@opt.OptionText @(isMyVote ? "✓" : "")</span>
                                                                <span class="fr-poll-pct">@opt.VoteCount szavazat (@pct%)</span>
                                                            </div>
                                                        }
                                                    </div>
                                                    <p class="fr-poll-total">Összesen: @poll.TotalVotes szavazat</p>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                else if (_detailTab == "exams")
                                {
                                    <div class="fr-tab-content">
                                        @if (_canManage)
                                        {
                                            <div class="fr-teacher-form">
                                                <h3 class="fr-section-title">Dolgozat meghirdetése</h3>
                                                <div class="fr-field">
                                                    <label class="fr-label">Megnevezés</label>
                                                    <input class="fr-input" type="text" placeholder="pl. Matek ZH – 3. fejezet" @bind="_examTitle" maxlength="200" />
                                                </div>
                                                <div class="fr-field">
                                                    <label class="fr-label">Tantárgy neve (opcionális)</label>
                                                    <input class="fr-input" type="text" placeholder="pl. Matematika" @bind="_examSubject" />
                                                </div>
                                                <div class="fr-field">
                                                    <label class="fr-label">Dátum és idő</label>
                                                    <input class="fr-input" type="datetime-local" @bind="_examDate" />
                                                </div>
                                                <div class="fr-field">
                                                    <label class="fr-label">Leírás (opcionális)</label>
                                                    <textarea class="fr-input fr-textarea" rows="2" placeholder="Tematika, tudnivalók..." @bind="_examDesc"></textarea>
                                                </div>
                                                @if (!string.IsNullOrEmpty(_examError)) { <p class="fr-form-error">@_examError</p> }
                                                <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="CreateExam" disabled="@_isSavingExam">
                                                    @(_isSavingExam ? "Mentés..." : "Dolgozat hozzáadása")
                                                </button>
                                            </div>
                                        }
                                        @if (!_exams.Any())
                                        {
                                            <div class="fr-panel-empty fr-text-muted">Még nincs dolgozat ebben a csoportban.</div>
                                        }
                                        else
                                        {
                                            <table class="fr-table">
                                                <thead><tr><th>Dolgozat</th><th>Tantárgy</th><th>Dátum</th><th>Tanár</th><th></th></tr></thead>
                                                <tbody>
                                                    @foreach (var ex in _exams.OrderBy(e => e.ExamDate))
                                                    {
                                                        var isPast = ex.ExamDate < DateTime.Now;
                                                        <tr class='@(isPast ? "fr-row-done" : "")'>
                                                            <td class="fr-td-name">
                                                                @ex.Title
                                                                @if (!string.IsNullOrEmpty(ex.Description)) { <div class="fr-td-meta" style="margin-top:2px">@ex.Description</div> }
                                                            </td>
                                                            <td class="fr-td-meta">@(ex.SubjectName ?? "—")</td>
                                                            <td class="fr-td-meta">@ex.ExamDate.ToString("yyyy.MM.dd HH:mm")</td>
                                                            <td class="fr-td-meta">@ex.CreatedByName</td>
                                                            <td>
                                                                @if (ex.CreatedBy == _currentUserId || _userRole == "Admin")
                                                                {
                                                                    <button class="fr-icon-btn fr-icon-btn-danger" @onclick="() => DeleteExam(ex.ExamID)">🗑</button>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                }
                                else if (_detailTab == "invite" && (_canManage))
                                {
                                    <div class="fr-invite-form">
                                        <p class="fr-form-desc">Add meg a meghívandó személy email-címét.@(_isTeacher ? " Tanárként bárkit meghívhatsz." : "")</p>
                                        <div class="fr-form-row-inline">
                                            <input class="fr-input" type="email" placeholder="email@example.com" @bind="_inviteEmail" />
                                            <button class="fr-btn fr-btn-primary" @onclick="SendInvite" disabled="@_isInviting">
                                                @(_isInviting ? "Küldés..." : "Meghívó küldése")
                                            </button>
                                        </div>
                                        @if (!string.IsNullOrEmpty(_inviteError))
                                        {
                                            <p class="fr-form-error">@_inviteError</p>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        
                        <div class="fr-group-welcome">
                            <div class="fr-welcome-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" opacity=".5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <h2 class="fr-welcome-title">Válassz egy csoportot</h2>
                            <p class="fr-welcome-desc">A bal oldali listából válassz egy csoportot a részletek megtekintéséhez, vagy hozz létre egy újat.</p>

                            <div class="fr-welcome-stats">
                                <div class="fr-wstat">
                                    <span class="fr-wstat-value">@_groups.Count</span>
                                    <span class="fr-wstat-label">Csoportom</span>
                                </div>
                                <div class="fr-wstat-divider"></div>
                                <div class="fr-wstat">
                                    <span class="fr-wstat-value">@_groups.Sum(g => g.MemberCount)</span>
                                    <span class="fr-wstat-label">Összes tag</span>
                                </div>
                                <div class="fr-wstat-divider"></div>
                                <div class="fr-wstat">
                                    <span class="fr-wstat-value">@_invites.Count</span>
                                    <span class="fr-wstat-label">Meghívó</span>
                                </div>
                            </div>

                            @if (_groups.Any())
                            {
                                <div class="fr-welcome-tip">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                    Legutóbbi csoport: <strong>@_groups.First().GroupName</strong> — kattints rá a bal oldali listában.
                                </div>
                            }

                            <button class="fr-btn fr-btn-primary" @onclick="() => _showCreate = true">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Új csoport létrehozása
                            </button>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>
}
else
{
    <div class="fr-unauth"><p>Nincs aktív munkamenet.</p><a href="/login" class="fr-btn fr-btn-primary">Bejelentkezés</a></div>
}

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    /* ── Topbar (gradient) + layout ── tokens from app.css */
    .fr-layout {
        display:flex; flex-direction:row; width:100vw; height:100vh; overflow:hidden;
        background:var(--bg,#f4f2f8); font-family:var(--font); color:var(--text-primary);
        --accent:#667eea; --accent-2:#764ba2; --accent-hover:#5a6fd8;
        --accent-subtle:rgba(102,126,234,.12); --accent-subtle-strong:rgba(102,126,234,.2);
        --bg:#f4f2f8; --surface:#fff; --surface-2:#f0eef8;
        --border:#e2ddf0; --border-strong:#c4bce0;
        --text-primary:#1a1630; --text-secondary:#4a4470; --text-muted:#8880aa;
        --danger:#e53935; --danger-subtle:rgba(229,57,53,.09);
        --warning:#f59e0b; --warning-subtle:rgba(245,158,11,.1);
        --success:#0e9f6e; --success-subtle:rgba(14,159,110,.1);
        --radius:12px;
    }
    .fr-layout[data-role="Teacher"] { --accent:#f59e0b; --accent-2:#d97706; --accent-hover:#d97706; --accent-subtle:rgba(245,158,11,.12); --accent-subtle-strong:rgba(245,158,11,.22); }
    .fr-layout[data-role="Teacher"] .fr-btn-primary { background:linear-gradient(135deg,#b45309,#f59e0b) !important; box-shadow:0 2px 10px rgba(245,158,11,.3) !important; }
    .fr-layout[data-role="Teacher"] .fr-btn-primary:hover:not(:disabled) { box-shadow:0 4px 16px rgba(217,119,6,.45); }
    .fr-layout[data-role="Teacher"] .fr-topbar { background:linear-gradient(135deg,#b45309 0%,#f59e0b 100%) !important; box-shadow:0 2px 16px rgba(245,158,11,.25) !important; }
    .fr-layout[data-role="Teacher"] .fr-brand { background:linear-gradient(135deg,#b45309 0%,#f59e0b 100%) !important; }
    .fr-layout[data-theme="dark"] {
        --bg:#0d0b18; --surface:#16132a; --surface-2:#1e1a38; --border:#2e2850; --border-strong:#4a4270;
        --text-primary:#f0eeff; --text-secondary:#9890cc; --text-muted:#5a5480;
        --accent-subtle:rgba(102,126,234,.18); --accent-subtle-strong:rgba(102,126,234,.28);
        --danger-subtle:rgba(229,57,53,.15); --warning-subtle:rgba(245,158,11,.13); --success-subtle:rgba(14,159,110,.13);
    }
    /* Admin — piros téma */
.fr-layout[data-role="Admin"] { --accent:#e53935; --accent-2:#b71c1c; --accent-hover:#c62828; --accent-subtle:rgba(229,57,53,.12); --accent-subtle-strong:rgba(229,57,53,.22); }
.fr-layout[data-role="Admin"] .fr-btn-primary { background:linear-gradient(135deg,#b71c1c,#e53935) !important; box-shadow:0 2px 10px rgba(229,57,53,.3) !important; }
.fr-layout[data-role="Admin"] .fr-btn-primary:hover:not(:disabled) { box-shadow:0 4px 16px rgba(229,57,53,.45); }
.fr-layout[data-role="Admin"] .fr-topbar { background:linear-gradient(135deg,#b71c1c 0%,#e53935 100%) !important; box-shadow:0 2px 16px rgba(229,57,53,.25) !important; }
.fr-layout[data-role="Admin"] .fr-brand { background:linear-gradient(135deg,#b71c1c 0%,#e53935 100%) !important; }
    .fr-sidebar { position:fixed; top:0; left:0; width:270px; height:100vh; z-index:200; display:flex; flex-direction:column; background:var(--surface); border-right:1px solid var(--border); transform:translateX(-270px); transition:transform .25s cubic-bezier(.4,0,.2,1); box-shadow:4px 0 32px rgba(102,126,234,.15); overflow:hidden; }
    .fr-sidebar.fr-sidebar-open { transform:translateX(0); }
    .fr-sidebar-backdrop { position:fixed; inset:0; z-index:199; background:rgba(26,22,48,.45); backdrop-filter:blur(3px); }
    .fr-brand { flex-shrink:0; display:flex; align-items:center; gap:9px; padding:18px 18px 16px; font-size:.95rem; font-weight:700; color:#fff; text-decoration:none; background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); }
    .fr-nav { flex-shrink:0; display:flex; flex-direction:column; gap:2px; padding:10px 8px; border-bottom:1px solid var(--border); }
    .fr-nav-item { display:flex; align-items:center; gap:9px; padding:9px 11px; border-radius:9px; text-decoration:none; font-size:.84rem; font-weight:500; color:var(--text-secondary); transition:all .15s; }
    .fr-nav-item:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-nav-item.fr-active { background:var(--accent-subtle); color:var(--accent); font-weight:600; }
    .fr-sidebar-footer { padding:10px 8px; display:flex; flex-direction:column; gap:2px; margin-top:auto; }
    .fr-theme-toggle, .fr-logout { display:flex; align-items:center; gap:9px; width:100%; padding:9px 11px; border:none; border-radius:9px; background:none; color:var(--text-secondary); font-size:.84rem; font-weight:500; cursor:pointer; text-align:left; transition:all .15s; font-family:var(--font); }
    .fr-theme-toggle:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-logout:hover { background:var(--danger-subtle); color:var(--danger); }
    .fr-main { display:flex; flex-direction:column; width:100vw; height:100vh; overflow:hidden; transition:width .25s cubic-bezier(.4,0,.2,1),margin-left .25s cubic-bezier(.4,0,.2,1); }
    .fr-menu-open .fr-main { width:calc(100vw - 270px); margin-left:270px; }
    .fr-topbar { display:flex; align-items:center; justify-content:space-between; padding:0 20px; height:56px; background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); box-shadow:0 2px 16px rgba(102,126,234,.3); flex-shrink:0; gap:12px; }
    .fr-topbar-left { display:flex; align-items:center; gap:10px; }
    .fr-topbar-right { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .fr-hamburger { width:34px; height:34px; border:1px solid rgba(255,255,255,.3); border-radius:8px; background:rgba(255,255,255,.1); backdrop-filter:blur(8px); display:flex; align-items:center; justify-content:center; cursor:pointer; color:#fff; transition:all .15s; }
    .fr-hamburger:hover { background:rgba(255,255,255,.2); }
    .fr-page-title { font-size:1rem; font-weight:700; color:#fff; }
    .fr-breadcrumb { font-size:.8rem; color:rgba(255,255,255,.65); }
    .fr-user-chip { display:flex; align-items:center; gap:7px; padding:6px 12px; border-radius:20px; background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.25); font-size:.8rem; color:#fff; font-weight:500; backdrop-filter:blur(8px); }
    .fr-user-dot { width:7px; height:7px; border-radius:50%; background:#4ade80; flex-shrink:0; }
    .fr-loading { display:flex; align-items:center; justify-content:center; height:100vh; }
    .fr-loading-inline { display:flex; align-items:center; gap:10px; padding:40px; color:var(--text-muted); font-size:.875rem; }
    .fr-spinner { width:28px; height:28px; border:2.5px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:fr-spin .7s linear infinite; }
    @@keyframes fr-spin { to { transform:rotate(360deg); } }
    .fr-unauth { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100vh; gap:16px; }
    .fr-btn { display:inline-flex; align-items:center; gap:7px; padding:9px 16px; border-radius:9px; font-size:.875rem; font-weight:600; text-decoration:none; border:none; cursor:pointer; transition:all .15s; font-family:var(--font); }
    .fr-btn-primary { background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; box-shadow:0 2px 10px rgba(102,126,234,.35); }
    .fr-btn-primary:hover:not(:disabled) { box-shadow:0 4px 16px rgba(102,126,234,.45); transform:translateY(-1px); }
    .fr-btn-primary:disabled { opacity:.5; cursor:not-allowed; }
    .fr-btn-ghost { background:none; border:1.5px solid var(--border); color:var(--text-secondary); }
    .fr-btn-ghost:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-btn-sm { padding:7px 12px; font-size:.82rem; }
    .fr-icon-btn { width:28px; height:28px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border); border-radius:7px; background:none; color:var(--text-muted); cursor:pointer; transition:all .15s; }
    .fr-icon-btn:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-field { display:flex; flex-direction:column; gap:5px; flex:1; min-width:150px; }
    .fr-label { font-size:.78rem; font-weight:600; color:var(--text-secondary); }
    .fr-input { padding:8px 12px; border:1.5px solid var(--border); border-radius:9px; background:var(--surface); color:var(--text-primary); font-size:.875rem; font-family:var(--font); outline:none; transition:border-color .15s,box-shadow .15s; width:100%; }
    .fr-input:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-subtle); }
    .fr-alert { display:flex; align-items:center; gap:10px; padding:11px 16px; border-radius:9px; font-size:.875rem; font-weight:500; }
    .fr-alert-danger { background:var(--danger-subtle); color:var(--danger); border:1px solid rgba(229,57,53,.2); }
    .fr-alert-success { background:var(--success-subtle); color:var(--success); border:1px solid rgba(14,159,110,.2); }
    .fr-alert-close { margin-left:auto; background:none; border:none; cursor:pointer; color:inherit; opacity:.6; display:flex; align-items:center; }
    .fr-panel { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
    .fr-panel-header { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid var(--border); background:linear-gradient(135deg,rgba(102,126,234,.05),rgba(118,75,162,.05)); }
    .fr-panel-title { font-weight:700; font-size:.875rem; display:flex; align-items:center; color:var(--text-primary); }
    .fr-panel-link { font-size:.78rem; color:var(--accent); text-decoration:none; font-weight:500; }
    .fr-panel-empty { display:flex; align-items:center; justify-content:center; padding:40px; color:var(--text-muted); font-size:.875rem; }
    .fr-form-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:22px 24px; display:flex; flex-direction:column; gap:16px; }
    .fr-form-title { font-size:1rem; font-weight:700; color:var(--text-primary); }
    .fr-form-desc { font-size:.82rem; color:var(--text-muted); }
    .fr-form-row { display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; }
    .fr-required { color:var(--danger); }
    .fr-optional { font-weight:400; color:var(--text-muted); }
    .fr-badge { display:inline-flex; align-items:center; justify-content:center; padding:2px 8px; border-radius:12px; font-size:.73rem; font-weight:700; }
    .fr-badge-warn { background:var(--warning-subtle); color:var(--warning); }

    /* ── Csoportok oldal specifikus CSS ── */
    .fr-content { flex:1; overflow-y:auto; padding:20px 24px; display:flex; flex-direction:column; gap:16px; }

    /* Panel body */
    .fr-panel-body { display:flex; flex-direction:column; }

    /* Invites */
    .fr-invite-row { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:12px 18px; border-bottom:1px solid var(--border); flex-wrap:wrap; }
    .fr-invite-row:last-child { border-bottom:none; }
    .fr-invite-info { display:flex; flex-direction:column; gap:3px; }
    .fr-invite-name { font-weight:600; font-size:.875rem; color:var(--text-primary); }
    .fr-invite-from { font-size:.75rem; color:var(--text-muted); }

    /* Groups layout */
    .fr-groups-layout { display:flex; gap:16px; align-items:flex-start; }
    .fr-group-list { width:260px; flex-shrink:0; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; display:flex; flex-direction:column; }
    .fr-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; padding:40px 20px; color:var(--text-muted); font-size:.875rem; text-align:center; }

    /* Group items */
    .fr-group-item { display:flex; align-items:center; gap:10px; padding:11px 14px; cursor:pointer; transition:background .1s; border-bottom:1px solid var(--border); }
    .fr-group-item:last-child { border-bottom:none; }
    .fr-group-item:hover { background:var(--surface-2); }
    .fr-group-item-active { background:var(--accent-subtle) !important; }
    .fr-group-color-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
    .fr-group-item-main { flex:1; display:flex; flex-direction:column; gap:2px; min-width:0; }
    .fr-group-item-name { font-size:.875rem; font-weight:600; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .fr-group-item-meta { display:flex; align-items:center; gap:4px; font-size:.73rem; color:var(--text-muted); }

    /* Group detail */
    .fr-group-detail { flex:1; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; min-width:0; }
    .fr-group-detail-head { padding:16px 20px; border-bottom:1px solid var(--border); background:linear-gradient(135deg,rgba(102,126,234,.05),rgba(118,75,162,.05)); display:flex; flex-direction:column; gap:10px; }
    .fr-group-detail-name { font-size:1.1rem; font-weight:800; color:var(--text-primary); }

    /* Detail tabs */
    .fr-detail-tabs { display:flex; flex-wrap:wrap; gap:4px; }
    .fr-dtab { padding:6px 14px; border-radius:8px; border:none; background:none; color:var(--text-secondary); font-size:.82rem; font-weight:500; cursor:pointer; transition:all .15s; font-family:var(--font); }
    .fr-dtab:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-dtab-active { background:var(--accent-subtle); color:var(--accent); font-weight:600; }

    /* Danger button variant */
    .fr-btn-danger { border-color:var(--danger) !important; color:var(--danger) !important; }
    .fr-btn-danger:hover { background:var(--danger-subtle) !important; }

    /* Detail body */
    .fr-detail-body { overflow:auto; }

    /* Table */
    .fr-table { width:100%; border-collapse:collapse; }
    .fr-table thead tr { background:linear-gradient(135deg,rgba(102,126,234,.04),rgba(118,75,162,.04)); border-bottom:1.5px solid var(--border); }
    .fr-table th { padding:10px 14px; text-align:left; font-size:.75rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.04em; white-space:nowrap; }
    .fr-table td { padding:11px 14px; border-bottom:1px solid var(--border); vertical-align:middle; }
    .fr-table tbody tr:last-child td { border-bottom:none; }
    .fr-table tbody tr:hover { background:var(--surface-2); }
    .fr-td-name { font-size:.875rem; font-weight:500; color:var(--text-primary); }
    .fr-td-meta { font-size:.8rem; color:var(--text-secondary); }
    .fr-td-code { font-size:.72rem; font-weight:700; color:var(--accent); }
    .fr-text-muted { color:var(--text-muted); }
    .fr-text-danger { color:var(--danger); font-weight:600; }
    .fr-row-danger { background:var(--danger-subtle) !important; }
    .fr-row-done td { opacity:.55; }

    /* Extra badges */
    .fr-badge-success { background:var(--success-subtle); color:var(--success); }
    .fr-badge-danger { background:var(--danger-subtle); color:var(--danger); }
    .fr-badge-accent { background:var(--accent-subtle); color:var(--accent); }
    .fr-group-type-badge { font-size:.65rem; font-weight:700; padding:1px 6px; border-radius:8px; margin-left:4px; }
    .fr-type-teacher { background:rgba(234,88,12,.12); color:#ea580c; }
    .fr-type-student { background:rgba(14,159,110,.12); color:#0e9f6e; }
    .fr-permission-notice { display:flex; align-items:center; gap:8px; padding:10px 16px; margin:0 0 -8px; border-radius:8px; background:rgba(245,158,11,.1); color:#b45309; font-size:.82rem; font-weight:500; border:1px solid rgba(245,158,11,.2); }

    /* Tab content wrapper */
    .fr-tab-content { display:flex; flex-direction:column; gap:16px; padding:16px 20px; }

    /* Teacher form */
    .fr-teacher-form { background:var(--surface-2); border:1px solid var(--border); border-radius:10px; padding:16px; display:flex; flex-direction:column; gap:12px; }
    .fr-section-title { font-size:.875rem; font-weight:700; color:var(--text-primary); }
    .fr-form-error { font-size:.8rem; color:var(--danger); font-weight:500; }
    .fr-textarea { resize:vertical; min-height:80px; }

    /* Icon btn danger */
    .fr-icon-btn-danger { border-color:var(--danger-subtle) !important; color:var(--danger) !important; }
    .fr-icon-btn-danger:hover { background:var(--danger-subtle) !important; }

    /* Polls */
    .fr-poll-card { background:var(--surface-2); border:1px solid var(--border); border-radius:10px; padding:14px 16px; display:flex; flex-direction:column; gap:10px; }
    .fr-poll-head { display:flex; align-items:flex-start; justify-content:space-between; gap:10px; flex-wrap:wrap; }
    .fr-poll-question { font-size:.9rem; font-weight:700; color:var(--text-primary); flex:1; }
    .fr-poll-options { display:flex; flex-direction:column; gap:6px; }
    .fr-poll-option { position:relative; display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:8px; border:1.5px solid var(--border); background:var(--surface); cursor:pointer; transition:all .15s; overflow:hidden; }
    .fr-poll-option:hover { border-color:var(--accent); background:var(--accent-subtle); }
    .fr-poll-option-selected { border-color:var(--accent); background:var(--accent-subtle); }
    .fr-poll-bar { position:absolute; left:0; top:0; bottom:0; background:var(--accent-subtle); opacity:.6; border-radius:6px; transition:width .4s ease; pointer-events:none; }
    .fr-poll-option-text { flex:1; font-size:.82rem; font-weight:500; color:var(--text-primary); position:relative; z-index:1; }
    .fr-poll-pct { font-size:.75rem; font-weight:700; color:var(--accent); position:relative; z-index:1; }
    .fr-poll-total { font-size:.75rem; color:var(--text-muted); }

    /* Invite form */
    .fr-invite-form { padding:16px 20px; display:flex; flex-direction:column; gap:12px; }
    .fr-form-row-inline { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
    .fr-form-row-inline .fr-input { flex:1; min-width:200px; }

    /* Welcome state */
    .fr-group-welcome { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px; padding:48px 32px; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); text-align:center; }
    .fr-welcome-icon { width:80px; height:80px; border-radius:50%; background:var(--surface-2); display:flex; align-items:center; justify-content:center; }
    .fr-welcome-title { font-size:1.2rem; font-weight:800; color:var(--text-primary); }
