@page "/csoport"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject GroupService GroupService
@inject TeacherService TeacherService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Csoportok — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (_isAuthenticated)
{
    <div class="@LayoutClass" data-theme="@_theme" data-role="@_userRole">
        @if (_menuOpen) { <div class="fr-sidebar-backdrop" @onclick="CloseMenu"></div> }
        <aside class="@SidebarClass">
                        <a href="/dashboard" class="fr-brand" @onclick="CloseMenu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <span>FeladatRadar</span>
            </a>
            <nav class="fr-nav">
                <a href="/dashboard" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></a>
                <a href="/naptar" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Naptár</a>
                <a href="/fokusz" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item fr-active" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Csoportok</a>
                            @if (_userRole == "Admin") { <a href="/admin" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>Admin</a> }
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark") { <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/></svg><span>Világos mód</span> }
                    else { <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg><span>Sötét mód</span> }
                </button>
                <button class="fr-logout" @onclick="HandleLogout"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Kijelentkezés</button>
            </div>
        </aside>

        <main class="fr-main">
            <header class="fr-topbar">
                <div class="fr-topbar-left">
                    <button class="fr-hamburger" @onclick="ToggleMenu" title="Menü">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                                        <span class="fr-page-title">Csoportok</span>
                    <span class="fr-breadcrumb">/ @_groups.Count csoport</span>
                </div>
                <div class="fr-topbar-right">
                    <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showCreate = !_showCreate">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Új csoport
                    </button>
                </div>
            </header>

            <div class="fr-content">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="fr-alert @(_messageIsError ? "fr-alert-danger" : "fr-alert-success")">
                        @_message
                        <button class="fr-alert-close" @onclick="() => _message = string.Empty"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                    </div>
                }

                <!-- Pending invites -->
                @if (_invites.Any())
                {
                    <div class="fr-panel">
                        <div class="fr-panel-header">
                            <span class="fr-panel-title">Függő meghívók</span>
                            <span class="fr-badge fr-badge-warn">@_invites.Count</span>
                        </div>
                        <div class="fr-panel-body">
                            @foreach (var inv in _invites)
                            {
                                <div class="fr-invite-row">
                                    <div class="fr-invite-info">
                                        <span class="fr-invite-name">@inv.GroupName</span>
                                        <span class="fr-invite-from">meghívta: @inv.InvitedByName · @inv.CreatedAt.ToString("MM.dd")</span>
                                    </div>
                                    <div style="display:flex;gap:8px;">
                                        <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => AcceptInvite(inv.InviteID)">Elfogadás</button>
                                        <button class="fr-btn-ghost fr-btn-sm" @onclick="() => DeclineInvite(inv.InviteID)">Elutasítás</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Create group form -->
                @if (_showCreate)
                {
                    <div class="fr-form-card">
                        <h2 class="fr-form-title">Új csoport létrehozása</h2>
                        <div class="fr-field">
                            <label class="fr-label">Csoport neve</label>
                            <input class="fr-input" type="text" placeholder="pl. Vizsgacsoport 2025" @bind="_newGroupName" maxlength="100" />
                        </div>
                        @if (!string.IsNullOrEmpty(_createError))
                        {
                            <div class="fr-alert fr-alert-danger">@_createError</div>
                        }
                        <div style="display:flex;gap:10px;">
                            <button class="fr-btn fr-btn-primary" @onclick="CreateGroup" disabled="@_isCreating">
                                @(_isCreating ? "Létrehozás..." : "Csoport létrehozása")
                            </button>
                            <button class="fr-btn-ghost" @onclick="() => _showCreate = false">Mégse</button>
                        </div>
                    </div>
                }

                <!-- Groups layout -->
                <div class="fr-groups-layout">
                    <!-- Group list -->
                    <div class="fr-group-list">
                        @if (!_groups.Any())
                        {
                            <div class="fr-empty">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                <span>Még nem vagy egy csoportban sem.</span>
                                <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showCreate = true">Csoport létrehozása</button>
                            </div>
                        }
                        else
                        {
                            @foreach (var g in _groups)
                            {
                                var gColor = _groupColors[Math.Abs(g.GroupName?.GetHashCode() ?? 0) % _groupColors.Length];
                                <div class="fr-group-item @(_selectedGroup?.GroupID == g.GroupID ? "fr-group-item-active" : "")"
                                     @onclick="() => SelectGroup(g)">
                                    <div class="fr-group-color-dot" style="background:@gColor"></div>
                                    <div class="fr-group-item-main">
                                        <span class="fr-group-item-name">@g.GroupName</span>
                                        <span class="fr-group-item-meta">
                                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
