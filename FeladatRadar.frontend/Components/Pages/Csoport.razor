@code {
        private bool _menuOpen = false;
    private string SidebarClass => _menuOpen ? "fr-sidebar fr-sidebar-open" : "fr-sidebar";
    private string LayoutClass => _menuOpen ? "fr-layout fr-menu-open" : "fr-layout";
    private void ToggleMenu() { _menuOpen = !_menuOpen; StateHasChanged(); }
    private void CloseMenu() { _menuOpen = false; StateHasChanged(); }
    private bool _hasCheckedAuth = false;
    private bool _isAuthenticated = false;
    private string _userEmail = "";
    private string _message = "";
    private bool _messageIsError = false;
    private string _theme = "light";
    private string _userRole = "";

    private static readonly string[] _groupColors = { "#4f46e5","#0891b2","#0e9f6e","#d97706","#db2777","#7c3aed","#ea580c","#65a30d" };

    private List<GroupDto> _groups = new();
    private List<GroupInviteDto> _invites = new();
    private GroupDto? _selectedGroup = null;
    private string _detailTab = "members";

    private List<GroupMemberDto> _members = new();
    private List<GroupSubjectDto> _groupSubjects = new();
    private List<GroupTaskDto> _groupTasks = new();
    private bool _isLoadingDetail = false;

    private bool _showCreate = false;
    private string _newGroupName = "";
    private string _createError = "";
    private bool _isCreating = false;

    private string _inviteEmail = "";
    private string _inviteError = "";
    private bool _isInviting = false;

    
    private bool _isTeacher = false;
    private int _currentUserId = 0;

    
    private bool _canManage
    {
        get
        {
            if (_selectedGroup == null) return false;
            // Tanári csoport: csak tanár kezelhet
            if (_selectedGroup.OwnerRole == "Teacher") return _isTeacher;
            // Diák csoport: mindenki kezelhet
            return true;
        }
    }

    
    private List<PollDto> _polls = new();
    private string _pollQuestion = "";
    
    private string _pollOptionsText = "Igen\nNem\nTalán";
    private DateTime? _pollExpires = null;
    private string _pollError = "";
    private bool _isSavingPoll = false;

    
    private List<TeacherExamDto> _exams = new();
    private string _examTitle = "";
    private string _examSubject = "";
    private DateTime _examDate = DateTime.Now.AddDays(7);
    private string _examDesc = "";
    private string _examError = "";
    private int _taskSubjectId = 0;
    private string _taskTitle = "";
    private DateTime _taskDate = DateTime.Now.AddDays(7);
    private string _taskDesc = "";
    private string _taskError = "";
    private bool _isSavingTask = false;
    private bool _isSavingExam = false;

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.setTheme", _theme);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        try { await AuthService.InitializeAsync(); } catch { }
        _hasCheckedAuth = true;
        _isAuthenticated = AuthService.IsAuthenticated;
        _userEmail = AuthService.CurrentUser?.Email ?? "";
        _isTeacher = AuthService.CurrentUser?.UserRole == "Teacher";
        _userRole = AuthService.CurrentUser?.UserRole ?? "";
        _currentUserId = AuthService.CurrentUser?.UserID ?? 0;
        if (!_isAuthenticated) { Navigation.NavigateTo("/login"); return; }
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try { _groups = await GroupService.GetMyGroupsAsync(); } catch { _groups = new(); }
        try { _invites = await GroupService.GetMyInvitesAsync(); } catch { _invites = new(); }
        // Utoljára használt sorrend – LocalStorage alapján
        await SortGroupsByLastUsed();
    }

    private async Task SortGroupsByLastUsed()
    {
        var order = new Dictionary<int, long>();
        foreach (var g in _groups)
        {
            try
            {
                var ts = await JS.InvokeAsync<long>("groupHelper.getLastUsed", g.GroupID);
                order[g.GroupID] = ts;
            }
            catch { order[g.GroupID] = 0; }
        }
        _groups = _groups.OrderByDescending(g => order.GetValueOrDefault(g.GroupID, 0)).ToList();
    }

    private async Task SelectGroup(GroupDto g)
    {
        _selectedGroup = g;
        _detailTab = "members";
        
        try { await JS.InvokeVoidAsync("groupHelper.setLastUsed", g.GroupID, DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()); } catch { }
        await LoadGroupDetail();
    }

    private async Task LoadGroupDetail()
    {
        if (_selectedGroup == null) return;
        _isLoadingDetail = true; StateHasChanged();
        try { _members = await GroupService.GetMembersAsync(_selectedGroup.GroupID); } catch { _members = new(); }
        try { _groupSubjects = await GroupService.GetGroupSubjectsAsync(_selectedGroup.GroupID); } catch { _groupSubjects = new(); }
        try { _groupTasks = await GroupService.GetGroupTasksAsync(_selectedGroup.GroupID); } catch { _groupTasks = new(); }
        try { _polls = await TeacherService.GetGroupPollsAsync(_selectedGroup.GroupID); } catch { _polls = new(); }
        try { _exams = await TeacherService.GetGroupExamsAsync(_selectedGroup.GroupID); } catch { _exams = new(); }
        _isLoadingDetail = false; StateHasChanged();
    }

    private async Task SwitchTab(string tab)
    {
        _detailTab = tab;
        StateHasChanged();
    }

    // ── SZAVAZÁS ──
    private async Task CreatePoll()
    {
        _pollError = "";
        if (string.IsNullOrWhiteSpace(_pollQuestion)) { _pollError = "Add meg a kérdést."; return; }
        
        var opts = _pollOptionsText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        if (opts.Count < 2) { _pollError = "Legalább 2 opció szükséges."; return; }
        _isSavingPoll = true; StateHasChanged();
        try
        {
            var r = await TeacherService.CreatePollAsync(_selectedGroup!.GroupID, _pollQuestion.Trim(), opts, _pollExpires);
            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                _message = "Szavazás létrehozva."; _messageIsError = false;
                
                _pollQuestion = ""; _pollOptionsText = "Igen\nNem\nTalán"; _pollExpires = null;
                _polls = await TeacherService.GetGroupPollsAsync(_selectedGroup.GroupID);
            }
            else { _pollError = r.Message; }
        }
        catch (Exception ex) { _pollError = ex.Message; }
        finally { _isSavingPoll = false; StateHasChanged(); }
    }

    private async Task CastVote(int pollId, int optionId)
    {
        try
        {
            var r = await TeacherService.VoteAsync(pollId, optionId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Szavazat rögzítve!";
            if (!_messageIsError) _polls = await TeacherService.GetGroupPollsAsync(_selectedGroup!.GroupID);
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task DeletePoll(int pollId)
    {
        try
        {
            var r = await TeacherService.DeletePollAsync(pollId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Szavazás törölve.";
            if (!_messageIsError) _polls = await TeacherService.GetGroupPollsAsync(_selectedGroup!.GroupID);
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

   
    private async Task CreateExam()
    {
        _examError = "";
        if (string.IsNullOrWhiteSpace(_examTitle)) { _examError = "Add meg a dolgozat nevét."; return; }
        _isSavingExam = true; StateHasChanged();
        try
        {
            var r = await TeacherService.CreateExamAsync(_selectedGroup!.GroupID, _examTitle.Trim(),
                _examDate, _examDesc.Trim(), _examSubject.Trim());
            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                _message = "Dolgozat felvéve a naptárba."; _messageIsError = false;
                _examTitle = ""; _examSubject = ""; _examDesc = "";
                _examDate = DateTime.Now.AddDays(7);
                _exams = await TeacherService.GetGroupExamsAsync(_selectedGroup.GroupID);
            }
            else { _examError = r.Message; }
        }
        catch (Exception ex) { _examError = ex.Message; }
        finally { _isSavingExam = false; StateHasChanged(); }
    }

    private async Task CreateGroupTask()
    {
        _taskError = "";
        if (string.IsNullOrWhiteSpace(_taskTitle)) { _taskError = "Add meg a feladat címét."; return; }
        if (_selectedGroup == null) return;
        _isSavingTask = true;
        try
        {
            var req = new AddGroupTaskRequest
            {
                SubjectID = _taskSubjectId > 0 ? _taskSubjectId : (_groupSubjects.Any() ? _groupSubjects[0].SubjectID : 1),
                Title = _taskTitle,
                Description = string.IsNullOrWhiteSpace(_taskDesc) ? null : _taskDesc,
                DueDate = _taskDate,
                TaskType = "Homework"
            };
            var r = await GroupService.AddGroupTaskAsync(_selectedGroup.GroupID, req);
            if (r.Status == "OK")
            {
                _taskTitle = ""; _taskDesc = ""; _taskError = ""; _taskSubjectId = 0;
                _taskDate = DateTime.Now.AddDays(7);
                _groupTasks = await GroupService.GetGroupTasksAsync(_selectedGroup.GroupID);
                _message = "Csoportos feladat hozzáadva."; _messageIsError = false;
            }
            else { _taskError = r.Message; }
        }
        finally { _isSavingTask = false; StateHasChanged(); }
    }

    private async Task DeleteExam(int examId)
    {
        try
        {
            SubjectResponse r;
            if (_userRole == "Admin")
                r = await AdminService.DeleteExamAsync(examId);
            else
                r = await TeacherService.DeleteExamAsync(examId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Dolgozat törölve.";
            if (!_messageIsError) _exams = await TeacherService.GetGroupExamsAsync(_selectedGroup!.GroupID);
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task CreateGroup()
    {
        _createError = "";
        if (string.IsNullOrWhiteSpace(_newGroupName)) { _createError = "Add meg a csoport nevét."; return; }
        _isCreating = true; StateHasChanged();
        try
        {
            var r = await GroupService.CreateGroupAsync(_newGroupName.Trim());
            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                _message = "Csoport létrehozva."; _messageIsError = false;
                _newGroupName = ""; _showCreate = false;
                await LoadData();
            }
            else { _createError = r.Message; }
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _isCreating = false; StateHasChanged(); }
    }

    private async Task AcceptInvite(int inviteId)
    {
        try
        {
            var r = await GroupService.AcceptInviteAsync(inviteId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Meghívó elfogadva.";
            if (!_messageIsError) await LoadData();
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task DeclineInvite(int inviteId)
    {
        try
        {
            var r = await GroupService.DeclineInviteAsync(inviteId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Meghívó elutasítva.";
            if (!_messageIsError) await LoadData();
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task LeaveGroup(int groupId)
    {
        try
        {
            var r = await GroupService.LeaveGroupAsync(groupId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Kilépés sikeres.";
            if (!_messageIsError) { _selectedGroup = null; await LoadData(); }
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task SendInvite()
    {
        _inviteError = "";
        if (string.IsNullOrWhiteSpace(_inviteEmail)) { _inviteError = "Add meg az email-címet."; return; }
        if (_selectedGroup == null) return;
        _isInviting = true; StateHasChanged();
        try
        {
            var r = await GroupService.InviteAsync(_selectedGroup.GroupID, _inviteEmail.Trim());
            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                _message = $"Meghívó elküldve: {_inviteEmail}"; _messageIsError = false; _inviteEmail = "";
            }
            else { _inviteError = r.Message; }
        }
        catch (Exception ex) { _inviteError = ex.Message; }
        finally { _isInviting = false; StateHasChanged(); }
    }

    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
