@page "/register"
@using FeladatRadar.frontend.Models
@using FeladatRadar.frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer
<PageTitle>Regisztráció — FeladatRadar</PageTitle>

<div class="register-page">
    <div class="register-left">
        <a href="/" class="register-brand">
            <div class="register-brand-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            FeladatRadar
        </a>
        <div class="register-card">
            <div class="register-header">
                <h1>Hozz létre fiókot</h1>
                <p>30 másodperc és máris kezdhetsz</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="reg-alert reg-alert-error">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <span>@errorMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="reg-alert reg-alert-success">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>@successMessage</span>
                </div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister" class="register-form">
                <DataAnnotationsValidator />

                <div class="form-row">
                    <div class="form-group">
                        <label>Keresztnév <span class="required">*</span></label>
                        <InputText class="form-input" @bind-Value="registerModel.FirstName" placeholder="János" />
                        <ValidationMessage For="@(() => registerModel.FirstName)" class="validation-error" />
                    </div>
                    <div class="form-group">
                        <label>Vezetéknév <span class="required">*</span></label>
                        <InputText class="form-input" @bind-Value="registerModel.LastName" placeholder="Kovács" />
                        <ValidationMessage For="@(() => registerModel.LastName)" class="validation-error" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Felhasználónév <span class="required">*</span></label>
                    <InputText class="form-input" @bind-Value="registerModel.Username" placeholder="kovacs.janos" />
                    <ValidationMessage For="@(() => registerModel.Username)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Email cím <span class="required">*</span></label>
                    <InputText type="email" class="form-input" @bind-Value="registerModel.Email" placeholder="pelda@email.com" />
                    <ValidationMessage For="@(() => registerModel.Email)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Szerepkör <span class="required">*</span></label>
                    <div class="role-selector">
                        <button type="button" class="role-card @(registerModel.UserRole == "Student" ? "role-active" : "")"
                                @onclick='() => registerModel.UserRole = "Student"'>
                            <span class="role-icon">🎒</span>
                            <span class="role-name">Diák</span>
                            <span class="role-desc">Feladatok, naptár, fókusz időzítő</span>
                        </button>
                        <button type="button" class="role-card @(registerModel.UserRole == "Teacher" ? "role-active" : "")"
                                @onclick='() => registerModel.UserRole = "Teacher"'>
                            <span class="role-icon">👨‍🏫</span>
                            <span class="role-name">Tanár</span>
                            <span class="role-desc">Feladatkiadás, csoportkezelés</span>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.UserRole)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Jelszó <span class="required">*</span></label>
                    <div class="password-wrapper">
                        <InputText type="@passwordInputType" class="form-input" @bind-Value="registerModel.Password" placeholder="Min. 8 karakter" @oninput="CheckPassword" />
                        <button type="button" class="toggle-password" @onclick="TogglePassword">
                            @if (showPassword)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.Password)" class="validation-error" />
                    @if (!string.IsNullOrEmpty(registerModel.Password))
                    {
                        <div class="password-strength">
                            <div class="strength-bar">
                                <div class="strength-fill strength-@passwordStrength"></div>
                            </div>
                            <div class="strength-checks">
                                <span class="check @(registerModel.Password.Length >= 8 ? "check-ok" : "check-fail")">
                                    @(registerModel.Password.Length >= 8 ? "✅" : "❌") Min. 8 kar.
                                </span>
                                <span class="check @(registerModel.Password.Any(char.IsUpper) ? "check-ok" : "check-fail")">
                                    @(registerModel.Password.Any(char.IsUpper) ? "✅" : "❌") Nagybetű
                                </span>
                                <span class="check @(registerModel.Password.Any(char.IsDigit) ? "check-ok" : "check-fail")">
                                    @(registerModel.Password.Any(char.IsDigit) ? "✅" : "❌") Szám
                                </span>
                            </div>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label>Jelszó megerősítése <span class="required">*</span></label>
                    <div class="password-wrapper">
                        <InputText type="@confirmPasswordInputType" class="form-input" @bind-Value="registerModel.ConfirmPassword" placeholder="Jelszó újra" />
                        <button type="button" class="toggle-password" @onclick="ToggleConfirmPassword">
                            @if (showConfirmPassword)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="validation-error" />
                    @if (!string.IsNullOrEmpty(registerModel.ConfirmPassword))
                    {
                        @if (registerModel.Password == registerModel.ConfirmPassword)
                        {
                            <div class="password-match success">✅ A jelszavak egyeznek</div>
                        }
                        else
                        {
                            <div class="password-match error">❌ A jelszavak nem egyeznek</div>
                        }
                    }
                </div>

                <button type="submit" class="register-submit" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="register-spinner"></span>
                        <span>Regisztráció...</span>
                    }
                    else
                    {
                        <span>Fiók létrehozása</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    }
                </button>
            </EditForm>

            <div class="register-footer">
                Már van fiókod? <a href="/login">Jelentkezz be</a>
            </div>
        </div>
    </div>

    <div class="register-right">
        <div class="register-right-bg">
            <div class="rr-blob rr-blob-1"></div>
            <div class="rr-blob rr-blob-2"></div>
            <div class="rr-grid"></div>
        </div>
        <div class="register-right-inner">
            <div class="rr-badge">
                <span class="rr-badge-dot"></span>
                Diákoknak és tanároknak
            </div>
            <p class="register-quote">„Rendszerezd a napjaidat, és a tanulás egyszerűbbé válik."</p>
            <div class="register-features">
                <div class="register-feat">
                    <div class="feat-icon-box feat-purple">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    </div>
                    Feladatok és határidők egy helyen
                </div>
                <div class="register-feat">
                    <div class="feat-icon-box feat-amber">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    Beépített Pomodoro fókuszidőzítő
                </div>
                <div class="register-feat">
                    <div class="feat-icon-box feat-green">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    </div>
                    Csoportmunka és megosztott feladatok
                </div>
                <div class="register-feat">
                    <div class="feat-icon-box feat-blue">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    Heti és havi naptárnézet
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private string passwordInputType = "password";
    private string confirmPasswordInputType = "password";
    private string passwordStrength = "weak";

    private void TogglePassword()
    {
        showPassword = !showPassword;
        passwordInputType = showPassword ? "text" : "password";
    }

    private void ToggleConfirmPassword()
    {
        showConfirmPassword = !showConfirmPassword;
        confirmPasswordInputType = showConfirmPassword ? "text" : "password";
    }

    private void CheckPassword(ChangeEventArgs e)
    {
        var pwd = e.Value?.ToString() ?? "";
        int strength = 0;
        if (pwd.Length >= 8) strength++;
        if (pwd.Any(char.IsUpper)) strength++;
        if (pwd.Any(char.IsDigit)) strength++;
        if (pwd.Any(char.IsSymbol) || pwd.Any(char.IsPunctuation)) strength++;
        passwordStrength = strength switch
        {
            0 or 1 => "weak",
            2 => "medium",
            3 => "good",
            4 => "strong",
            _ => "weak"
        };
    }

    private async Task HandleRegister()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
        isLoading = true;
        try
        {
            var response = await AuthService.Register(registerModel);
            if (response != null && response.Status == "SUCCESS")
            {
                successMessage = "Sikeres regisztráció! Átirányítás a bejelentkezési oldalra...";
                await Task.Delay(1500);
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                errorMessage = response?.Message ?? "Ismeretlen hiba történt!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Hiba történt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}


<style>
    /* Regisztrációs oldal stílusok - következő commitban */
    .register-page { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; font-family: 'Segoe UI', system-ui, sans-serif; }
    .register-left { display: flex; flex-direction: column; padding: 2.5rem 5vw; }
    .register-right { display: none; }
</style>