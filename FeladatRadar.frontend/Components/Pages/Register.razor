@page "/register"
@using FeladatRadar.frontend.Models
@using FeladatRadar.frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer
<PageTitle>Regisztráció — FeladatRadar</PageTitle>

<div class="register-page">
    <div class="register-left">
        <a href="/" class="register-brand">
            <div class="register-brand-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            FeladatRadar
        </a>
        <div class="register-card">
            <div class="register-header">
                <h1>Hozz létre fiókot</h1>
                
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="reg-alert reg-alert-error">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <span>@errorMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="reg-alert reg-alert-success">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>@successMessage</span>
                </div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister" class="register-form">
                <DataAnnotationsValidator />

                <div class="form-row">
                    <div class="form-group">
                        <label>Keresztnév <span class="required">*</span></label>
                        <InputText class="form-input" @bind-Value="registerModel.FirstName" placeholder="János" />
                        <ValidationMessage For="@(() => registerModel.FirstName)" class="validation-error" />
                    </div>
                    <div class="form-group">
                        <label>Vezetéknév <span class="required">*</span></label>
                        <InputText class="form-input" @bind-Value="registerModel.LastName" placeholder="Kovács" />
                        <ValidationMessage For="@(() => registerModel.LastName)" class="validation-error" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Felhasználónév <span class="required">*</span></label>
                    <InputText class="form-input" @bind-Value="registerModel.Username" placeholder="kovacs.janos" />
                    <ValidationMessage For="@(() => registerModel.Username)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Email cím <span class="required">*</span></label>
                    <InputText type="email" class="form-input" @bind-Value="registerModel.Email" placeholder="pelda@email.com" />
                    <ValidationMessage For="@(() => registerModel.Email)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Szerepkör <span class="required">*</span></label>
                    <div class="role-selector">
                        <button type="button" class="role-card @(registerModel.UserRole == "Student" ? "role-active" : "")"
                                @onclick='() => registerModel.UserRole = "Student"'>
                            <span class="role-icon">🎒</span>
                            <span class="role-name">Diák</span>
                            <span class="role-desc">Feladatok, naptár, fókusz időzítő</span>
                        </button>
                        <button type="button" class="role-card @(registerModel.UserRole == "Teacher" ? "role-active" : "")"
                                @onclick='() => registerModel.UserRole = "Teacher"'>
                            <span class="role-icon">👨‍🏫</span>
                            <span class="role-name">Tanár</span>
                            <span class="role-desc">Feladatkiadás, csoportkezelés</span>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.UserRole)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Jelszó <span class="required">*</span></label>
                    <div class="password-wrapper">
                        <InputText type="@passwordInputType" class="form-input" @bind-Value="registerModel.Password" placeholder="Min. 8 karakter" @oninput="CheckPassword" />
                        <button type="button" class="toggle-password" @onclick="TogglePassword">
                            @if (showPassword)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.Password)" class="validation-error" />
                    @if (!string.IsNullOrEmpty(registerModel.Password))
                    {
                        <div class="password-strength">
                            <div class="strength-bar">
                                <div class="strength-fill strength-@passwordStrength"></div>
                            </div>
                            <div class="strength-checks">
                                <span class="check @(registerModel.Password.Length >= 8 ? "check-ok" : "check-fail")">
                                    @(registerModel.Password.Length >= 8 ? "✅" : "❌") Min. 8 kar.
                                </span>
                                <span class="check @(registerModel.Password.Any(char.IsUpper) ? "check-ok" : "check-fail")">
                                    @(registerModel.Password.Any(char.IsUpper) ? "✅" : "❌") Nagybetű
                                </span>
                                <span class="check @(registerModel.Password.Any(char.IsDigit) ? "check-ok" : "check-fail")">
                                    @(registerModel.Password.Any(char.IsDigit) ? "✅" : "❌") Szám
                                </span>
                            </div>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label>Jelszó megerősítése <span class="required">*</span></label>
                    <div class="password-wrapper">
                        <InputText type="@confirmPasswordInputType" class="form-input" @bind-Value="registerModel.ConfirmPassword" placeholder="Jelszó újra" />
                        <button type="button" class="toggle-password" @onclick="ToggleConfirmPassword">
                            @if (showConfirmPassword)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="validation-error" />
                    @if (!string.IsNullOrEmpty(registerModel.ConfirmPassword))
                    {
                        @if (registerModel.Password == registerModel.ConfirmPassword)
                        {
                            <div class="password-match success">✅ A jelszavak egyeznek</div>
                        }
                        else
                        {
                            <div class="password-match error">❌ A jelszavak nem egyeznek</div>
                        }
                    }
                </div>

                <button type="submit" class="register-submit" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="register-spinner"></span>
                        <span>Regisztráció...</span>
                    }
                    else
                    {
                        <span>Fiók létrehozása</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    }
                </button>
            </EditForm>

            <div class="register-footer">
                Már van fiókod? <a href="/login">Jelentkezz be</a>
            </div>
        </div>
    </div>

    <div class="register-right">
        <div class="register-right-bg">
            <div class="rr-blob rr-blob-1"></div>
            <div class="rr-blob rr-blob-2"></div>
            <div class="rr-grid"></div>
        </div>
        <div class="register-right-inner">
            
            <p class="register-quote">„Rendszerezd a napjaidat, és a tanulás egyszerűbbé válik."</p>
            <div class="register-features">
                <div class="register-feat">
                    <div class="feat-icon-box feat-purple">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    </div>
                    Feladatok és határidők egy helyen
                </div>
                <div class="register-feat">
                    <div class="feat-icon-box feat-amber">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    Beépített fókuszidőzítő
                </div>
                <div class="register-feat">
                    <div class="feat-icon-box feat-green">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    </div>
                    Csoportmunka és megosztott feladatok
                </div>
                <div class="register-feat">
                    <div class="feat-icon-box feat-blue">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    Heti és havi naptárnézet
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private string passwordInputType = "password";
    private string confirmPasswordInputType = "password";
    private string passwordStrength = "weak";

    private void TogglePassword()
    {
        showPassword = !showPassword;
        passwordInputType = showPassword ? "text" : "password";
    }

    private void ToggleConfirmPassword()
    {
        showConfirmPassword = !showConfirmPassword;
        confirmPasswordInputType = showConfirmPassword ? "text" : "password";
    }

    private void CheckPassword(ChangeEventArgs e)
    {
        var pwd = e.Value?.ToString() ?? "";
        int strength = 0;
        if (pwd.Length >= 8) strength++;
        if (pwd.Any(char.IsUpper)) strength++;
        if (pwd.Any(char.IsDigit)) strength++;
        if (pwd.Any(char.IsSymbol) || pwd.Any(char.IsPunctuation)) strength++;
        passwordStrength = strength switch
        {
            0 or 1 => "weak",
            2 => "medium",
            3 => "good",
            4 => "strong",
            _ => "weak"
        };
    }

    private async Task HandleRegister()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
        isLoading = true;
        try
        {
            var response = await AuthService.Register(registerModel);
            if (response != null && response.Status == "SUCCESS")
            {
                successMessage = "Sikeres regisztráció! Átirányítás a bejelentkezési oldalra...";
                await Task.Delay(1500);
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                errorMessage = response?.Message ?? "Ismeretlen hiba történt!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Hiba történt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --accent: #6d28d9;
        --accent-hover: #5b21b6;
        --accent-sub: rgba(109,40,217,.09);
        --amber: #d97706;
        --border: rgba(109,40,217,.14);
        --text: #1e1b4b;
        --text-2: #4a4080;
        --text-muted: #9284c2;
        --danger: #e53935;
        --danger-sub: rgba(229,57,53,.08);
        --success: #0e9f6e;
        --success-sub: rgba(14,159,110,.09);
        --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .register-page {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
        font-family: var(--font);
    }

    
    .register-left {
        display: flex; flex-direction: column;
        padding: 2.5rem 5vw;
        background: linear-gradient(160deg, #f8f4ff 0%, #fffdf5 100%);
        overflow-y: auto;
    }
    .register-brand {
        display: inline-flex; align-items: center; gap: 10px;
        font-weight: 700; font-size: .95rem; color: var(--text);
        text-decoration: none; margin-bottom: 1.5rem;
        letter-spacing: -.02em;
    }
    .register-brand-icon {
        width: 32px; height: 32px; border-radius: 8px;
        background: rgba(109,40,217,.1); border: 1px solid rgba(109,40,217,.2);
        display: flex; align-items: center; justify-content: center;
        color: var(--accent); flex-shrink: 0;
    }

    .register-card {
        width: 100%; max-width: 440px;
        margin: auto;
        padding: 1.5rem 0 3rem;
        display: flex; flex-direction: column; gap: 1.4rem;
    }

    .register-header h1 {
        font-size: 2rem; font-weight: 800;
        color: var(--text); letter-spacing: -.03em;
        margin-bottom: .35rem;
    }
    .register-header p { font-size: .9rem; color: var(--text-muted); }

    .reg-alert {
        display: flex; align-items: center; gap: 9px;
        padding: 11px 14px; border-radius: 10px;
        font-size: .85rem; font-weight: 500;
    }
    .reg-alert-error  { background: var(--danger-sub);  color: var(--danger);  border: 1px solid rgba(229,57,53,.18); }
    .reg-alert-success { background: var(--success-sub); color: var(--success); border: 1px solid rgba(14,159,110,.2); }

    .register-form { display: flex; flex-direction: column; gap: 1rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }

    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label { font-size: .8rem; font-weight: 600; color: var(--text-2); }

    .form-input {
        padding: 11px 14px;
        border: 1.5px solid var(--border); border-radius: 10px;
        background: #fff; color: var(--text);
        font-size: .9rem; font-family: var(--font);
        outline: none; transition: border-color .15s, box-shadow .15s; width: 100%;
    }
    .form-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-sub); }

    .required { color: var(--danger); }
    .validation-error { font-size: .78rem; color: var(--danger); margin-top: 2px; }

   
    .role-selector { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
    .role-card {
        display: flex; flex-direction: column; align-items: center; gap: 7px;
        padding: 16px 12px; border: 1.5px solid var(--border); border-radius: 12px;
        cursor: pointer; transition: all .18s; background: #fff;
        font-family: var(--font);
    }
    .role-card:hover { border-color: var(--accent); background: var(--accent-sub); }
    .role-card.role-active {
        border-color: var(--accent); background: var(--accent-sub);
        box-shadow: 0 0 0 3px rgba(109,40,217,.1);
    }
    .role-card:nth-child(2):hover { border-color: var(--amber); background: rgba(217,119,6,.08); }
    .role-card:nth-child(2).role-active { border-color: var(--amber); background: rgba(217,119,6,.08); box-shadow: 0 0 0 3px rgba(217,119,6,.1); }
    .role-icon { font-size: 1.6rem; }
    .role-name { font-size: .85rem; font-weight: 700; color: var(--text); }
    .role-desc { font-size: .72rem; color: var(--text-muted); text-align: center; line-height: 1.4; }

    
    .password-wrapper { position: relative; }
    .toggle-password {
        position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
        background: none; border: none; cursor: pointer;
        color: var(--text-muted); padding: 2px;
        display: flex; align-items: center;
        transition: color .15s;
    }
    .toggle-password:hover { color: var(--accent); }
    .password-strength { margin-top: 8px; display: flex; flex-direction: column; gap: 6px; }
    .strength-bar { height: 4px; background: rgba(109,40,217,.1); border-radius: 2px; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 2px; transition: width .3s; }
    .strength-weak   { width: 33%; background: var(--danger); }
    .strength-medium { width: 66%; background: var(--amber); }
    .strength-good   { width: 83%; background: #84cc16; }
    .strength-strong { width: 100%; background: var(--success); }
    .strength-checks { display: flex; gap: 12px; flex-wrap: wrap; }
    .check { font-size: .72rem; color: var(--text-muted); }
    .check-ok { color: var(--success); }
    .check-fail { color: var(--danger); }
    .password-match { font-size: .78rem; margin-top: 4px; }
    .password-match.success { color: var(--success); }
    .password-match.error { color: var(--danger); }

    .register-submit {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        width: 100%; padding: 13px;
        background: linear-gradient(135deg, #6d28d9 0%, #9333ea 100%);
        color: #fff; border: none; border-radius: 10px;
        font-size: .9rem; font-weight: 600; cursor: pointer;
        transition: all .15s; font-family: var(--font);
        box-shadow: 0 4px 16px rgba(109,40,217,.3);
        margin-top: .3rem;
    }
    .register-submit:hover:not(:disabled) { box-shadow: 0 6px 20px rgba(109,40,217,.4); transform: translateY(-1px); }
    .register-submit:disabled { opacity: .65; cursor: not-allowed; }

    .register-spinner {
        width: 16px; height: 16px;
        border: 2.5px solid rgba(255,255,255,.3);
        border-top-color: #fff; border-radius: 50%;
        animation: spin .7s linear infinite; flex-shrink: 0;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .register-footer {
        text-align: center; font-size: .85rem; color: var(--text-muted);
        padding-top: .75rem; border-top: 1px solid rgba(109,40,217,.1);
    }
    .register-footer a { color: var(--accent); font-weight: 600; text-decoration: none; }
    .register-footer a:hover { text-decoration: underline; }

    
    .register-right {
        position: relative; overflow: hidden;
        background: linear-gradient(135deg, #f0ebff 0%, #fffbeb 100%);
        display: flex; align-items: center; justify-content: center;
        padding: 4rem 6vw;
        position: sticky; top: 0; height: 100vh;
    }
    .register-right-bg { position: absolute; inset: 0; z-index: 0; }
    .rr-blob {
        position: absolute; border-radius: 50%;
        filter: blur(80px); opacity: .45;
    }
    .rr-blob-1 {
        width: 500px; height: 500px;
        background: radial-gradient(circle, #a78bfa, transparent);
        top: -150px; left: -100px;
    }
    .rr-blob-2 {
        width: 380px; height: 380px;
        background: radial-gradient(circle, #fcd34d, transparent);
        bottom: -80px; right: -60px;
    }
    .rr-grid {
        position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(109,40,217,.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(109,40,217,.05) 1px, transparent 1px);
        background-size: 50px 50px;
    }
    .register-right-inner {
        position: relative; z-index: 1;
        max-width: 360px; display: flex; flex-direction: column; gap: 2.2rem;
    }
    .rr-badge {
        display: inline-flex; align-items: center; gap: 8px;
        background: rgba(109,40,217,.1); border: 1px solid rgba(109,40,217,.2);
        padding: 6px 14px; border-radius: 50px;
        font-size: .78rem; font-weight: 600; color: var(--accent);
        width: fit-content;
    }
    .rr-badge-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: var(--amber); box-shadow: 0 0 8px rgba(217,119,6,.5);
        animation: pulse-dot 2s infinite;
    }
    @@keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.35} }

    .register-quote {
        font-size: 1.25rem; font-weight: 700; color: #1e1b4b;
        line-height: 1.6; letter-spacing: -.02em;
    }
    .register-features { display: flex; flex-direction: column; gap: 14px; }
    .register-feat {
        display: flex; align-items: center; gap: 12px;
        font-size: .875rem; color: #5b5285; font-weight: 500;
    }
    .feat-icon-box {
        width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
    }
    .feat-purple { background: rgba(109,40,217,.12); color: var(--accent); }
    .feat-amber  { background: rgba(217,119,6,.12);  color: var(--amber); }
    .feat-green  { background: rgba(14,159,110,.12); color: #0e9f6e; }
    .feat-blue   { background: rgba(37,99,235,.12);  color: #2563eb; }

    @@media (max-width: 768px) {
        .register-page { grid-template-columns: 1fr; }
        .register-right { display: none; }
        .register-left { padding: 1.5rem; }
        .form-row { grid-template-columns: 1fr; }
    }
</style>