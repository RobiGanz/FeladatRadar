@page "/register"
@using FeladatRadar.frontend.Models
@using FeladatRadar.frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer
<PageTitle>Regisztráció - FeladatRadar</PageTitle>

<div class="register-page">
    <div class="register-container">
        <div class="register-header">
            <div class="header-icon">✨</div>
            <h1>Regisztráció</h1>
            <p>Hozd létre a fiókodat és kezdj el tanulni!</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">
                <span class="alert-icon">❌</span>
                <span>@errorMessage</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">
                <span class="alert-icon">✅</span>
                <span>@successMessage</span>
            </div>
        }

        <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister" class="register-form">
            <DataAnnotationsValidator />

            <div class="form-row">
                <div class="form-group">
                    <label>Keresztnév <span class="required">*</span></label>
                    <InputText class="form-input" @bind-Value="registerModel.FirstName" placeholder="János" />
                    <ValidationMessage For="@(() => registerModel.FirstName)" class="validation-error" />
                </div>

                <div class="form-group">
                    <label>Vezetéknév <span class="required">*</span></label>
                    <InputText class="form-input" @bind-Value="registerModel.LastName" placeholder="Kovács" />
                    <ValidationMessage For="@(() => registerModel.LastName)" class="validation-error" />
                </div>
            </div>

            <div class="form-group">
                <label>Felhasználónév <span class="required">*</span></label>
                <InputText class="form-input" @bind-Value="registerModel.Username" placeholder="kovacs.janos" />
                <ValidationMessage For="@(() => registerModel.Username)" class="validation-error" />
            </div>

            <div class="form-group">
                <label>Email cím <span class="required">*</span></label>
                <InputText type="email" class="form-input" @bind-Value="registerModel.Email" placeholder="pelda@email.com" />
                <ValidationMessage For="@(() => registerModel.Email)" class="validation-error" />
            </div>

            <div class="form-group">
                <label>Szerepkör <span class="required">*</span></label>
                <InputSelect class="form-input" @bind-Value="registerModel.UserRole">
                    <option value="Student">🎒 Diák</option>
                    <option value="Teacher">👨‍🏫 Tanár</option>
                </InputSelect>
                <ValidationMessage For="@(() => registerModel.UserRole)" class="validation-error" />
            </div>

            <div class="form-group">
                <label>Jelszó <span class="required">*</span></label>
                <div class="password-wrapper">
                    <InputText type="@passwordInputType" class="form-input" @bind-Value="registerModel.Password" placeholder="Min. 8 karakter" @oninput="CheckPassword" />
                    <button type="button" class="toggle-password" @onclick="TogglePassword">
                        @if (showPassword)
                        {
                            <span>🙈</span>
                        }
                        else
                        {

                            <span>👁️</span>
                        }
                    </button>
                </div>
                <ValidationMessage For="@(() => registerModel.Password)" class="validation-error" />

                <!-- Password Strength Indicator -->
                @if (!string.IsNullOrEmpty(registerModel.Password))
                {
                    <div class="password-strength">
                        <div class="strength-bar">
                            <div class="strength-fill strength-@passwordStrength"></div>
                        </div>
                        <div class="strength-checks">
                            <span class="check @(registerModel.Password.Length >= 8 ? "check-ok" : "check-fail")">
                                @(registerModel.Password.Length >= 8 ? "✅" : "❌") Min. 8 karakter
                            </span>
                            <span class="check @(registerModel.Password.Any(char.IsUpper) ? "check-ok" : "check-fail")">
                                @(registerModel.Password.Any(char.IsUpper) ? "✅" : "❌") Nagybetű
                            </span>
                            <span class="check @(registerModel.Password.Any(char.IsDigit) ? "check-ok" : "check-fail")">
                                @(registerModel.Password.Any(char.IsDigit) ? "✅" : "❌") Szám
                            </span>
                        </div>
                    </div>
                }
            </div>

            <!-- ÚJ: Jelszó megerősítése -->
            <div class="form-group">
                <label>Jelszó megerősítése <span class="required">*</span></label>
                <div class="password-wrapper">
                    <InputText type="@confirmPasswordInputType" class="form-input" @bind-Value="registerModel.ConfirmPassword" placeholder="Jelszó újra" />
                    <button type="button" class="toggle-password" @onclick="ToggleConfirmPassword">
                        @if (showConfirmPassword)
                        {
                            <span>🙈</span>
                        }
                        else
                        {

                            <span>👁️</span>
                        }
                    </button>
                </div>
                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="validation-error" />

                @if (!string.IsNullOrEmpty(registerModel.ConfirmPassword))
                {
                    @if (registerModel.Password == registerModel.ConfirmPassword)
                    {
                        <div class="password-match success">
                            ✅ A jelszavak egyeznek
                        </div>
                    }
                    else
                    {
                        <div class="password-match error">
                            ❌ A jelszavak nem egyeznek
                        </div>
                    }
                }
            </div>

            <button type="submit" class="btn-submit" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Regisztráció...</span>
                }
                else
                {
                    <span>Regisztráció</span>
                }
            </button>
        </EditForm>

        <div class="register-footer">
            <p>Már van fiókod? <a href="/login">Jelentkezz be itt</a></p>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private string passwordInputType = "password";
    private string confirmPasswordInputType = "password";
    private string passwordStrength = "weak";

    private void TogglePassword()
    {
        showPassword = !showPassword;
        passwordInputType = showPassword ? "text" : "password";
    }

    private void ToggleConfirmPassword()
    {
        showConfirmPassword = !showConfirmPassword;
        confirmPasswordInputType = showConfirmPassword ? "text" : "password";
    }

    private void CheckPassword(ChangeEventArgs e)
    {
        var pwd = e.Value?.ToString() ?? "";
        int strength = 0;

        if (pwd.Length >= 8) strength++;
        if (pwd.Any(char.IsUpper)) strength++;
        if (pwd.Any(char.IsDigit)) strength++;
        if (pwd.Any(char.IsSymbol) || pwd.Any(char.IsPunctuation)) strength++;

        passwordStrength = strength switch
        {
            0 or 1 => "weak",
            2 => "medium",
            3 => "good",
            4 => "strong",
            _ => "weak"
        };
    }

    private async Task HandleRegister()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
        isLoading = true;

        try
        {
            var response = await AuthService.Register(registerModel);

            if (response != null && response.Status == "SUCCESS")
            {
                successMessage = "Sikeres regisztráció! Átirányítás a bejelentkezési oldalra...";
                await Task.Delay(1500);
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                errorMessage = response?.Message ?? "Ismeretlen hiba történt!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Hiba történt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .register-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
    }

    .register-container {
        background: white;
        border-radius: 20px;
        padding: 3rem;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        max-height: 90vh;
        overflow-y: auto;
    }

    .register-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .header-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .register-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 0.5rem;
    }

    .register-header p {
        color: #718096;
        font-size: 1.1rem;
    }

    .required {
        color: #e53e3e;
    }

    .alert {
        padding: 1rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .alert-error {
        background: #fee;
        color: #c53030;
        border: 1px solid #feb2b2;
    }

    .alert-success {
        background: #f0fff4;
        color: #276749;
        border: 1px solid #9ae6b4;
    }

    .alert-icon {
        font-size: 1.5rem;
    }

    .register-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

        .form-group label {
            font-weight: 600;
            color: #2d3748;
            font-size: 0.95rem;
        }

    .form-input {
        padding: 0.875rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
        width: 100%;
    }

        .form-input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

    /* Validation Error Styling */
    .validation-error {
        color: #e53e3e;
        font-size: 0.85rem;
        margin-top: 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

        .validation-error::before {
            content: "⚠️";
            font-size: 0.8rem;
        }

    /* Password Wrapper */
    .password-wrapper {
        position: relative;
    }

    .toggle-password {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0;
    }

    /* Password Strength */
    .password-strength {
        margin-top: 0.5rem;
    }

    .strength-bar {
        height: 6px;
        background: #e2e8f0;
        border-radius: 3px;
        margin-bottom: 0.5rem;
        overflow: hidden;
    }

    .strength-fill {
        height: 100%;
        border-radius: 3px;
        transition: all 0.3s ease;
    }

    .strength-weak {
        width: 25%;
        background: #e53e3e;
    }

    .strength-medium {
        width: 50%;
        background: #f6ad55;
    }

    .strength-good {
        width: 75%;
        background: #68d391;
    }

    .strength-strong {
        width: 100%;
        background: #38a169;
    }

    .strength-checks {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .check {
        font-size: 0.8rem;
    }

    .check-ok {
        color: #38a169;
    }

    .check-fail {
        color: #e53e3e;
    }

    /* Password Match Indicator */
    .password-match {
        margin-top: 0.5rem;
        padding: 0.5rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
    }

        .password-match.success {
            background: #f0fff4;
            color: #38a169;
            border: 1px solid #9ae6b4;
        }

        .password-match.error {
            background: #fee;
            color: #e53e3e;
            border: 1px solid #feb2b2;
        }

    .btn-submit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        border: none;
        border-radius: 10px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

        .btn-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-submit:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .register-footer {
        text-align: center;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid #e2e8f0;
    }

        .register-footer p {
            color: #718096;
        }

        .register-footer a {
            color: #667eea;
            font-weight: 600;
            text-decoration: none;
        }

            .register-footer a:hover {
                text-decoration: underline;
            }

    @@media (max-width: 768px) {
        .register-container {
            padding: 2rem;
        }

        .register-header h1 {
            font-size: 2rem;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .strength-checks {
            flex-direction: column;
            gap: 0.25rem;
        }
    }
</style>