@page "/feladatok"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject TaskService TaskService
@inject SubjectService SubjectService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable

<PageTitle>Feladatok — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (_isAuthenticated)
{
    <div class="@LayoutClass" data-theme="@_theme" data-role="@_userRole">
        @if (_menuOpen) { <div class="fr-sidebar-backdrop" @onclick="CloseMenu"></div> }
        <aside class="@SidebarClass">
                        <a href="/dashboard" class="fr-brand" @onclick="CloseMenu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <span>FeladatRadar</span>
            </a>
            <nav class="fr-nav">
                
                <a href="/naptar" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Naptár</a>
                <a href="/feladatok" class="fr-nav-item fr-active" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>Feladatok</a>
                <a href="/fokusz" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Fókusz Időzítő</a>
                <a href="/csoport" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Csoportok</a>
                            @if (_userRole == "Admin") { <a href="/admin" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>Admin</a> }
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark") { <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/></svg><span>Világos mód</span> }
                    else { <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg><span>Sötét mód</span> }
                </button>

            </div>
        </aside>

        <main class="fr-main">
            <header class="fr-topbar">
                <div class="fr-topbar-left">
                    <button class="fr-hamburger" @onclick="ToggleMenu" title="Menü">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                                        <span class="fr-page-title">Feladatok</span>
                    <span class="fr-breadcrumb">/ @FilteredTasks.Count() feladat</span>
                </div>
                <div class="fr-topbar-right">
                    <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showAdd = !_showAdd">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Új esemény
                    </button>
                </div>
            </header>

            <div class="fr-content">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="fr-alert @(_messageIsError ? "fr-alert-danger" : "fr-alert-success")">
                        @_message
                        <button class="fr-alert-close" @onclick='() => _message = ""'>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                }

                @if (_showAdd)
                {
                    <div class="fr-add-card">
                        <div class="fr-add-head">
                            <span class="fr-add-title">Új esemény hozzáadása</span>
                            <button class="fr-icon-btn" @onclick='() => _showAdd = false'>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                        <div class="fr-add-body">
                            <!-- Típus gyors választó -->
                            <div class="fr-type-picker">
                                @foreach (var et in _eventTypes)
                                {
                                    <button class="fr-type-pick-btn @(_newType == et.Key ? "fr-type-pick-active" : "")"
                                            style="--tc:@et.Color"
                                            @onclick="() => _newType = et.Key">
                                        <span class="fr-type-pick-emoji">@et.Emoji</span>
                                        <span>@et.Label</span>
                                    </button>
                                }
                            </div>
                            <!-- Tantárgy kártyák -->
                            <div class="fr-subject-section">
                                <label class="fr-label">Tantárgy / Kategória</label>
                                <div class="fr-subject-grid">
                                    <button class="fr-subject-card @(_newSubjectId == 0 ? "fr-subject-active" : "")"
                                            @onclick='() => _newSubjectId = 0'>
                                        <span class="fr-subject-icon">📌</span>
                                        <span class="fr-subject-name">Általános</span>
                                    </button>
                                    @foreach (var e in _enrollments)
                                    {
                                        var subj = e;
                                        <button class="fr-subject-card @(_newSubjectId == subj.SubjectID ? "fr-subject-active" : "")"
                                                @onclick="() => _newSubjectId = subj.SubjectID">
                                            <span class="fr-subject-code">@subj.SubjectCode</span>
                                            <span class="fr-subject-name">@subj.SubjectName</span>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="fr-form-row">
                                <div class="fr-field" style="flex:2;min-width:200px">
                                    <label class="fr-label">Esemény neve <span class="fr-required">*</span></label>
                                    <input class="fr-input" type="text" placeholder="@GetPlaceholder(_newType)" @bind="_newTitle" maxlength="200" />
                                </div>
                                <div class="fr-field fr-field-sm">
                                    <label class="fr-label">Határidő / Dátum <span class="fr-required">*</span></label>
                                    <input class="fr-input" type="datetime-local" @bind="_newDueDate" />
                                </div>
                                <div class="fr-field" style="flex:2;min-width:180px">
                                    <label class="fr-label">Megjegyzés <span class="fr-optional">— opcionális</span></label>
                                    <input class="fr-input" type="text" placeholder="Részletek, helyszín..." @bind="_newDescription" />
                                </div>
                                <button class="fr-btn fr-btn-primary fr-btn-sm" style="align-self:flex-end" @onclick="AddTask" disabled="@_isSaving">
                                    @(_isSaving ? "Mentés..." : "Hozzáadás")
                                </button>
                            </div>
                            <div class="fr-form-row-secondary">
                                <div class="fr-field fr-field-sm">
                                    <label class="fr-label">Ismétlődés</label>
                                    <select class="fr-input" @bind="_newRecurrence">
                                        <option value="None">Egyszeri</option>
                                        <option value="Weekly">Heti</option>
                                        <option value="Biweekly">Kéthetente</option>
                                        <option value="Monthly">Havonta</option>
                                    </select>
                                </div>
                                @if (_newRecurrence != "None")
                                {
                                    <div class="fr-field fr-field-sm">
                                        <label class="fr-label">
                                            <input type="checkbox" @bind="_newHasEndDate" style="margin-right:5px" />Vége dátum
                                        </label>
                                        @if (_newHasEndDate)
                                        {
                                            <input type="date" class="fr-input" @bind="_newRecurrenceEnd" />
                                        }
                                    </div>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_formError))
                            {
                                <p class="fr-form-error">@_formError</p>
                            }
                        </div>
                    </div>
                }

                <!-- Filter + search sor -->
                <div class="fr-filter-row">
                    <div class="fr-pills">
                        <button class="fr-pill @(_filter == "all" ? "fr-pill-on" : "")" @onclick='() => _filter = "all"'>
                            Összes <span class="fr-pill-n">@_tasks.Count</span>
                        </button>
                        <button class="fr-pill @(_filter == "active" ? "fr-pill-on" : "")" @onclick='() => _filter = "active"'>
                            Aktív <span class="fr-pill-n">@_tasks.Count(t => !t.IsCompleted && !t.IsOverdue)</span>
                        </button>
                        <button class="fr-pill fr-pill-warn @(_filter == "soon" ? "fr-pill-on" : "")" @onclick='() => _filter = "soon"'>
                            ⚡ Hamarosan <span class="fr-pill-n">@_tasks.Count(t => t.IsDueSoon)</span>
                        </button>
                        <button class="fr-pill fr-pill-danger @(_filter == "overdue" ? "fr-pill-on" : "")" @onclick='() => _filter = "overdue"'>
                            Lejárt <span class="fr-pill-n">@_tasks.Count(t => t.IsOverdue)</span>
                        </button>
                        <button class="fr-pill fr-pill-done @(_filter == "done" ? "fr-pill-on" : "")" @onclick='() => _filter = "done"'>
                            ✓ Kész <span class="fr-pill-n">@_tasks.Count(t => t.IsCompleted)</span>
                        </button>
                        <!-- Típus szűrők -->
                        @foreach (var et in _eventTypes.Where(e => _tasks.Any(t => t.TaskType == e.Key)))
                        {
                            <button class="fr-pill fr-pill-type @(_filter == et.Key ? "fr-pill-on" : "")"
                                    style="--tc:@et.Color"
                                    @onclick="() => _filter = et.Key">
                                @et.Emoji @et.Label
                                <span class="fr-pill-n">@_tasks.Count(t => t.TaskType == et.Key && !t.IsCompleted)</span>
                            </button>
                        }
                    </div>
                    <div class="fr-filter-right">
                        <div class="fr-search-box">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input class="fr-search-input" type="text" placeholder="Keresés..." @bind="_search" @bind:event="oninput" />
                        </div>
                        <select class="fr-sort-select" @bind="_sort">
                            <option value="due">Határidő szerint</option>
                            <option value="type">Típus szerint</option>
                            <option value="subject">Tantárgy szerint</option>
                            <option value="name">Név szerint</option>
                        </select>
                    </div>
                </div>

                <!-- Task list -->
                <div class="fr-panel">
                    @if (_isLoading)
                    {
                        <div class="fr-panel-empty"><div class="fr-spinner fr-spinner-sm"></div></div>
                    }
                    else if (!FilteredTasks.Any())
                    {
                        <div class="fr-panel-empty">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            <span>Nincs ide illő esemény.</span>
                        </div>
                    }
                    else
                    {
                        <table class="fr-table">
                            <thead>
                                <tr>
                                    <th style="width:36px"></th>
                                    <th>Esemény</th>
                                    <th>Kategória</th>
                                    <th>Típus</th>
                                    <th>Határidő</th>
                                    <th>Állapot</th>
                                    <th style="width:36px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in FilteredTasks)
                                {
                                    var isOverdue = task.IsOverdue;
                                    var isDone = task.IsCompleted;
                                    var et = _eventTypes.FirstOrDefault(e => e.Key == task.TaskType);
                                    <tr class="fr-task-tr @(isOverdue && !isDone ? "fr-tr-danger" : "") @(isDone ? "fr-tr-done" : "")">
                                        <td>
                                            <button class="fr-check @(isDone ? "fr-check-done" : "")" @onclick="() => ToggleComplete(task)" title="@(isDone ? "Visszavonás" : "Kész jelölés")">
                                                @if (isDone) { <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg> }
                                            </button>
                                        </td>
                                        <td>
                                            <div class="fr-task-cell">
                                                <span class="fr-task-title @(isDone ? "fr-done-text" : "")">@task.Title</span>
                                                @if (!string.IsNullOrEmpty(task.Description))
                                                {
                                                    <span class="fr-task-desc">@task.Description</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(task.SubjectCode))
                                            {
                                                <span class="fr-td-code">@task.SubjectCode</span>
                                            }
                                            <span class="fr-td-sub">@(string.IsNullOrEmpty(task.SubjectName) ? "—" : task.SubjectName)</span>
                                        </td>
                                        <td>
                                            <span class="fr-type-badge" style="--tc:@(et?.Color ?? "#9b948c")">
                                                @(et?.Emoji ?? "") @TranslateType(task.TaskType)
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fr-due @(isOverdue && !isDone ? "fr-due-danger" : task.IsDueSoon && !isDone ? "fr-due-warn" : "")">
                                                @task.DueDate.ToString("MM.dd HH:mm")
                                            </span>
                                            <span class="fr-days-left @(isOverdue && !isDone ? "fr-text-danger" : task.IsDueSoon && !isDone ? "fr-text-warn" : "fr-text-muted")">
                                                @task.DaysLeft
                                            </span>
                                        </td>
                                        <td>
                                            @if (isDone) { <span class="fr-badge fr-badge-done">Kész</span> }
                                            else if (isOverdue) { <span class="fr-badge fr-badge-danger">Lejárt</span> }
                                            else if (task.IsDueSoon) { <span class="fr-badge fr-badge-warn">Hamarosan</span> }
                                            else { <span class="fr-badge fr-badge-default">Folyamatban</span> }
                                        </td>
                                        <td>
                                            <button class="fr-del-btn" @onclick="() => DeleteTask(task.TaskID)" title="Törlés">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </main>
    </div>
}
else
{
    <div class="fr-unauth"><p>Nincs aktív munkamenet.</p><a href="/login" class="fr-btn fr-btn-primary">Bejelentkezés</a></div>
}

@code {
    private bool _menuOpen = false;
    private string SidebarClass => _menuOpen ? "fr-sidebar fr-sidebar-open" : "fr-sidebar";
    private string LayoutClass => _menuOpen ? "fr-layout fr-menu-open" : "fr-layout";
    private void ToggleMenu() { _menuOpen = !_menuOpen; StateHasChanged(); }
    private void CloseMenu() { _menuOpen = false; StateHasChanged(); }
    private bool _hasCheckedAuth, _isAuthenticated, _isLoading, _isSaving, _showAdd, _messageIsError;
    private string _userRole = "", _userEmail = "", _message = "", _formError = "";
    private string _filter = "all", _search = "", _sort = "due", _theme = "light";
    private string _newTitle = "", _newType = "Assignment", _newDescription = "";
    private string _newRecurrence = "None";
    private bool _newHasEndDate = false;
    private DateTime? _newRecurrenceEnd = null;
    private int _newSubjectId = 0;
    private DateTime _newDueDate = DateTime.Now.AddDays(7);
    private List<TaskDto> _tasks = new();
    private List<EnrollmentDto> _enrollments = new();
    private System.Threading.Timer? _uiTimer, _dataTimer;

    private record EventTypeInfo(string Key, string Emoji, string Label, string Color);
    private readonly List<EventTypeInfo> _eventTypes = new()
    {
        new("Assignment", "📝", "Beadandó",   "#4f46e5"),
        new("Homework",   "📚", "Házi",        "#7c3aed"),
        new("Exam",       "✍️", "Dolgozat",    "#e53935"),
        new("Vizsga",     "🎓", "Vizsga",      "#ea580c"),
        new("Project",    "💡", "Projekt",     "#d97706"),
        new("Verseny",    "🏆", "Verseny",     "#0891b2"),
        new("Sport",      "🏋️", "Sport",       "#0e9f6e"),
        new("Olvasas",    "📖", "Olvasás",     "#8b5cf6"),
        new("Kulturalis", "🎭", "Kulturális",  "#db2777"),
        new("Personal",   "⭐", "Személyes",   "#9b948c"),
        new("Other",      "⚡", "Egyéb",       "#64748b"),
    };

    private string TranslateType(string t) => _eventTypes.FirstOrDefault(e => e.Key == t)?.Label ?? t;
    private string GetPlaceholder(string t) => t switch
    {
        "Assignment" => "pl. Irodalom esszé beadandó",
        "Exam"       => "pl. Matematika ZH – deriválás",
        "Vizsga"     => "pl. Fizika záróvizsga",
        "Verseny"    => "pl. Országos matematikaverseny",
        "Sport"      => "pl. Edzés – konditerem",
        "Kulturalis" => "pl. Színházi előadás – Hamlet",
        "Personal"   => "pl. Fogorvos",
        _            => "pl. Megnevezés..."
    };

    private IEnumerable<TaskDto> FilteredTasks
    {
        get
        {
            var q = _tasks.AsEnumerable();
            q = _filter switch
            {
                "active"  => q.Where(t => !t.IsCompleted && !t.IsOverdue),
                "soon"    => q.Where(t => t.IsDueSoon && !t.IsCompleted),
                "overdue" => q.Where(t => t.IsOverdue),
                "done"    => q.Where(t => t.IsCompleted),
                _         => _eventTypes.Any(e => e.Key == _filter)
                             ? q.Where(t => t.TaskType == _filter && !t.IsCompleted)
                             : q
            };
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim().ToLower();
                q = q.Where(t => t.Title.ToLower().Contains(s) || (t.SubjectName?.ToLower().Contains(s) ?? false) || (t.Description?.ToLower().Contains(s) ?? false));
            }
            q = _sort switch
            {
                "type"    => q.OrderBy(t => t.TaskType).ThenBy(t => t.DueDate),
                "subject" => q.OrderBy(t => t.SubjectName).ThenBy(t => t.DueDate),
                "name"    => q.OrderBy(t => t.Title),
                _         => q.OrderBy(t => t.IsCompleted).ThenBy(t => t.DueDate)
            };
            return q;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        try { await AuthService.InitializeAsync(); } catch { }
        _hasCheckedAuth = true;
        _isAuthenticated = AuthService.IsAuthenticated;
        _userEmail = AuthService.CurrentUser?.Email ?? "";
        _userRole  = AuthService.CurrentUser?.UserRole ?? "";
        if (!_isAuthenticated) { Navigation.NavigateTo("/login"); return; }
        await LoadData();
        _uiTimer   = new System.Threading.Timer(_ => InvokeAsync(StateHasChanged), null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
        _dataTimer = new System.Threading.Timer(async _ => { if (!_isSaving) await InvokeAsync(LoadData); }, null, TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));
        StateHasChanged();
    }

    public void Dispose() { _uiTimer?.Dispose(); _dataTimer?.Dispose(); }

    private async Task LoadData()
    {
        _isLoading = true; StateHasChanged();
        try { _tasks = await TaskService.GetMyTasksAsync(); } catch { _tasks = new(); }
        try { _enrollments = await SubjectService.GetMyEnrollmentsAsync(); } catch { _enrollments = new(); }
        _isLoading = false;
    }

    private void OnSubjectChanged(ChangeEventArgs e) { if (int.TryParse(e.Value?.ToString(), out var id)) _newSubjectId = id; }

    private async Task AddTask()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_newTitle)) { _formError = "Add meg az esemény nevét."; return; }
        _isSaving = true; StateHasChanged();
        try
        {
            var r = await TaskService.AddTaskAsync(new AddTaskRequest
            {
                SubjectID   = _newSubjectId == 0 ? (int?)null : _newSubjectId,
                Title       = _newTitle.Trim(),
                Description = string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
                DueDate     = _newDueDate,
                TaskType    = _newType,
                RecurrenceType = _newRecurrence,
                RecurrenceEndDate = _newHasEndDate ? _newRecurrenceEnd : null
            });
            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                _message = $"Esemény hozzáadva: {_newTitle}"; _messageIsError = false;
                _newTitle = _newDescription = ""; _newSubjectId = 0; _newDueDate = DateTime.Now.AddDays(7); _newType = "Assignment"; _newRecurrence = "None"; _newHasEndDate = false; _newRecurrenceEnd = null; _showAdd = false;
                await LoadData();
            }
            else { _formError = r.Message; }
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _isSaving = false; StateHasChanged(); }
    }

    private async Task ToggleComplete(TaskDto task)
    {
        try
        {
            var r = task.IsCompleted ? await TaskService.UncompleteTaskAsync(task.TaskID) : await TaskService.CompleteTaskAsync(task.TaskID);
            if (r.Status == "OK" || r.Status == "SUCCESS") await LoadData();
            else { _message = r.Message; _messageIsError = true; }
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task DeleteTask(int id)
    {
        try
        {
            var r = await TaskService.DeleteTaskAsync(id);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Esemény törölve.";
            if (!_messageIsError) await LoadData();
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task ToggleTheme() { _theme = _theme == "dark" ? "light" : "dark"; await JS.InvokeVoidAsync("themeHelper.setTheme", _theme); StateHasChanged(); }
    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
}

