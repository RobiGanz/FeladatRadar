    /* Table */
    .fr-table { width:100%; border-collapse:collapse; }
    .fr-table thead tr { background:linear-gradient(135deg,rgba(102,126,234,.04),rgba(118,75,162,.04)); border-bottom:1.5px solid var(--border); }
    .fr-table th { padding:10px 14px; text-align:left; font-size:.75rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.04em; white-space:nowrap; }
    .fr-table td { padding:11px 14px; border-bottom:1px solid var(--border); vertical-align:middle; }
    .fr-table tbody tr:last-child td { border-bottom:none; }
    .fr-table tbody tr:hover { background:var(--surface-2); }
    .fr-task-tr { transition:background .1s; }
    .fr-tr-danger { background:var(--danger-subtle) !important; }
    .fr-tr-done td { opacity:.55; }

    /* Check button */
    .fr-check {
        width:22px; height:22px; border-radius:6px; border:2px solid var(--border);
        background:none; cursor:pointer; display:flex; align-items:center; justify-content:center;
        transition:all .15s; color:transparent;
    }
    .fr-check:hover { border-color:var(--success); background:var(--success-subtle); }
    .fr-check-done { background:var(--success); border-color:var(--success); color:#fff; }

    /* Task cell */
    .fr-task-cell { display:flex; flex-direction:column; gap:2px; }
    .fr-task-title { font-size:.875rem; font-weight:500; color:var(--text-primary); }
    .fr-done-text { text-decoration:line-through; color:var(--text-muted) !important; }
    .fr-task-desc { font-size:.75rem; color:var(--text-muted); }

    /* TD variants */
    .fr-td-code { display:block; font-size:.72rem; font-weight:700; color:var(--accent); }
    .fr-td-sub { display:block; font-size:.8rem; color:var(--text-secondary); }
    .fr-td-meta { font-size:.8rem; color:var(--text-secondary); }

    /* Type badge */
    .fr-type-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 9px; border-radius:12px; font-size:.73rem; font-weight:700; background:rgba(from var(--tc,#667eea) r g b /.12); color:var(--tc,var(--accent)); border:1px solid rgba(from var(--tc,#667eea) r g b /.25); }

    /* Due dates */
    .fr-due { display:block; font-size:.82rem; font-weight:500; color:var(--text-primary); }
    .fr-due-danger { color:var(--danger) !important; font-weight:700; }
    .fr-due-warn { color:var(--warning) !important; font-weight:600; }
    .fr-days-left { display:block; font-size:.73rem; }
    .fr-text-danger { color:var(--danger); }
    .fr-text-warn { color:var(--warning); }
    .fr-text-muted { color:var(--text-muted); }

    /* Badges */
    .fr-badge-done { background:var(--success-subtle); color:var(--success); }
    .fr-badge-danger { background:var(--danger-subtle); color:var(--danger); }
    .fr-badge-default { background:var(--surface-2); color:var(--text-muted); }

    /* Delete button */
    .fr-del-btn { width:28px; height:28px; border-radius:7px; border:none; background:none; color:var(--text-muted); cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .15s; }
    .fr-del-btn:hover { background:var(--danger-subtle); color:var(--danger); }

    /* Spinner small */
    .fr-spinner-sm { width:18px; height:18px; border-width:2px; }

/* ── Responsive breakpoints ── */
    @@media (max-width:900px) {
        .fr-table th:nth-child(4), .fr-table td:nth-child(4) { display:none; }
    }
    @@media (max-width:768px) {
        .fr-filter-row { flex-wrap:wrap; gap:8px; padding:10px 12px; }
        .fr-filter-right { width:100%; justify-content:space-between; }
        .fr-search-input { width:120px; }
        .fr-table th:nth-child(3), .fr-table td:nth-child(3) { display:none; }
        .fr-topbar-right { gap:6px; }
        .fr-content { padding:14px 16px; }
    }
    @@media (max-width:580px) {
        .fr-filter-row { flex-direction:column; align-items:stretch; gap:8px; }
        .fr-filter-right { justify-content:space-between; }
        .fr-search-input { width:100%; }
        .fr-type-picker { gap:4px; }
        .fr-type-pick-btn { font-size:.74rem; padding:5px 9px; }
        .fr-add-body { padding:12px; gap:10px; }
        .fr-subject-grid { gap:4px; }
        .fr-subject-card { padding:6px 10px; min-width:70px; }
        .fr-content { padding:10px 12px; }
    }
    @@media (max-width:480px) {
