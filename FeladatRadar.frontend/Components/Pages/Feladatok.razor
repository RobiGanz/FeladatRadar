@page "/feladatok"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject TaskService TaskService
@inject SubjectService SubjectService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable

<PageTitle>Feladatok — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (_isAuthenticated)
{
    <div class="fr-layout" data-theme="@_theme">
        <!-- Sidebar -->
        <aside class="fr-sidebar">
            <div class="fr-brand">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
                <span>FeladatRadar</span>
            </div>
            <nav class="fr-nav">
                <a href="/dashboard" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>Dashboard</a>
                <a href="/naptar" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Naptár</a>
                <a href="/feladatok" class="fr-nav-item fr-active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>Feladatok</a>
                <a href="/fokusz" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Csoportok</a>
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark")
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /></svg>
                        <span>Világos mód</span>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
                        <span>Sötét mód</span>
                    }
                </button>
                <button class="fr-logout" @onclick="HandleLogout">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    Kijelentkezés
                </button>
            </div>
        </aside>

        <!-- Main -->
        <main class="fr-main">
            <header class="fr-topbar">
                <div class="fr-topbar-left">
                    <span class="fr-page-title">Feladatok</span>
                    <span class="fr-breadcrumb">/ @FilteredTasks.Count() feladat</span>
                </div>
                <div class="fr-topbar-right">
                    <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => _showAdd = !_showAdd">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Új feladat
                    </button>
                    <div class="fr-user-chip">
                        <div class="fr-user-dot"></div>
                        <span>@_userEmail</span>
                    </div>
                </div>
            </header>

            <div class="fr-content">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="fr-alert @(_messageIsError ? "fr-alert-danger" : "fr-alert-success")">
                        @_message
                        <button class="fr-alert-close" @onclick='() => _message = ""'>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                        </button>
                    </div>
                }

                <!-- Add task form -->
                @if (_showAdd)
                {
                    <div class="fr-add-card">
                        <div class="fr-add-card-head">
                            <span class="fr-add-card-title">Új feladat hozzáadása</span>
                            <button class="fr-icon-btn" @onclick='() => _showAdd = false'>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            </button>
                        </div>
                        <div class="fr-add-card-body">
                            <div class="fr-form-row">
                                <div class="fr-field" style="flex:2;min-width:200px">
                                    <label class="fr-label">Feladat neve <span class="fr-required">*</span></label>
                                    <input class="fr-input" type="text" placeholder="pl. Beadandó dolgozat" @bind="_newTitle" maxlength="200" />
                                </div>
                                <div class="fr-field">
                                    <label class="fr-label">Tantárgy <span class="fr-required">*</span></label>
                                    <select class="fr-input" value="@_newSubjectId" @onchange="OnSubjectChanged">
                                        <option value="0">— Válassz —</option>
                                        @foreach (var e in _enrollments)
                                        {
                                            <option value="@e.SubjectID">@e.SubjectCode – @e.SubjectName</option>
                                        }
                                    </select>
                                </div>
                                <div class="fr-field fr-field-sm">
                                    <label class="fr-label">Típus</label>
                                    <select class="fr-input" @bind="_newType">
                                        <option value="Assignment">Beadandó</option>
                                        <option value="Homework">Házi feladat</option>
                                        <option value="Exam">Dolgozat / ZH</option>
                                        <option value="Vizsga">Vizsga</option>
                                        <option value="Project">Projekt</option>
                                        <option value="Personal">Egyéb</option>
                                    </select>
                                </div>
                                <div class="fr-field fr-field-sm">
                                    <label class="fr-label">Határidő <span class="fr-required">*</span></label>
                                    <input class="fr-input" type="datetime-local" @bind="_newDueDate" />
                                </div>
                                <div class="fr-field" style="flex:2;min-width:200px">
                                    <label class="fr-label">Megjegyzés <span class="fr-optional">— opcionális</span></label>
                                    <input class="fr-input" type="text" placeholder="Részletek..." @bind="_newDescription" />
                                </div>
                                <button class="fr-btn fr-btn-primary fr-btn-sm" style="align-self:flex-end" @onclick="AddTask" disabled="@_isSaving">
                                    @(_isSaving ? "Mentés..." : "Hozzáadás")
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(_formError))
                            {
                                <p class="fr-form-error">@_formError</p>
                            }
                        </div>
                    </div>
                }

                <!-- Stats row -->
                <div class="fr-stat-row">
                    @{
                        var pending = _tasks.Count(t => !t.IsCompleted && !t.IsOverdue);
                        var overdue = _tasks.Count(t => t.IsOverdue);
                        var dueSoon = _tasks.Count(t => t.IsDueSoon);
                        var done = _tasks.Count(t => t.IsCompleted);
                    }
                    <button class="fr-stat-pill @(_filter == "all" ? "fr-pill-active" : "")" @onclick='() => _filter = "all"'>
                        Összes <span class="fr-pill-num">@_tasks.Count</span>
                    </button>
                    <button class="fr-stat-pill @(_filter == "active" ? "fr-pill-active" : "")" @onclick='() => _filter = "active"'>
                        Aktív <span class="fr-pill-num">@pending</span>
                    </button>
                    <button class="fr-stat-pill fr-pill-warn @(_filter == "soon" ? "fr-pill-active" : "")" @onclick='() => _filter = "soon"'>
                        Hamarosan <span class="fr-pill-num">@dueSoon</span>
                    </button>
                    <button class="fr-stat-pill fr-pill-danger @(_filter == "overdue" ? "fr-pill-active" : "")" @onclick='() => _filter = "overdue"'>
                        Lejárt <span class="fr-pill-num">@overdue</span>
                    </button>
                    <button class="fr-stat-pill fr-pill-vizsga @(_filter == "vizsga" ? "fr-pill-active" : "")" @onclick='() => _filter = "vizsga"'>
                        🎓 Vizsgák <span class="fr-pill-num">@_tasks.Count(t => t.TaskType == "Vizsga" && !t.IsCompleted)</span>
                    </button>
                    <button class="fr-stat-pill fr-pill-done @(_filter == "done" ? "fr-pill-active" : "")" @onclick='() => _filter = "done"'>
                        Befejezett <span class="fr-pill-num">@done</span>
                    </button>
                    <div class="fr-spacer"></div>
                    <!-- Search -->
                    <div class="fr-search-box">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        <input class="fr-search-input" type="text" placeholder="Keresés..." @bind="_search" @bind:event="oninput" />
                    </div>
                    <!-- Sort -->
                    <select class="fr-sort-select" @bind="_sort">
                        <option value="due">Határidő szerint</option>
                        <option value="subject">Tantárgy szerint</option>
                        <option value="type">Típus szerint</option>
                        <option value="name">Név szerint</option>
                    </select>
                </div>

                <!-- Task list -->
                <div class="fr-panel">
                    @if (_isLoading)
                    {
                        <div class="fr-panel-empty"><div class="fr-spinner fr-spinner-sm"></div></div>
                    }
                    else if (!FilteredTasks.Any())
                    {
                        <div class="fr-panel-empty">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                            <span>Nincs megjeleníthető feladat.</span>
                        </div>
                    }
                    else
                    {
                        <table class="fr-table">
                            <thead>
                                <tr>
                                    <th style="width:36px"></th>
                                    <th>Feladat</th>
                                    <th>Tantárgy</th>
                                    <th>Típus</th>
                                    <th>Határidő</th>
                                    <th>Állapot</th>
                                    <th style="width:48px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in FilteredTasks)
                                {
                                    var isOverdue = task.IsOverdue;
                                    var isDone = task.IsCompleted;
                                    <tr class="fr-task-tr @(isOverdue ? "fr-tr-danger" : "") @(isDone ? "fr-tr-done" : "")">
                                        <td>
                                            <button class="fr-check @(isDone ? "fr-check-done" : "")"
                                                    @onclick="() => ToggleComplete(task)"
                                                    title="@(isDone ? "Visszavonás" : "Kész")">
                                                @if (isDone)
                                                {
                                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" /></svg>
                                                }
                                            </button>
                                        </td>
                                        <td>
                                            <div class="fr-task-name-cell">
                                                <span class="fr-task-title @(isDone ? "fr-strikethrough" : "")">@task.Title</span>
                                                @if (!string.IsNullOrEmpty(task.Description))
                                                {
                                                    <span class="fr-task-desc">@task.Description</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="fr-td-code">@task.SubjectCode</span>
                                            <span class="fr-td-sub">@task.SubjectName</span>
                                        </td>
                                        <td>
                                            <span class="fr-type-badge fr-type-@task.TaskType.ToLower()">@TranslateType(task.TaskType)</span>
                                        </td>
                                        <td>
                                            <span class="fr-due @(isOverdue ? "fr-due-danger" : task.IsDueSoon ? "fr-due-warn" : "")">
                                                @task.DueDate.ToString("yyyy.MM.dd HH:mm")
                                            </span>
                                            <span class="fr-days-left @(isOverdue ? "fr-text-danger" : task.IsDueSoon ? "fr-text-warn" : "fr-text-muted")">
                                                @task.DaysLeft
                                            </span>
                                        </td>
                                        <td>
                                            @if (isDone)
                                            {
                                                <span class="fr-badge fr-badge-success">Kész</span>
                                            }
                                            else if (isOverdue)
                                            {
                                                <span class="fr-badge fr-badge-danger">Lejárt</span>
                                            }
                                            else if (task.IsDueSoon)
                                            {
                                                <span class="fr-badge fr-badge-warn">Hamarosan</span>
                                            }
                                            else
                                            {
                                                <span class="fr-badge fr-badge-default">Folyamatban</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="fr-del-btn" @onclick="() => DeleteTask(task.TaskID)" title="Törlés">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v6" /><path d="M14 11v6" /><path d="M9 6V4h6v2" /></svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </main>
    </div>
}
else
{
    <div class="fr-unauth">
        <p>Nincs aktív munkamenet.</p>
        <a href="/login" class="fr-btn fr-btn-primary">Bejelentkezés</a>
    </div>
}


@code {
    private bool _hasCheckedAuth = false;
    private bool _isAuthenticated = false;
    private string _userEmail = "";
    private string _message = "";
    private bool _messageIsError = false;
    private bool _isLoading = false;
    private bool _isSaving = false;
    private string _formError = "";
    private string _theme = "light";

    // Automatikus UI-frissítés timer (percenként frissíti a DaysLeft / IsOverdue / IsDueSoon értékeket)
    private System.Threading.Timer? _uiRefreshTimer;
    // Automatikus adatlekérési timer (5 percenként kéri le újra az adatokat a szerverről)
    private System.Threading.Timer? _dataRefreshTimer;

    private List<TaskDto> _tasks = new();
    private List<EnrollmentDto> _enrollments = new();

    // Filters
    private string _filter = "all";
    private string _search = "";
    private string _sort = "due";

    // New task form
    private bool _showAdd = false;
    private string _newTitle = "";
    private int _newSubjectId = 0;
    private string _newType = "Assignment";
    private DateTime _newDueDate = DateTime.Now.AddDays(7);
    private string _newDescription = "";

    private IEnumerable<TaskDto> FilteredTasks
    {
        get
        {
            var q = _tasks.AsEnumerable();

            // Filter by status
            q = _filter switch
            {
                "active" => q.Where(t => !t.IsCompleted && !t.IsOverdue),
                "soon" => q.Where(t => t.IsDueSoon),
                "overdue" => q.Where(t => t.IsOverdue),
                "done" => q.Where(t => t.IsCompleted),
                "vizsga" => q.Where(t => t.TaskType == "Vizsga" && !t.IsCompleted),
                _ => q
            };

            // Search
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim().ToLower();
                q = q.Where(t =>
                    t.Title.ToLower().Contains(s) ||
                    t.SubjectName.ToLower().Contains(s) ||
                    t.SubjectCode.ToLower().Contains(s) ||
                    (t.Description?.ToLower().Contains(s) ?? false));
            }

            // Sort
            q = _sort switch
            {
                "subject" => q.OrderBy(t => t.SubjectName).ThenBy(t => t.DueDate),
                "type" => q.OrderBy(t => t.TaskType).ThenBy(t => t.DueDate),
                "name" => q.OrderBy(t => t.Title),
                _ => q.OrderBy(t => t.IsCompleted).ThenBy(t => t.DueDate)
            };

            return q;
        }
    }

    private string TranslateType(string t) => t switch
    {
        "Assignment" => "Beadandó",
        "Homework" => "Házi",
        "Exam" => "Dolgozat",
        "Vizsga" => "Vizsga",
        "Project" => "Projekt",
        "Personal" => "Egyéb",
        _ => t
    };

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.setTheme", _theme);
        StateHasChanged();
    }

    private void OnSubjectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id)) _newSubjectId = id;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        try { await AuthService.InitializeAsync(); } catch { }
        _hasCheckedAuth = true;
        _isAuthenticated = AuthService.IsAuthenticated;
        _userEmail = AuthService.CurrentUser?.Email ?? "";
        if (!_isAuthenticated) { Navigation.NavigateTo("/login"); return; }
        await LoadData();

        // UI-frissítő timer: percenként frissíti a megjelenítést
        // (DaysLeft, IsOverdue, IsDueSoon értékek élőben változnak)
        _uiRefreshTimer = new System.Threading.Timer(
            _ => InvokeAsync(StateHasChanged),
            null,
            TimeSpan.FromMinutes(1),
            TimeSpan.FromMinutes(1));

        // Adat-frissítő timer: 5 percenként újra lekéri a feladatokat a szerverről
        _dataRefreshTimer = new System.Threading.Timer(
            async _ =>
            {
                if (_isAuthenticated && !_isSaving)
                    await InvokeAsync(LoadData);
            },
            null,
            TimeSpan.FromMinutes(5),
            TimeSpan.FromMinutes(5));

        StateHasChanged();
    }

    public void Dispose()
    {
        _uiRefreshTimer?.Dispose();
        _dataRefreshTimer?.Dispose();
    }

    private async Task LoadData()
    {
        _isLoading = true; StateHasChanged();
        try { _tasks = await TaskService.GetMyTasksAsync(); } catch { _tasks = new(); }
        try { _enrollments = await SubjectService.GetMyEnrollmentsAsync(); } catch { _enrollments = new(); }
        _isLoading = false;
    }

    private async Task AddTask()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_newTitle)) { _formError = "Add meg a feladat nevét."; return; }
        if (_newSubjectId == 0) { _formError = "Válassz tantárgyat."; return; }

        _isSaving = true; StateHasChanged();
        try
        {
            var r = await TaskService.AddTaskAsync(new AddTaskRequest
            {
                SubjectID = _newSubjectId,
                Title = _newTitle.Trim(),
                Description = string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
                DueDate = _newDueDate,
                TaskType = _newType
            });

            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                _message = $"Feladat hozzáadva: {_newTitle}";
                _messageIsError = false;
                _newTitle = _newDescription = "";
                _newSubjectId = 0;
                _newDueDate = DateTime.Now.AddDays(7);
                _newType = "Assignment";
                _showAdd = false;
                await LoadData();
            }
            else { _formError = r.Message; }
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _isSaving = false; StateHasChanged(); }
    }

    private async Task ToggleComplete(TaskDto task)
    {
        try
        {
            SubjectResponse r;
            if (task.IsCompleted)
            {
                r = await TaskService.UncompleteTaskAsync(task.TaskID);
            }
            else
            {
                r = await TaskService.CompleteTaskAsync(task.TaskID);
            }
            if (r.Status == "OK" || r.Status == "SUCCESS")
            {
                await LoadData();
            }
            else
            {
                _message = r.Message;
                _messageIsError = true;
            }
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task DeleteTask(int taskId)
    {
        try
        {
            var r = await TaskService.DeleteTaskAsync(taskId);
            _messageIsError = r.Status != "OK" && r.Status != "SUCCESS";
            _message = _messageIsError ? r.Message : "Feladat törölve.";
            if (!_messageIsError) await LoadData();
        }
        catch (Exception ex) { _message = ex.Message; _messageIsError = true; }
        StateHasChanged();
    }

    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
}

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* Theme tokens */
    .fr-layout {
        --accent:#2563eb; --accent-hover:#1d4ed8; --accent-subtle:rgba(37,99,235,.08);
        --bg:#f8f9fb; --surface:#fff; --surface-2:#f1f3f7;
        --border:#e4e7ed; --border-strong:#c9cdd6;
        --text-primary:#0f1117; --text-secondary:#52586a; --text-muted:#9299aa;
        --danger:#dc2626; --danger-subtle:rgba(220,38,38,.07);
        --warning:#d97706; --warning-subtle:rgba(217,119,6,.08);
        --success:#16a34a; --success-subtle:rgba(22,163,74,.08);
        --radius:10px;
        --font:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',system-ui,sans-serif;
