@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>FeladatRadar - Kezdőlap</PageTitle>


<nav class="site-nav" id="nav-top">
    <div class="nav-inner">
        <a href="/" class="nav-brand">
            <div class="nav-logo">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            <span class="nav-brand-name">FeladatRadar</span>
        </a>
        <div class="nav-links">
            <a href="#sec-features" class="nav-link" @onclick='() => ScrollTo("sec-features")'>Funkciók</a>
            <a href="#sec-how" class="nav-link" @onclick='() => ScrollTo("sec-how")'>Hogyan működik?</a>
        </div>
    </div>
</nav>


<div class="page-bg-wrapper">
<section class="hero">
    <div class="hero-bg">
        <div class="hero-blob hero-blob-1"></div>
        <div class="hero-blob hero-blob-2"></div>
        <div class="hero-blob hero-blob-3"></div>
        <div class="hero-grid"></div>
    </div>

    <div class="hero-center">
        <h1 class="hero-title">
            Minden <br/>
            <span class="hero-title-accent">feladat egy helyen.</span>
        </h1>
        <p class="hero-sub">
            határidők, órarend, csoportmunka, fókuszidőzítő
            
        </p>
        <div class="hero-actions">
            <a href="/register" class="hero-btn-primary">
                Kezdés most
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <a href="/login" class="hero-btn-ghost">Már van fiókom</a>
        </div>
        <div class="hero-trust">
            <span class="hero-trust-item">✓ Regisztráció 30 mp alatt</span>
            <span class="hero-trust-sep">·</span>
            <span class="hero-trust-item">✓ Azonnali hozzáférés</span>
        </div>
    </div>

</section>


<section class="features-section" id="sec-features">
    <div class="features-inner">
        <div class="section-label">Funkciók</div>
        <h2 class="section-title">Mit találsz itt?</h2>
        <p class="section-sub">Válaszd ki a szerepkörödet, és nézd meg, mi vár rád</p>

        <div class="tab-selector">
            <button class="tab-btn @(_tab == "diak" ? "tab-active" : "")" @onclick='() => _tab = "diak"'>
                🎒 Diákoknak
            </button>
            <button class="tab-btn @(_tab == "tanar" ? "tab-active" : "")" @onclick='() => _tab = "tanar"'>
                👨‍🏫 Tanároknak
            </button>
        </div>

        @if (_tab == "diak")
        {
            <div class="tab-content fade-in">
                <div class="feature-grid">
                    <div class="feat-card feat-wide feat-dark-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-indigo">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            </div>
                            <span class="feat-label-tag">Feladatkezelő</span>
                        </div>
                        <h3 class="feat-title">Soha ne maradj le határidőről</h3>
                        <p class="feat-desc">Rögzítsd a házik, beadandók és dolgozatok dátumát. Automatikus figyelmeztetés, ha közeledik a határidő.</p>
                        <div class="feat-chips">
                            <span class="chip">📝 Beadandó</span>
                            <span class="chip">✍️ Dolgozat</span>
                            <span class="chip">📚 Házi feladat</span>
                            <span class="chip">🎓 Vizsga</span>
                        </div>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-blue">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            </div>
                            <span class="feat-label-tag">Naptár</span>
                        </div>
                        <h3 class="feat-title">Minden esemény egy nézeten</h3>
                        <p class="feat-desc">Heti és havi naptárnézet, ahol látod az összes tantárgyad eseményét egyszerre.</p>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-purple">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <span class="feat-label-tag">Fókusz Időzítő</span>
                        </div>
                        <h3 class="feat-title">Pomodoro-technika beépítve</h3>
                        <p class="feat-desc">25 perces fókuszblokkok automatikus szünetekkel. Kövesd nyomon, mennyit tanultál ma.</p>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-green">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <span class="feat-label-tag">Csoportok</span>
                        </div>
                        <h3 class="feat-title">Csoportmunka rendszerezve</h3>
                        <p class="feat-desc">Hozz létre tanulócsoportokat, oszd meg a feladatokat és szavazz közösen a fontos kérdésekben.</p>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-orange">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                            </div>
                            <span class="feat-label-tag">Tantárgyak</span>
                        </div>
                        <h3 class="feat-title">Iratkozz fel tantárgyakra</h3>
                        <p class="feat-desc">Válaszd ki a tárgyaidat, és automatikusan megjelennek az órarend eseményeid és a feladatok.</p>
                    </div>

                </div>
            </div>
        }

        @if (_tab == "tanar")
        {
            <div class="tab-content fade-in">
                <div class="feature-grid">
                    <div class="feat-card feat-wide feat-dark-card feat-dark-green">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-green">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            </div>
                            <span class="feat-label-tag">Feladatkiadás</span>
                        </div>
                        <h3 class="feat-title">Add ki a feladatokat egy kattintással</h3>
                        <p class="feat-desc">Hozz létre házi feladatot, beadandót vagy dolgozatot — automatikusan megjelenik a diákok naptárában és feladatlistájában.</p>
                        <div class="feat-chips">
                            <span class="chip chip-green">📊 Osztályáttekintés</span>
                            <span class="chip chip-green">✅ Feladatkiadás</span>
                            <span class="chip chip-green">📈 Előrehaladás</span>
                        </div>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-blue">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            </div>
                            <span class="feat-label-tag">Dolgozatütemező</span>
                        </div>
                        <h3 class="feat-title">Ütemezd be a dolgozatokat</h3>
                        <p class="feat-desc">Rögzítsd a ZH-kat és vizsgákat — megjelenik a csoport összes tagjánál egyszerre.</p>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-purple">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <span class="feat-label-tag">Csoportkezelés</span>
                        </div>
                        <h3 class="feat-title">Hozz létre osztálycsoportokat</h3>
                        <p class="feat-desc">Meghívó küldése emailen — a diákok azonnal látják a csoport tartalmát és feladatait.</p>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-orange">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v13H3z"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
                            </div>
                            <span class="feat-label-tag">Szavazások</span>
                        </div>
                        <h3 class="feat-title">Szavazz a csoportban</h3>
                        <p class="feat-desc">Hozz létre gyors szavazásokat pl. időpontra, témára — a diákok valós időben szavaznak.</p>
                    </div>
                    <div class="feat-card">
                        <div class="feat-card-top">
                            <div class="feat-icon-wrap feat-icon-indigo">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                            </div>
                            <span class="feat-label-tag">Tantárgyak</span>
                        </div>
                        <h3 class="feat-title">Saját tantárgyak kezelése</h3>
                        <p class="feat-desc">Hozz létre és szerkessz tantárgyakat, állítsd be az órarendet, diákok feliratkoznak.</p>
                    </div>

                </div>
            </div>
        }
    </div>
</section>


<section class="how-section" id="sec-how">
    <div class="how-inner">
        <div class="section-label">Hogyan működik?</div>
        <h2 class="section-title">Négy lépés, és minden a helyén van</h2>
        <p class="section-sub">Nem kell hozzá semmiféle előismeret — ha tudod kezelni az emailt, ezt is tudod majd kezelni.</p>

        <div class="how-grid">
            <div class="how-card">
                <div class="how-card-head">
                    <div class="how-icon-wrap how-icon-purple">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div class="how-step-num">01</div>
                </div>
                <h3 class="how-card-title">Hozz létre egy fiókot</h3>
                <p class="how-card-desc">Kattints a „Regisztráció" gombra, add meg a nevedet, egy felhasználónevet, az email címedet és egy jelszót. Az egész kb. 30 másodpercet vesz igénybe. Választanod kell egy szerepkört is: <strong>Diák</strong> vagyok, vagy <strong>Tanár</strong> vagyok — ettől függ, milyen funkciók lesznek elérhetők számodra.</p>
                <div class="how-tip">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    A regisztráció után rögtön beléphetsz, nincs email-megerősítés.
                </div>
            </div>

            <div class="how-card">
                <div class="how-card-head">
                    <div class="how-icon-wrap how-icon-amber">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    </div>
                    <div class="how-step-num">02</div>
                </div>
                <h3 class="how-card-title">Iratkozz fel tantárgyakra</h3>
                <p class="how-card-desc">A Tantárgyak menüben megtalálod az összes elérhető tárgyat. Egyszerűen kattints arra, amelyiket tanulod, és feliratkozol. Ezután az adott tantárgyhoz tartozó órarendi alkalmakat és feladatokat fel tudod venni és megjelennek a naptáradban és a feladatlistádban.</p>
                <div class="how-tip">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    Ha a tantárgyad nem szerepel a listában, kérheted a tanárodat, hogy hozza létre.
                </div>
            </div>

            <div class="how-card">
                <div class="how-card-head">
                    <div class="how-icon-wrap how-icon-green">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    </div>
                    <div class="how-step-num">03</div>
                </div>
                <h3 class="how-card-title">Kezeld a feladataidat</h3>
                <p class="how-card-desc">A Feladatok oldalon látod az összes teendődet, határidővel együtt. Új feladatot a „+" gombbal adhatsz hozzá: megadod a nevet, a tantárgyat és a határidőt. Ha kész vagy egy feladattal, egyszerűen pipáld ki — eltűnik az aktív listából. A naptárban heti és havi nézetben is látod, mi mikor esedékes.</p>
                <div class="how-tip">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    A közeledő határidőjű feladatok piros jelzést kapnak, hogy ne maradj le semmiről.
                </div>
            </div>

            <div class="how-card">
                <div class="how-card-head">
                    <div class="how-icon-wrap how-icon-blue">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="how-step-num">04</div>
                </div>
                <h3 class="how-card-title">Csatlakozz csoportokhoz</h3>
                <p class="how-card-desc">A Csoportok menüben létrehozhatsz vagy csatlakozhatsz tanulócsoportokhoz. Ha a tanárod vagy egy osztálytársad meghív, egy értesítést kapsz — elfogadod, és máris látod a közös feladatokat, a csoportos szavazásokat és az órarendet. A Fókusz időzítővel pedig akár 90 perces tanulási blokkokat is indíthatsz, beépített szünetjelzővel.</p>
                <div class="how-tip">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    A fókusz időzítő és a csoportfunkciók egyszerre is használhatók.
                </div>
            </div>
        </div>
    </div>
</section>


<section class="cta-section" id="sec-cta">
    <div class="cta-inner">
        <h2 class="cta-title">Készen állsz?</h2>
        <p class="cta-sub">Csatlakozz és kezdd el szervezni a tanulmányaidat még ma!</p>
        <div class="cta-btns">
            <a href="/register" class="hero-btn-primary">Regisztráció</a>
            <a href="/login" class="hero-btn-ghost cta-ghost">Bejelentkezés</a>
        </div>
    </div>
</section>
</div>

@code {
    private string _tab = "diak";

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("eval", $"document.getElementById('{id}')?.scrollIntoView({{behavior:'smooth'}})");
    }
}

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :focus { outline: none; }
    :focus-visible { outline: none; }

    :root {
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-sub: rgba(79,70,229,.1);
        --green: #0e9f6e;
        --green-hover: #057a55;
        --green-sub: rgba(14,159,110,.1);
        --border: #e8e2d8;
        --text: #1a1714;
        --text-2: #5c5650;
        --text-muted: #9b948c;
        --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
        --grid-line: rgba(109,40,217,.07);
        --grid-size: 56px;
    }

   
    .site-nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: rgba(250,247,255,.88);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(109,40,217,.1);
    }
    .nav-inner {
        max-width: 1200px; margin: 0 auto;
        display: flex; align-items: center; gap: 2rem;
        padding: 0 6vw; height: 62px;
    }
    .nav-brand {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; flex-shrink: 0;
    }
    .nav-logo {
        width: 34px; height: 34px; border-radius: 9px;
        background: rgba(109,40,217,.1); border: 1px solid rgba(109,40,217,.2);
        display: flex; align-items: center; justify-content: center;
        color: #6d28d9; flex-shrink: 0;
    }
    .nav-brand-name {
        font-size: .95rem; font-weight: 700; color: #1e1b4b;
        letter-spacing: -.02em;
    }
    .nav-links {
        display: flex; align-items: center; gap: 4px;
        flex: 1; margin-left: 1.5rem;
    }
    .nav-link {
        padding: 7px 14px; border-radius: 8px;
        color: #5b5285; font-size: .85rem; font-weight: 500;
        text-decoration: none; transition: color .15s, background .15s;
        cursor: pointer;
    }
    .nav-link:hover { color: #1e1b4b; background: rgba(109,40,217,.07); }
    .nav-actions { display: flex; align-items: center; gap: 8px; margin-left: auto; }
    .nav-btn-ghost {
        padding: 8px 16px; border-radius: 8px;
        color: #5b5285; font-size: .83rem; font-weight: 500;
        text-decoration: none; border: 1px solid rgba(109,40,217,.2);
        transition: all .15s; white-space: nowrap;
    }
    .nav-btn-ghost:hover { color: #1e1b4b; background: rgba(109,40,217,.07); }
    .nav-btn-primary {
        padding: 8px 18px; border-radius: 8px;
        background: var(--accent); color: #fff;
        font-size: .83rem; font-weight: 600;
        text-decoration: none; transition: background .15s; white-space: nowrap;
    }
    .nav-btn-primary:hover { background: var(--accent-hover); }

    
    .hero {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 11rem 6vw 7rem;
        overflow: hidden;
        background: transparent;
        color: #1e1b4b;
    }
    .hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
    .hero-blob {
        position: absolute; border-radius: 50%;
        filter: blur(110px); opacity: .42;
    }
    .hero-blob-1 {
        width: 700px; height: 700px;
        background: radial-gradient(circle, #a78bfa, transparent);
        top: -200px; left: -150px;
    }
    .hero-blob-2 {
        width: 500px; height: 500px;
        background: radial-gradient(circle, #fcd34d, transparent);
        bottom: 100px; right: -100px;
    }
    .hero-blob-3 {
        width: 400px; height: 400px;
        background: radial-gradient(circle, #c4b5fd, transparent);
        top: 60%; left: 50%; transform: translateX(-50%);
    }
  
    .hero-grid {
        position: absolute; inset: 0;
        background-image:
            linear-gradient(var(--grid-line) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: var(--grid-size) var(--grid-size);
    }

    
    .hero-center {
        position: relative; z-index: 1;
        display: flex; flex-direction: column;
        align-items: center; text-align: center;
        max-width: 780px;
        padding-bottom: 0;
    }
