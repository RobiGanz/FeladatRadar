@page "/login"
@using FeladatRadar.frontend.Models
@using FeladatRadar.frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer
<PageTitle>Bejelentkezés — FeladatRadar</PageTitle>

<div class="auth-page">
    <div class="auth-left">
        <a href="/" class="auth-brand">
            <div class="auth-brand-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            FeladatRadar
        </a>
        <div class="auth-card">
            <div class="auth-header">
                <h1>Üdvözölünk vissza!</h1>
                <p>Jelentkezz be a fiókodba</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="auth-alert">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span>@errorMessage</span>
                </div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin" class="auth-form">
                <DataAnnotationsValidator />

                <div class="auth-field">
                    <label class="auth-label">Felhasználónév</label>
                    <InputText class="auth-input" @bind-Value="loginModel.Username" placeholder="kovacs.janos" />
                    <ValidationMessage For="@(() => loginModel.Username)" class="auth-error" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Jelszó</label>
                    <div class="password-wrapper">
                        <InputText type="@passwordInputType" class="auth-input" @bind-Value="loginModel.Password" placeholder="••••••••" />
                        <button type="button" class="toggle-password" @onclick="TogglePassword">
                            @if (showPassword)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => loginModel.Password)" class="auth-error" />
                </div>

                <button type="submit" class="auth-submit" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="auth-spinner"></span>
                        <span>Bejelentkezés...</span>
                    }
                    else
                    {
                        <span>Bejelentkezés</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    }
                </button>
            </EditForm>

            <div class="auth-footer">
                Új vagy itt? <a href="/register">Regisztrálj most</a>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-right-bg">
            <div class="ar-blob ar-blob-1"></div>
            <div class="ar-blob ar-blob-2"></div>
            <div class="ar-grid"></div>
        </div>
        <div class="auth-right-inner">
            <div class="ar-badge">
                <span class="ar-badge-dot"></span>
                Diákoknak és tanároknak
            </div>
            <p class="auth-quote">„Rendszerezd a napjaidat, és a tanulás egyszerűbbé válik."</p>
            <div class="auth-features">
                <div class="auth-feat">
                    <div class="feat-icon-box feat-purple">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    </div>
                    Feladatok és határidők egy helyen
                </div>
                <div class="auth-feat">
                    <div class="feat-icon-box feat-amber">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    Beépített Pomodoro fókuszidőzítő
                </div>
                <div class="auth-feat">
                    <div class="feat-icon-box feat-green">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    </div>
                    Csoportmunka és megosztott feladatok
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool hasRendered = false;
    private bool showPassword = false;
    private string passwordInputType = "password";

    private void TogglePassword()
    {
        showPassword = !showPassword;
        passwordInputType = showPassword ? "text" : "password";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) hasRendered = true;
        if (hasRendered && AuthService.IsAuthenticated)
            await AuthService.SaveToLocalStorageAsync();
    }

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;
        isLoading = true;
        try
        {
            var response = await AuthService.Login(loginModel);
            if (response != null && response.Status == "SUCCESS")
            {
                StateHasChanged();
                await Task.Delay(100);
                await AuthService.SaveToLocalStorageAsync();
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                errorMessage = response?.Message ?? "Bejelentkezési hiba!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Hiba történt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}


<style>
    
    .auth-page { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; font-family: 'Segoe UI', system-ui, sans-serif; }
    .auth-left { display: flex; flex-direction: column; padding: 2.5rem 5vw; }
    .auth-right { display: none; }
</style>