    .fr-panel { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; flex-shrink:0; }
    .fr-panel-header { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid var(--border); background:linear-gradient(135deg,rgba(102,126,234,.05),rgba(118,75,162,.05)); flex-wrap:wrap; gap:6px; flex-shrink:0; }
    .fr-panel-title { font-weight:700; font-size:.875rem; display:flex; align-items:center; color:var(--text-primary); }
