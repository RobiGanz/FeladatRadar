@code {
    private bool _menuOpen = false;
    private string SidebarClass => _menuOpen ? "fr-sidebar fr-sidebar-open" : "fr-sidebar";
    private string LayoutClass  => _menuOpen ? "fr-layout fr-menu-open"    : "fr-layout";
    private void ToggleMenu() { _menuOpen = !_menuOpen; StateHasChanged(); }
    private void CloseMenu()  { _menuOpen = false; StateHasChanged(); }

    private bool   _hasCheckedAuth  = false;
    private bool   _isAuthenticated = false;
    private string _userRole  = "";
    private string _userEmail = "";
    private string _firstName = "";
    private string _theme     = "light";
    private bool   _isLoading = true;

    private int _activeTasks  = 0;
    private int _overdueTasks = 0;
    private int _subjectCount = 0;
    private int _groupCount   = 0;
    private int _todayEvents  = 0;
    private List<TaskDto> _allTasks = new();
    private string _dayFilter = "today";

    private IEnumerable<TaskDto> FilteredTasks => _dayFilter switch
    {
        "today"    => _allTasks.Where(t => !t.IsCompleted && t.DueDate.Date == DateTime.Today).OrderBy(t => t.DueDate),
        "tomorrow" => _allTasks.Where(t => !t.IsCompleted && t.DueDate.Date == DateTime.Today.AddDays(1)).OrderBy(t => t.DueDate),
        "week"     => _allTasks.Where(t => !t.IsCompleted && t.DueDate.Date >= DateTime.Today && t.DueDate.Date <= DateTime.Today.AddDays(7)).OrderBy(t => t.DueDate),
        _          => _allTasks.Where(t => !t.IsCompleted).OrderBy(t => t.DueDate).Take(10),
    };

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.setTheme", _theme);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        try { await AuthService.InitializeAsync(); } catch { }
        _hasCheckedAuth  = true;
        _isAuthenticated = AuthService.IsAuthenticated;
        _userEmail = AuthService.CurrentUser?.Email ?? "";
        _userRole  = AuthService.CurrentUser?.UserRole ?? "";
        var p = _userEmail.Split('@')[0].Split('.')[0];
        _firstName = p.Length > 0 ? char.ToUpper(p[0]) + p.Substring(1) : _userEmail;
        if (!_isAuthenticated) { Navigation.NavigateTo("/login"); return; }
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _isLoading = true; StateHasChanged();
        List<EnrollmentDto> enrollments = new();
        List<GroupDto> groups = new();
        try { _allTasks   = await TaskService.GetMyTasksAsync(); }          catch { _allTasks = new(); }
        try { enrollments = await SubjectService.GetMyEnrollmentsAsync(); } catch { }
        try { groups      = await GroupService.GetMyGroupsAsync(); }        catch { }
        _activeTasks  = _allTasks.Count(t => !t.IsCompleted && !t.IsOverdue);
        _overdueTasks = _allTasks.Count(t => t.IsOverdue);
        _subjectCount = enrollments.Count;
        _groupCount   = groups.Count;
        _todayEvents  = _allTasks.Count(t => !t.IsCompleted && t.DueDate.Date == DateTime.Today);
        _isLoading = false;
    }

    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
}
