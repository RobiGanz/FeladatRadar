@page "/dashboard"
@using FeladatRadar.frontend.Models
@using FeladatRadar.frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable

<PageTitle>Dashboard - FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="loading-screen">
        <div class="spinner-large"></div>
        <p>Betöltés...</p>
    </div>
}
else if (AuthService.IsAuthenticated && AuthService.CurrentUser != null)
{
    <div class="fr-layout fr-layout-dashboard" data-theme="@_theme">
        <!-- Sidebar -->
        <aside class="fr-sidebar">
            <div class="fr-brand">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
                <span>FeladatRadar</span>
            </div>
            <nav class="fr-nav">
                <a href="/dashboard" class="fr-nav-item fr-active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>Dashboard</a>
                <a href="/naptar" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Naptár</a>
                <a href="/feladatok" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>Feladatok</a>
                <a href="/fokusz" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Csoportok</a>
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark")
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /></svg>
                
                        <span>Világos mód</span>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
                
                        <span>Sötét mód</span>
                    }
                </button>
                <button class="fr-logout" @onclick="HandleLogout"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Kijelentkezés</button>
            </div>
        </aside>

       
        <div class="main-content">
        </div>
    </div>
}
else
{
    <div class="not-authenticated">
        <h2>🔒 Nem vagy bejelentkezve</h2>
        <p>Jelentkezz be a dashboard eléréséhez!</p>
        <a href="/login" class="btn-login">Bejelentkezés</a>
    </div>
}

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    .fr-layout { --accent:#2563eb; --accent-hover:#1d4ed8; --accent-subtle:rgba(37,99,235,.08); --bg:#f8f9fb; --surface:#fff; --surface-2:#f1f3f7; --border:#e4e7ed; --border-strong:#c9cdd6; --text-primary:#0f1117; --text-secondary:#52586a; --text-muted:#9299aa; --danger:#dc2626; --danger-subtle:rgba(220,38,38,.07); --warning:#d97706; --warning-subtle:rgba(217,119,6,.08); --success:#16a34a; --success-subtle:rgba(22,163,74,.08); --radius:10px; --font:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',system-ui,sans-serif; }
    .fr-layout[data-theme="dark"] { --bg:#0d0f14; --surface:#161820; --surface-2:#1e2130; --border:#272b3a; --border-strong:#363c50; --text-primary:#f0f2f8; --text-secondary:#8892a4; --text-muted:#4e566a; --accent-subtle:rgba(37,99,235,.15); --danger-subtle:rgba(220,38,38,.12); --warning-subtle:rgba(217,119,6,.12); --success-subtle:rgba(22,163,74,.12); }
    .fr-layout { display:grid; grid-template-columns:220px 1fr; height:100vh; background:var(--bg); font-family:var(--font); color:var(--text-primary); overflow:hidden; }
    .fr-layout-dashboard { grid-template-columns:220px 1fr 280px; }
    .fr-sidebar { display:flex; flex-direction:column; background:var(--surface); border-right:1px solid var(--border); height:100vh; }
    .fr-brand { display:flex; align-items:center; gap:10px; padding:20px 18px; font-weight:700; font-size:.95rem; color:var(--accent); border-bottom:1px solid var(--border); }
    .fr-nav { flex:1; padding:12px 10px; display:flex; flex-direction:column; gap:2px; overflow-y:auto; scrollbar-width:none; }
    .fr-nav::-webkit-scrollbar { display:none; }
    .fr-nav-item { display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; color:var(--text-secondary); text-decoration:none; font-size:.875rem; font-weight:500; transition:background .15s,color .15s; }
    .fr-nav-item:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-nav-item.fr-active { background:var(--accent-subtle); color:var(--accent); }
    .fr-sidebar-footer { padding:12px 10px; border-top:1px solid var(--border); display:flex; flex-direction:column; gap:4px; }
    .fr-theme-toggle, .fr-logout { display:flex; align-items:center; gap:9px; width:100%; padding:9px 10px; border:none; border-radius:8px; background:none; color:var(--text-secondary); font-size:.85rem; font-weight:500; cursor:pointer; text-align:left; transition:background .15s,color .15s; font-family:var(--font); }
    .fr-theme-toggle:hover { background:var(--surface-2); color:var(--text-primary); }
    .fr-logout:hover { background:var(--danger-subtle); color:var(--danger); }
    .loading-screen { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100vh; gap:14px; color:var(--text-muted, #9299aa); font-size:.875rem; font-family:-apple-system,BlinkMacSystemFont,'Inter',system-ui,sans-serif; }
    .spinner-large { width:36px; height:36px; border:3px solid #e4e7ed; border-top-color:#2563eb; border-radius:50%; animation:fr-spin .7s linear infinite; }
    .spinner-sm { width:20px; height:20px; border:2px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:fr-spin .7s linear infinite; margin:0 auto; }
    @@keyframes fr-spin { to { transform:rotate(360deg); } }
    .not-authenticated { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100vh; gap:16px; text-align:center; font-family:-apple-system,BlinkMacSystemFont,'Inter',system-ui,sans-serif; }
    .not-authenticated h2 { font-size:1.4rem; font-weight:700; }
    .not-authenticated p { color:#52586a; font-size:.875rem; }
    .btn-login { padding:10px 20px; background:#2563eb; color:#fff; border-radius:8px; text-decoration:none; font-size:.875rem; font-weight:600; transition:background .15s; }
    .btn-login:hover { background:#1d4ed8; }
    .main-content { display:flex; flex-direction:column; overflow-y:auto; background:var(--bg); }
</style>

@code {
    private bool _hasCheckedAuth = false;
    private string _theme = "light";

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.setTheme", _theme);
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
            await AuthService.InitializeAsync();
            _hasCheckedAuth = true;
            StateHasChanged();

            if (!AuthService.IsAuthenticated)
            {
                await Task.Delay(100);
                Navigation.NavigateTo("/login");
                return;
            }
            StateHasChanged();
        }
    }

    public void Dispose() { }
}