    .db-day-filter { display:flex; gap:2px; background:var(--surface-2); border-radius:7px; padding:2px; }
    .db-day-btn { padding:3px 8px; border:none; border-radius:5px; background:none; color:var(--text-muted); font-size:.7rem; font-weight:500; cursor:pointer; transition:all .15s; font-family:var(--font); }
    .db-day-btn:hover { color:var(--text-primary); }
    .db-day-btn.db-day-active { background:var(--surface); color:var(--text-primary); font-weight:600; box-shadow:0 1px 3px rgba(0,0,0,.08); }

    .fr-task-list { flex:1; overflow-y:auto; }
    .fr-task-row { display:flex; align-items:center; padding:10px 14px; border-bottom:1px solid var(--border); gap:10px; transition:background .12s; }
    .fr-task-row:last-child { border-bottom:none; }
    .fr-task-row:hover { background:var(--surface-2); }
    .fr-task-row.fr-task-overdue { background:var(--danger-subtle); }
    .fr-task-row.fr-task-urgent { background:var(--warning-subtle); }
    .fr-task-check { color:var(--border-strong); flex-shrink:0; }
    .fr-task-info { flex:1; min-width:0; }
    .fr-task-title { display:block; font-weight:600; font-size:.82rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--text-primary); }
    .fr-task-sub { font-size:.68rem; color:var(--text-muted); }
    .fr-due-badge { font-size:.66rem; font-weight:600; padding:2px 6px; border-radius:4px; white-space:nowrap; }
    .fr-due-overdue { background:var(--danger-subtle); color:var(--danger); }
    .fr-due-today { background:var(--warning-subtle); color:var(--warning); }
    .fr-due-soon { background:var(--warning-subtle); color:var(--warning); }
    .fr-due-date { font-size:.7rem; color:var(--text-muted); font-weight:500; white-space:nowrap; }

    .db-nav-list { display:flex; flex-direction:column; }
    .db-navitem { display:flex; align-items:center; gap:14px; padding:14px 18px; text-decoration:none; border-bottom:1px solid var(--border); transition:background .12s; }
    .db-navitem:last-child { border-bottom:none; }
    .db-navitem:hover { background:var(--surface-2); }
    .db-navitem-icon { width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .db-navitem-label { flex:1; font-size:.88rem; font-weight:600; color:var(--text-primary); }
    .db-navitem-arrow { color:var(--text-muted); }
    .db-nav-naptar-ic { background:var(--accent-subtle); color:var(--accent); }
    .db-nav-feladat-ic { background:var(--danger-subtle); color:var(--danger); }
    .db-nav-tantargy-ic { background:var(--warning-subtle); color:var(--warning); }
    .db-nav-csoport-ic { background:var(--success-subtle); color:var(--success); }
    .db-navitem:hover .db-navitem-arrow { color:var(--accent); }

 /* 1100px: hide right column */
    @@media (max-width:1100px) {
        .db-three-grid { grid-template-columns:1fr; }
