@page "/Error"
@using System.Diagnostics

<PageTitle>Hiba — FeladatRadar</PageTitle>

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif;color:#1e1b4b;">
    <h1 style="font-size:2rem;font-weight:800;margin-bottom:.5rem;">Hiba történt</h1>
    <p style="color:#5b5285;">A kérés feldolgozása során váratlan hiba lépett fel.</p>
    @if (ShowRequestId)
    {
        <p style="margin-top:1rem;font-size:.85rem;color:#9284c2;">Azonosító: <code>@RequestId</code></p>
    }
    <a href="/" style="margin-top:2rem;color:#6d28d9;font-weight:600;text-decoration:none;">← Vissza a főoldalra</a>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
