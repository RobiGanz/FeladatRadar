@page "/tantargyak"
@using FeladatRadar.frontend.Services
@using FeladatRadar.frontend.Models
@inject AuthService AuthService
@inject SubjectService SubjectService
@inject TaskService TaskService
@inject ScheduleService ScheduleService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Tantárgyak — FeladatRadar</PageTitle>

@if (!_hasCheckedAuth)
{
    <div class="fr-loading"><div class="fr-spinner"></div></div>
}
else if (AuthService.IsAuthenticated && AuthService.CurrentUser != null)
{
    <div class="@LayoutClass" data-theme="@_theme" data-role="@_userRole">
        @if (_menuOpen)
        {
            <div class="fr-sidebar-backdrop" @onclick="CloseMenu"></div>
        }
        <aside class="@SidebarClass">
            <a href="/dashboard" class="fr-brand" @onclick="CloseMenu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
                <span>FeladatRadar</span>
            </a>
            <nav class="fr-nav">
                <a href="/naptar" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Naptár</a>
                <a href="/fokusz" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>Fókusz Időzítő</a>
                <a href="/tantargyak" class="fr-nav-item fr-active" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>Tantárgyak</a>
                <a href="/csoport" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>Csoportok</a>
                @if (_userRole == "Admin")
                {
                    <a href="/admin" class="fr-nav-item" @onclick="CloseMenu"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>Admin</a>
                }
            </nav>
            <div class="fr-sidebar-footer">
                <button class="fr-theme-toggle" @onclick="ToggleTheme">
                    @if (_theme == "dark")
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /></svg>
                        <span>Világos mód</span>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
                        <span>Sötét mód</span>
                    }
                </button>
                <button class="fr-logout" @onclick="HandleLogout"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Kijelentkezés</button>
            </div>
        </aside>

        <main class="fr-main">
            <header class="fr-topbar">
                <div class="fr-topbar-left">
                    <button class="fr-hamburger" @onclick="ToggleMenu" title="Menü">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
                    </button>
                    <span class="fr-page-title">Tantárgyak</span>
                    <span class="fr-breadcrumb">/ @_myEnrollments.Count aktív</span>
                </div>
                <div class="fr-topbar-right">
                    <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick='() => { _showCustomForm = !_showCustomForm; _showTemplates = false; }'>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Egyéni tantárgy
                    </button>
                    <button class="fr-btn fr-btn-sm fr-btn-secondary" @onclick='() => { _showTemplates = !_showTemplates; _showCustomForm = false; }'>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                        Sablon tantárgyak
                        @if (_availableSubjects.Count > 0)
                        {
                            <span class="fr-btn-badge">@_availableSubjects.Count</span>
                        }
                    </button>
                  <button class="fr-btn fr-btn-sm fr-btn-secondary" @onclick="RefreshSubjects" disabled="@_isLoading">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="@(_isLoading ? "fr-spin-icon" : "")"><polyline points="23 4 23 10 17 10" /><polyline points="1 20 1 14 7 14" /><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" /></svg>
                        Frissítés
                    </button>
                </div>
            </header>

            <div class="fr-content">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="fr-alert @(_messageIsError ? "fr-alert-danger" : "fr-alert-success")">
                        @_message
                        <button class="fr-alert-close" @onclick="() => _message = string.Empty">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                        </button>
                    </div>
                }

                <!-- Egyéni tantárgy form -->
                @if (_showCustomForm)
                {
                    <div class="fr-form-card">
                        <div class="fr-form-card-head">
                            <div>
                                <h2 class="fr-form-title">Saját tantárgy hozzáadása</h2>
                                <p class="fr-form-desc">Nem szerepel a listában? Add hozzá manuálisan — csak te látod.</p>
                            </div>
                            <button class="fr-icon-btn" @onclick='() => _showCustomForm = false'>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_customError))
                        {
                            <div class="fr-alert fr-alert-danger">@_customError</div>
                        }
                        <div class="fr-form-row">
                            <div class="fr-field" style="flex:2">
                                <label class="fr-label">Tantárgy neve <span class="fr-required">*</span></label>
                                <input class="fr-input" type="text" placeholder="pl. Kvantumfizika" @bind="_customSubjectName" maxlength="200" />
                            </div>
                            <div class="fr-field">
                                <label class="fr-label">Kód <span class="fr-optional">— opcionális</span></label>
                                <input class="fr-input" type="text" placeholder="pl. KF001" @bind="_customSubjectCode" maxlength="20" />
                            </div>
                            <button class="fr-btn fr-btn-primary" style="align-self:flex-end" @onclick="EnrollCustomSubject" disabled="@_customIsLoading">
                                @(_customIsLoading ? "Hozzáadás..." : "Felvétel")
                            </button>
                        </div>
                    </div>
                }

                <!-- Sablon tantárgyak (elérhető, előre megadott) -->
                @if (_showTemplates)
                {
                    <div class="fr-form-card">
                        <div class="fr-form-card-head">
                            <div>
                                <h2 class="fr-form-title">Sablon tantárgyak</h2>
                                <p class="fr-form-desc">Előre összeállított tantárgyak — egy kattintással felveheted bármelyiket.</p>
                            </div>
                            <button class="fr-icon-btn" @onclick='() => _showTemplates = false'>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            </button>
                        </div>
                        @if (_availableSubjects.Count == 0)
                        {
                            <div class="fr-empty-state" style="padding:24px 0">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                                <span>Már minden elérhető sablon tantárgyat felvettél!</span>
                            </div>
                        }
                        else
                        {
                            <div class="fr-template-list">
                                @foreach (var s in _availableSubjects)
                                {
                                    var color = SubjectColor(s.SubjectName);
                                    var isEnrolling = _enrollingIds.Contains(s.SubjectID);
                                    <div class="fr-template-row">
                                        <div class="fr-template-dot" style="background:@color"></div>
                                        <div class="fr-template-info">
                                            <span class="fr-template-name">@s.SubjectName</span>
                                            <span class="fr-template-meta">
                                                @if (!string.IsNullOrEmpty(s.SubjectCode))
                                                {
                                                    <span>@s.SubjectCode</span>
                                                }
                                                @if (!string.IsNullOrEmpty(s.TeacherName))
                                                {
                                                    <span>· @s.TeacherName</span>
                                                }
                                                @if (s.Credits > 0)
                                                {
                                                    <span>· @s.Credits kredit</span>
                                                }

                                            </span>
                                        </div>
                                        <button class="fr-btn fr-btn-primary fr-btn-sm" @onclick="() => EnrollTemplate(s.SubjectID)" disabled="@isEnrolling">
                                            @if (isEnrolling)
                                            {
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="fr-spin-icon"><polyline points="23 4 23 10 17 10" /><polyline points="1 20 1 14 7 14" /><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" /></svg>
                                                <span>Felvétel...</span>
                                            }
                                            else
                                            {
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                                <span>Felvenni</span>
                                            }
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @if (_isLoading)
                {
                    <div class="fr-empty-state"><div class="fr-spinner fr-spinner-sm"></div></div>
                }
                else
                {
                    <!-- Felvett tantárgyak -->
                    <div class="fr-section">
                        <div class="fr-section-head">
                            <span class="fr-section-title">Felvett tantárgyaim</span>
                            <span class="fr-section-count">@_myEnrollments.Count</span>
                        </div>
                        @if (_myEnrollments.Count == 0)
                        {
                            <div class="fr-empty-state">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                                <span>Még nincs felvett tantárgyad.</span>
                                <span style="font-size:.78rem;opacity:.7">Vegyél fel sablont, vagy adj hozzá egyéni tantárgyat.</span>
                            </div>
                        }
                        else
                        {
                            <div class="fr-subject-grid">
                                @foreach (var e in _myEnrollments)
                                {
                                    var color = SubjectColor(e.SubjectName);
                                    var taskCount = _tasks.Count(t => t.SubjectID == e.SubjectID && !t.IsCompleted);
                                    var doneCount = _tasks.Count(t => t.SubjectID == e.SubjectID && t.IsCompleted);
                                    var classCount = _schedule.Count(s => s.SubjectID == e.SubjectID);
                                    var isDropping = _droppingIds.Contains(e.SubjectID);
                                    <div class="fr-subject-card" style="--sc:@color">
                                        <div class="fr-sc-stripe"></div>
                                        <div class="fr-sc-body">
                                            <div class="fr-sc-top">
                                                <span class="fr-sc-code">@(string.IsNullOrEmpty(e.SubjectCode) ? "—" : e.SubjectCode)</span>
                                                <span class="fr-badge fr-badge-active">Aktív</span>
                                                <button class="fr-drop-btn @(isDropping ? "fr-drop-btn-loading" : "")"
                                                        @onclick="() => DropSubject(e.SubjectID)"
                                                        disabled="@isDropping"
                                                        title="Tantárgy leadása">
                                                    @if (isDropping)
                                                    {
                                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="fr-spin-icon"><polyline points="23 4 23 10 17 10" /><polyline points="1 20 1 14 7 14" /><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" /></svg>
                                                    }
                                                    else
                                                    {
                                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6" /><path d="M14 11v6" /><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></svg>
                                                    }
                                                </button>
                                            </div>
                                            <h3 class="fr-sc-name">@e.SubjectName</h3>
                                            <p class="fr-sc-meta">Felvéve: @e.EnrolledAt.ToString("yyyy. MM. dd.")</p>
                                            <div class="fr-sc-stats">
                                                <span class="fr-sc-stat">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                                    <span class="fr-sc-stat-n">@classCount</span> óra/hét
                                                </span>
                                                <span class="fr-sc-stat">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4" /></svg>
                                                    <span class="fr-sc-stat-n">@taskCount</span> aktív
                                                </span>
                                                <span class="fr-sc-stat">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M9 12l2 2 4-4" /></svg>
                                                    <span class="fr-sc-stat-n">@doneCount</span> kész
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </main>
    </div>
}
else
{
    <div class="fr-unauth"><p>Nincs aktív munkamenet.</p><a href="/login" class="fr-btn fr-btn-primary">Bejelentkezés</a></div>
}

@code {
    private bool _menuOpen = false;
    private string SidebarClass => _menuOpen ? "fr-sidebar fr-sidebar-open" : "fr-sidebar";
    private string LayoutClass => _menuOpen ? "fr-layout fr-menu-open" : "fr-layout";
    private void ToggleMenu() { _menuOpen = !_menuOpen; StateHasChanged(); }
    private void CloseMenu() { _menuOpen = false; StateHasChanged(); }

    private bool _hasCheckedAuth, _isLoading, _messageIsError, _showCustomForm, _showTemplates, _customIsLoading;
    private string _message = "", _customSubjectName = "", _customSubjectCode = "", _customError = "", _theme = "light", _userRole = "";
    private List<SubjectDto> _availableSubjects = new();
    private List<EnrollmentDto> _myEnrollments = new();
    private List<TaskDto> _tasks = new();
    private List<ScheduleEntryDto> _schedule = new();
    private HashSet<int> _droppingIds = new();
    private HashSet<int> _enrollingIds = new();

    private static readonly string[] _palette = { "#4f46e5", "#0891b2", "#0e9f6e", "#d97706", "#db2777", "#7c3aed", "#ea580c", "#65a30d" };
    private string SubjectColor(string name) => _palette[Math.Abs(name?.GetHashCode() ?? 0) % _palette.Length];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _theme = await JS.InvokeAsync<string>("themeHelper.getTheme"); } catch { _theme = "light"; }
        await AuthService.InitializeAsync();
        _hasCheckedAuth = true;
        _userRole = AuthService.CurrentUser?.UserRole ?? "";
        if (!AuthService.IsAuthenticated) { Navigation.NavigateTo("/login"); return; }
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _isLoading = true; StateHasChanged();

        try { _myEnrollments = await SubjectService.GetMyEnrollmentsAsync(); } catch { _myEnrollments = new(); }
        try { _availableSubjects = await SubjectService.GetAvailableSubjectsAsync(); } catch { _availableSubjects = new(); }
        try { _tasks = await TaskService.GetMyTasksAsync(); } catch { _tasks = new(); }
        try { _schedule = await ScheduleService.GetMyScheduleAsync(); } catch { _schedule = new(); }

        // Már felvett tantárgyakat szűrjük ki az elérhető listából
        var enrolledIds = _myEnrollments.Select(e => e.SubjectID).ToHashSet();
        _availableSubjects = _availableSubjects.Where(s => !enrolledIds.Contains(s.SubjectID)).ToList();

        _isLoading = false;
    }

    private async Task RefreshSubjects()
    {
        _message = "";
        await LoadData();
        StateHasChanged();
    }

    // Sablon tantárgy felvétele (a sablon panelből)
    private async Task EnrollTemplate(int subjectId)
    {
        _enrollingIds.Add(subjectId);
        StateHasChanged();

        var r = await SubjectService.EnrollAsync(subjectId);
        _enrollingIds.Remove(subjectId);

        var isOk = r.Status == "OK" || r.Status == "SUCCESS" || r.Status == "ALREADY_ENROLLED";
        _messageIsError = !isOk;
        _message = isOk
            ? "Tantárgy sikeresen felvéve!"
            : r.Message;

        if (isOk) await LoadData();
        StateHasChanged();
    }

    // Egyéni tantárgy felvétele
    private async Task EnrollCustomSubject()
    {
        _customError = "";
        if (string.IsNullOrWhiteSpace(_customSubjectName)) { _customError = "A tantárgy neve kötelező."; return; }
        _customIsLoading = true; StateHasChanged();
        var r = await SubjectService.EnrollCustomAsync(_customSubjectName.Trim(), _customSubjectCode.Trim());
        _customIsLoading = false;
        if (r.Status == "OK" || r.Status == "SUCCESS")
        {
            _message = $"'{_customSubjectName}' hozzáadva."; _messageIsError = false;
            _customSubjectName = _customSubjectCode = ""; _showCustomForm = false;
            await LoadData();
        }
        else { _customError = r.Message; }
        StateHasChanged();
    }

    // Tantárgy leadása (drop)
    private async Task DropSubject(int subjectId)
    {
        _droppingIds.Add(subjectId);
        StateHasChanged();

        var r = await SubjectService.DropAsync(subjectId);
        _droppingIds.Remove(subjectId);

        var isOk = r.Status == "OK" || r.Status == "SUCCESS";
        _messageIsError = !isOk;
        _message = isOk ? "Tantárgy leadva." : r.Message;

        if (isOk) await LoadData();
        StateHasChanged();
    }

    private async Task ToggleTheme() { _theme = _theme == "dark" ? "light" : "dark"; await JS.InvokeVoidAsync("themeHelper.setTheme", _theme); StateHasChanged(); }
    private async Task HandleLogout() { await AuthService.Logout(); Navigation.NavigateTo("/login"); }
}

<style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

    /* ── Design tokens ── */
    .fr-layout {
        display:flex; flex-direction:row; width:100vw; height:100vh; overflow:hidden;
        background:var(--bg); font-family:var(--font,'Inter',system-ui,sans-serif); color:var(--text-primary);
        --accent:#667eea; --accent-2:#764ba2; --accent-hover:#5a6fd8;
        --accent-subtle:rgba(102,126,234,.12); --accent-subtle-strong:rgba(102,126,234,.2);
        --bg:#f4f2f8; --surface:#fff; --surface-2:#f0eef8;
        --border:#e2ddf0; --border-strong:#c4bce0;
        --text-primary:#1a1630; --text-secondary:#4a4470; --text-muted:#8880aa;
        --danger:#e53935; --danger-subtle:rgba(229,57,53,.09);
        --warning:#f59e0b; --warning-subtle:rgba(245,158,11,.1);
